##### App Launcher Icons #####

APPS_FILE="$HOME/.config/hub/apps.json"
if [ -f "$APPS_FILE" ]; then
    APP_COUNT=$(jq 'length' "$APPS_FILE" 2>/dev/null || echo 0)

    ICONS_DIR="$HOME/.config/hub/icons"

    # Only add app slots that have configured apps.
    for ((i=APP_COUNT; i>=1; i--)); do
        IDX=$((i-1))
        APP_ICON=$(jq -r --argjson i "$IDX" '.[$i] | .icon // .name' "$APPS_FILE" 2>/dev/null || echo "")
        # Use pre-extracted PNG if available; otherwise fall back to live app icon
        ICON_PNG="$ICONS_DIR/${APP_ICON}.png"
        if [ -f "$ICON_PNG" ]; then
            BG_IMAGE="$ICON_PNG"
        else
            BG_IMAGE="app.$APP_ICON"
        fi
        sketchybar --add item "app_slot.$i" right \
                   --set "app_slot.$i" \
                   drawing=on \
                   width=34 \
                   icon=● \
                   icon.drawing=off \
                   icon.align=center \
                   icon.width=34 \
                   icon.font="Hack Nerd Font:Bold:6.0" \
                   icon.color=0xff9ed072 \
                   icon.y_offset=-13 \
                   icon.padding_left=0 \
                   icon.padding_right=0 \
                   label.drawing=off \
                   label.width=0 \
                   label.padding_left=0 \
                   label.padding_right=0 \
                   background.drawing=on \
                   background.color=0x00000000 \
                   background.image="$BG_IMAGE" \
                   background.image.scale=0.78 \
                   background.image.padding_left=0 \
                   background.image.padding_right=0 \
                   background.height=40 \
                   background.y_offset=2 \
                   background.corner_radius=6 \
                   padding_left=0 \
                   padding_right=0 \
                   script="$PLUGIN_DIR/app_slot.sh" \
                   --subscribe "app_slot.$i" mouse.entered mouse.exited mouse.clicked
        sketchybar --add item "app_tip.$i" right \
                   --set "app_tip.$i" \
                   drawing=on \
                   width=8 \
                   icon.drawing=off \
                   label="$i" \
                   label.drawing=on \
                   label.font="Hack Nerd Font:Bold:9.0" \
                   label.color=0xaaffffff \
                   label.align=center \
                   label.width=8 \
                   label.padding_left=0 \
                   label.padding_right=0 \
                   label.y_offset=-6 \
                   background.drawing=on \
                   background.color=0x00000000 \
                   background.height=40 \
                   background.y_offset=2 \
                   background.corner_radius=6 \
                   padding_left=3 \
                   padding_right=0 \
                   script="$PLUGIN_DIR/app_slot.sh" \
                   --subscribe "app_tip.$i" mouse.clicked
    done

    # Build bracket member list: app_tip.1 app_slot.1 .. app_tip.N app_slot.N
    APP_SLOTS=()
    for ((i=1; i<=APP_COUNT; i++)); do
        APP_SLOTS+=("app_tip.$i")
        APP_SLOTS+=("app_slot.$i")
    done
    sketchybar --add bracket app_bracket "${APP_SLOTS[@]}" \
               --set app_bracket background.color=$ITEM_BG \
                                 background.corner_radius=9 \
                                 background.height=28 \
                                 background.border_width=2 \
                                 background.border_color=$ITEM_BG2

    # Hidden trigger: update running-app dots when focus changes (app open/close)
    sketchybar --add item app_refresh_trigger right \
               --set app_refresh_trigger \
               drawing=off \
               script="$PLUGIN_DIR/app_launcher.sh" \
               --subscribe app_refresh_trigger front_app_switched system_woke

    # One-shot icon refresh: fires ~8s after startup to recover from icon cache races,
    # then again on system_woke for the same reason.
    sketchybar --add item app_icon_init right \
               --set app_icon_init \
               drawing=off \
               update_freq=8 \
               script="$PLUGIN_DIR/app_icon_refresh.sh" \
               --subscribe app_icon_init system_woke

    # Spacer between the dynamic workspace-window module and static app launcher.
    sketchybar --add item pad_r5 right \
               --set pad_r5 width=22 icon.drawing=off label.drawing=off background.drawing=off
fi

