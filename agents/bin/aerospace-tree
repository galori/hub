#!/usr/bin/env python3
"""
Reconstruct AeroSpace's tiling tree from window geometry.

AeroSpace tiles windows by recursively splitting a workspace's screen area.
Since windows perfectly partition that area, we can recover the tree by finding
which windows share a full split edge and grouping them under a common H/V container.

Limitation: AeroSpace moves windows off-screen when their workspace isn't visible,
so only currently-visible workspaces produce accurate tree output. Hidden workspaces
show a flat list of windows with a "(hidden — geometry unavailable)" warning.

Usage:
  aerospace-tree [--workspace <ws>] [--json]
  aerospace-tree --all [--json]
"""

import json
import subprocess
import sys
from dataclasses import dataclass, field
from typing import Optional


@dataclass
class Rect:
    x: int
    y: int
    w: int
    h: int

    @property
    def right(self): return self.x + self.w
    @property
    def bottom(self): return self.y + self.h


@dataclass
class Window:
    window_id: int
    app: str
    title: str
    workspace: str
    rect: Optional[Rect] = None


@dataclass
class Node:
    split: Optional[str] = None       # "h" | "v" | None for leaf
    window: Optional[Window] = None   # set iff leaf
    children: list = field(default_factory=list)
    hidden: bool = False              # workspace was off-screen; geometry unreliable

    def to_dict(self):
        if self.window:
            w = self.window
            r = w.rect
            d = {"type": "window", "window-id": w.window_id, "app": w.app, "title": w.title}
            if r:
                d["rect"] = {"x": r.x, "y": r.y, "w": r.w, "h": r.h}
            return d
        d = {"type": f"split-{self.split}", "children": [c.to_dict() for c in self.children]}
        if self.hidden:
            d["note"] = "hidden workspace — geometry unavailable, order may be wrong"
        return d

    def to_text(self, indent=0):
        pad = "  " * indent
        if self.window:
            w = self.window
            r = w.rect
            geo = f" [{r.w}x{r.h} @ {r.x},{r.y}]" if r else ""
            return f"{pad}window {w.window_id}  {w.app}  {w.title!r}{geo}"
        label = f"[{self.split}-split]"
        if self.hidden:
            label += "  (hidden — geometry unavailable)"
        lines = [f"{pad}{label}"]
        for c in self.children:
            lines.append(c.to_text(indent + 1))
        return "\n".join(lines)


# ── geometry ──────────────────────────────────────────────────────────────────

def get_window_frames() -> dict[int, Rect]:
    swift = r"""
import Foundation
import CoreGraphics

let opts = CGWindowListOption([.optionOnScreenOnly, .excludeDesktopElements])
let info = CGWindowListCopyWindowInfo(opts, kCGNullWindowID) as! [[String: Any]]
var out: [[String: Any]] = []
for w in info {
    guard let wid    = w[kCGWindowNumber as String] as? Int,
          let bounds = w[kCGWindowBounds as String] as? [String: CGFloat]
    else { continue }
    out.append(["id": wid,
                "x": Int(bounds["X"] ?? 0),
                "y": Int(bounds["Y"] ?? 0),
                "w": Int(bounds["Width"] ?? 0),
                "h": Int(bounds["Height"] ?? 0)])
}
let data = try! JSONSerialization.data(withJSONObject: out)
print(String(data: data, encoding: .utf8)!)
"""
    try:
        result = subprocess.run(
            ["swift", "-"], input=swift, capture_output=True, text=True, timeout=15
        )
        return {
            e["id"]: Rect(e["x"], e["y"], e["w"], e["h"])
            for e in json.loads(result.stdout)
        }
    except Exception:
        return {}


# ── tree reconstruction ───────────────────────────────────────────────────────

TOLERANCE = 4  # pixels — allow minor AeroSpace rounding


def bounding_box(windows: list[Window]) -> Rect:
    xs      = [w.rect.x      for w in windows]
    ys      = [w.rect.y      for w in windows]
    rights  = [w.rect.right  for w in windows]
    bottoms = [w.rect.bottom for w in windows]
    return Rect(min(xs), min(ys), max(rights) - min(xs), max(bottoms) - min(ys))


def slice_by_cuts(windows, cuts, get_lo, get_hi):
    """Partition windows into ordered groups using a sorted list of cut coordinates."""
    groups = []
    remaining = list(windows)
    for cut in cuts:
        group = [w for w in remaining if get_hi(w) <= cut + TOLERANCE]
        remaining = [w for w in remaining if get_lo(w) >= cut - TOLERANCE]
        if group:
            groups.append(group)
    if remaining:
        groups.append(remaining)
    return groups


def find_groups(windows):
    """
    Find all clean cuts along one axis and return (axis, [group, ...]).
    Tries h-split (vertical cuts) first, then v-split (horizontal cuts).
    Returns None if no clean partition exists.
    """
    if len(windows) < 2:
        return None
    box = bounding_box(windows)

    # Collect all right-edges that aren't the bbox right — each is a candidate column boundary
    h_cuts = sorted({w.rect.right for w in windows if abs(w.rect.right - box.right) > TOLERANCE})
    if h_cuts:
        groups = slice_by_cuts(windows, h_cuts, lambda w: w.rect.x, lambda w: w.rect.right)
        if len(groups) >= 2 and sum(len(g) for g in groups) == len(windows):
            return ("h", groups)

    # Collect all bottom-edges that aren't the bbox bottom
    v_cuts = sorted({w.rect.bottom for w in windows if abs(w.rect.bottom - box.bottom) > TOLERANCE})
    if v_cuts:
        groups = slice_by_cuts(windows, v_cuts, lambda w: w.rect.y, lambda w: w.rect.bottom)
        if len(groups) >= 2 and sum(len(g) for g in groups) == len(windows):
            return ("v", groups)

    return None


def build_tree(windows: list[Window]) -> Node:
    if len(windows) == 1:
        return Node(window=windows[0])
    result = find_groups(windows)
    if result is None:
        return Node(split="h", children=[Node(window=w) for w in windows])
    axis, groups = result
    return Node(split=axis, children=[build_tree(g) for g in groups])


# ── aerospace CLI helpers ─────────────────────────────────────────────────────

def aerospace_json(*args) -> list[dict]:
    r = subprocess.run(["aerospace", *args, "--json"], capture_output=True, text=True)
    return json.loads(r.stdout) if r.stdout.strip() else []


def get_workspace_info() -> dict[str, dict]:
    r = subprocess.run(
        ["aerospace", "list-workspaces", "--all",
         "--format", "%{workspace}\t%{workspace-is-visible}"],
        capture_output=True, text=True
    )
    info = {}
    for line in r.stdout.splitlines():
        parts = line.split("\t")
        if len(parts) == 2:
            info[parts[0]] = {"visible": parts[1].strip() == "true"}
    return info


def get_windows_for_workspace(ws: str) -> list[Window]:
    r = subprocess.run(
        ["aerospace", "list-windows", "--workspace", ws,
         "--format", "%{window-id}\t%{app-name}\t%{window-title}"],
        capture_output=True, text=True
    )
    windows = []
    for line in r.stdout.splitlines():
        parts = line.split("\t", 2)
        if len(parts) == 3:
            windows.append(Window(int(parts[0]), parts[1], parts[2], ws))
    return windows


# ── main ──────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    as_json = "--json" in args
    args = [a for a in args if a != "--json"]

    ws_info = get_workspace_info()

    if "--workspace" in args:
        idx = args.index("--workspace")
        workspaces = [args[idx + 1]]
    elif "--all" in args:
        workspaces = list(ws_info.keys())
    else:
        r = subprocess.run(
            ["aerospace", "list-workspaces", "--focused"],
            capture_output=True, text=True
        )
        focused = r.stdout.strip()
        workspaces = [focused] if focused else list(ws_info.keys())

    frames = get_window_frames()

    result = {}
    for ws in workspaces:
        windows = get_windows_for_workspace(ws)
        if not windows:
            continue

        for w in windows:
            w.rect = frames.get(w.window_id)

        is_visible = ws_info.get(ws, {}).get("visible", False)

        if is_visible:
            with_geo    = [w for w in windows if w.rect]
            without_geo = [w for w in windows if not w.rect]
            tree = build_tree(with_geo) if with_geo else Node(split="h")
            for w in without_geo:
                tree.children.append(Node(window=w))
        else:
            # Hidden workspace: windows are stacked off-screen; can't recover split structure.
            tree = Node(split="h", hidden=True, children=[Node(window=w) for w in windows])

        result[ws] = tree

    if as_json:
        print(json.dumps({ws: t.to_dict() for ws, t in result.items()}, indent=2))
    else:
        for ws, tree in sorted(result.items()):
            print(f"workspace {ws}")
            print(tree.to_text(indent=1))
            print()


if __name__ == "__main__":
    main()
