#!/usr/bin/env bash
# Capture a screenshot of the sketchybar region (top of primary screen only).
# Usage: screenshot-bar [output.png]
# Requires: screencapture (macOS)

set -euo pipefail

OUT="${1:-/tmp/hub-bar-screenshot.png}"
BAR_HEIGHT=50
[ -f "$HOME/.config/hub/bar_tall" ] && BAR_HEIGHT=90

# Get primary display width via system_profiler (main display is listed first).
PRIMARY_WIDTH=""
if command -v system_profiler &>/dev/null; then
    PRIMARY_WIDTH=$(system_profiler SPDisplaysDataType 2>/dev/null \
        | awk '/Main Display: Yes/{found=1} found && /Resolution:/{if(match($0,/[0-9]+/)) print substr($0,RSTART,RLENGTH); exit}')
fi

# Fall back to trying common widths if system_profiler didn't yield a result.
if [[ ! "$PRIMARY_WIDTH" =~ ^[0-9]+$ ]] || [ "$PRIMARY_WIDTH" -eq 0 ]; then
    if [[ "${HUB_BAR_SCREEN_WIDTH:-}" =~ ^[0-9]+$ ]] && [ "$HUB_BAR_SCREEN_WIDTH" -gt 0 ]; then
        PRIMARY_WIDTH="$HUB_BAR_SCREEN_WIDTH"
    else
        for W in 3456 3024 2560 1920 1440; do
            if screencapture -x -R "0,0,${W},${BAR_HEIGHT}" "$OUT" 2>/dev/null; then
                echo "$OUT"
                exit 0
            fi
        done
        echo "Unable to capture the SketchyBar region" >&2
        exit 1
    fi
fi

screencapture -x -R "0,0,${PRIMARY_WIDTH},${BAR_HEIGHT}" "$OUT"
echo "$OUT"
