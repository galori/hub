#!/usr/bin/env bash
# Capture the Hub Bar, then keep the requested rectangle.
# Usage: screenshot-bar-cropped <x1> <y1> <x2> <y2> [output.png]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUT="/tmp/hub-bar-cropped.png"

usage() {
    cat <<'EOF'
Usage: screenshot-bar-cropped <x1> <y1> <x2> <y2> [output.png]

Arguments:
  x1          Left edge of the rectangle to keep, in screen points.
  y1          Top edge of the rectangle to keep, in screen points.
  x2          Right edge of the rectangle to keep, in screen points.
  y2          Bottom edge of the rectangle to keep, in screen points.
  output.png  Destination path. Defaults to /tmp/hub-bar-cropped.png.

Example:
  screenshot-bar-cropped 10 10 30 30
  Produces a 20x20 point crop. On Retina displays the PNG has more backing pixels.
EOF
}

is_number() {
    [[ "${1:-}" =~ ^[0-9]+$ ]]
}

if [ "$#" -eq 0 ]; then
    usage
    exit 0
fi

if [ "$#" -lt 4 ] || [ "$#" -gt 5 ]; then
    usage >&2
    exit 2
fi

X1="$1"
Y1="$2"
X2="$3"
Y2="$4"
if [ "$#" -eq 5 ]; then
    OUT="$5"
fi

if ! is_number "$X1" || ! is_number "$Y1" || ! is_number "$X2" || ! is_number "$Y2"; then
    echo "Coordinates must be non-negative integer pixels" >&2
    exit 2
fi

if [ "$X2" -le "$X1" ] || [ "$Y2" -le "$Y1" ]; then
    echo "Coordinates must describe a non-empty rectangle where x2 > x1 and y2 > y1" >&2
    exit 2
fi

TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/hub-bar-cropped.XXXXXX")"
FULL_IMG="$TMP_DIR/full.png"
trap 'rm -rf "$TMP_DIR"' EXIT

CAPTURE_OUTPUT="$("$SCRIPT_DIR/screenshot-bar" "$FULL_IMG")"
CAPTURED_IMG="$(printf '%s\n' "$CAPTURE_OUTPUT" | tail -n 1)"
if [[ -n "$CAPTURED_IMG" ]]; then
    FULL_IMG="$CAPTURED_IMG"
fi

WIDTH="$(sips -g pixelWidth "$FULL_IMG" | awk '/pixelWidth:/ {print $2; exit}')"
HEIGHT="$(sips -g pixelHeight "$FULL_IMG" | awk '/pixelHeight:/ {print $2; exit}')"
DPI_WIDTH="$(sips -g dpiWidth "$FULL_IMG" | awk '/dpiWidth:/ {print $2; exit}')"

if [[ ! "$WIDTH" =~ ^[0-9]+$ ]] || [[ ! "$HEIGHT" =~ ^[0-9]+$ ]] || [ "$WIDTH" -eq 0 ] || [ "$HEIGHT" -eq 0 ]; then
    echo "Unable to read screenshot dimensions" >&2
    exit 1
fi

SCALE="$(awk -v dpi="$DPI_WIDTH" 'BEGIN {
    if (dpi ~ /^[0-9]+([.][0-9]+)?$/ && dpi > 0) {
        printf "%.6f", dpi / 72
    } else {
        printf "1.000000"
    }
}')"

PX_X1="$(awk -v value="$X1" -v scale="$SCALE" 'BEGIN { printf "%d", int(value * scale + 0.5) }')"
PX_Y1="$(awk -v value="$Y1" -v scale="$SCALE" 'BEGIN { printf "%d", int(value * scale + 0.5) }')"
PX_X2="$(awk -v value="$X2" -v scale="$SCALE" 'BEGIN { printf "%d", int(value * scale + 0.5) }')"
PX_Y2="$(awk -v value="$Y2" -v scale="$SCALE" 'BEGIN { printf "%d", int(value * scale + 0.5) }')"

if [ "$PX_X1" -ge "$WIDTH" ] || [ "$PX_Y1" -ge "$HEIGHT" ] || [ "$PX_X2" -gt "$WIDTH" ] || [ "$PX_Y2" -gt "$HEIGHT" ]; then
    echo "Rectangle must fit inside image bounds (${WIDTH}x${HEIGHT})" >&2
    exit 2
fi

CROP_WIDTH=$((PX_X2 - PX_X1))
CROP_HEIGHT=$((PX_Y2 - PX_Y1))

if [ "$CROP_WIDTH" -le 0 ] || [ "$CROP_HEIGHT" -le 0 ]; then
    echo "Coordinates produce an empty backing-pixel rectangle at ${SCALE}x scale" >&2
    exit 2
fi

sips --cropOffset "$PX_Y1" "$PX_X1" \
    --cropToHeightWidth "$CROP_HEIGHT" "$CROP_WIDTH" \
    "$FULL_IMG" --out "$OUT" >/dev/null

echo "$OUT"
