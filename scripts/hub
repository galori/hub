#!/usr/bin/env bash
set -euo pipefail
# bash 5.3 enables patsub_replacement by default, making & in ${var//pat/repl}
# act as a sed-style backreference. This breaks URL substitution (& in query
# strings gets replaced by the pattern text). Disable it globally.
shopt -u patsub_replacement 2>/dev/null || true

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB_DIR="$REPO_DIR/lib"
CONFIG_DIR="$REPO_DIR/config"
AEROSPACE_CONFIG="$HOME/.aerospace.toml"
SKETCHYBAR_CONFIG_DIR="$HOME/.config/sketchybar"
OVERLAY_SRC="$LIB_DIR/overlay.swift"
OVERLAY_BIN="$HOME/.config/hub/overlay"
DIALOG_SRC="$LIB_DIR/new_workspace_dialog.swift"
DIALOG_BIN="$HOME/.config/hub/new_workspace_dialog"
CONFIRM_SRC="$LIB_DIR/confirm_dialog.swift"
CONFIRM_BIN="$HOME/.config/hub/confirm_dialog"
RENAME_SRC="$LIB_DIR/rename_dialog.swift"
RENAME_BIN="$HOME/.config/hub/rename_dialog"
DASHBOARD_SRC="$LIB_DIR/dashboard_dialog.swift"
DASHBOARD_BIN="$HOME/.config/hub/dashboard_dialog"
OUTPUT_WINDOW_SRC="$LIB_DIR/output_window.swift"
OUTPUT_WINDOW_BIN="$HOME/.config/hub/output_window"
HTTP_HANDLER_SRC="$LIB_DIR/http_handler.swift"
HTTP_HANDLER_APP="$HOME/Applications/HubHTTPHandler.app"
BROWSER_CTL_SRC="$LIB_DIR/browser_ctl.swift"
BROWSER_CTL_BIN="$HOME/.config/hub/browser_ctl"
SPATIAL_ORDER_SRC="$LIB_DIR/spatial_order.swift"
SPATIAL_ORDER_BIN="$HOME/.config/hub/spatial_order"
TESTING_BANNER_SRC="$LIB_DIR/testing_banner.swift"
TESTING_BANNER_BIN="$HOME/.config/hub/testing_banner"
TESTING_BANNER_PIDFILE="$HOME/.config/hub/testing_banner.pid"
PROGRESS_BANNER_SRC="$LIB_DIR/progress_banner.swift"
PROGRESS_BANNER_BIN="$HOME/.config/hub/progress_banner"
PROGRESS_BANNER_PIDFILE="$HOME/.config/hub/progress_banner.pid"
APP_SWITCHER_SRC="$LIB_DIR/app_switcher.swift"
APP_SWITCHER_BIN="$HOME/.config/hub/app_switcher"
APP_SWITCHER_LOCK_DIR="$HOME/.config/hub/.app-switcher-lock"
APP_SWITCHER_RESULT="/tmp/hub-app-switcher-result"
PREV_BROWSER_FILE="$HOME/.config/hub/prev_browser"
HUB_BROWSER_ID="sh.hub.http-handler"
WORKSPACES_FILE="$HOME/.config/hub/workspaces.json"
RECENT_REPOS_FILE="$HOME/.config/hub/recent_repos.json"
APPS_FILE="$HOME/.config/hub/apps.json"
HUB_CONFIG_FILE="$HOME/.config/hub/config.json"
ICONS_DIR="$HOME/.config/hub/icons"
APP_PRESETS_SRC="$CONFIG_DIR/app_presets.json"
APP_PRESETS_FILE="$HOME/.config/hub/app_presets.json"
APPLESCRIPT="$LIB_DIR/hide_menu_bar.applescript"
LOG_VIEWER_SRC="$LIB_DIR/log_viewer.swift"
LOG_VIEWER_BIN="$HOME/.config/hub/log_viewer"
HUB_LOG_FILE="$HOME/.config/hub/hub.log"
FULLSCREEN_STATE_FILE="$HOME/.config/hub/fullscreen"

# AeroSpace outer.top padding (px) — see config/aerospace.toml.
# tall = notch-avoidance / sketchybar-visible mode; normal = compact.
BAR_PADDING_NORMAL=55
BAR_PADDING_TALL=65

# Ensure standard binary paths are available — AeroSpace's exec-and-forget
# inherits a minimal environment that omits /usr/local/bin and /opt/homebrew/bin.
# Append only; any caller-prepended paths (e.g. test stubs) must stay first.
for _hub_p in /usr/local/bin /opt/homebrew/sbin /opt/homebrew/bin; do
    [[ ":$PATH:" != *":$_hub_p:"* ]] && PATH="$PATH:$_hub_p"
done
export PATH
unset _hub_p

# Colors
bold='\033[1m'
green='\033[32m'
yellow='\033[33m'
red='\033[31m'
blue='\033[34m'
reset='\033[0m'

print_usage() {
    echo -e "${bold}Usage:${reset} hub <command>"
    echo
    echo -e "${bold}Commands:${reset}"
    echo "  install       Install hub alias, check dependencies, compile binaries, and deploy configs"
    echo "  up            Start AeroSpace, SketchyBar, JankyBorders (restores fullscreen state if active)"
    echo "  down          Stop everything, restore the Dock and menu bar (preserves fullscreen state)"
    echo "  reboot        Stop, reinstall, and restart the hub environment"
    echo "  new           Create a new workspace (opens dialog; pass flags to run silently)"
    echo "  list          List all defined workspaces
  tree          Show the tiling tree for a workspace"
    echo "  status        Show current service state, workspace info, and label length"
    echo "  remove        Remove a workspace (current or by ID)"
    echo "  rename        Rename a workspace (current or by ID)"
    echo "  apps          Manage configured app launcher slots (list/add/edit/remove/reset)"
  echo "  open          Open configured apps in current workspace"
    echo "  app-switcher  Cmd-Tab-style cycle over launch-bar apps (Alt-N; hold Alt, tap N)"
    echo "  keys          List all AeroSpace key bindings (main and service mode)"
    echo "  dashboard     Show status and key bindings in a full-screen modal"
    echo "  label-length  Shrink or grow workspace label max length (+/-/grow/shrink/min/max/number)"
    echo "  bar-height    Toggle bar height for notch avoidance (tall/normal/toggle)"
    echo "  bar-reload    Reload sketchybar (fix rendering inconsistencies)"
    echo "  fullscreen    Hide/show the Dock and menu bar (on/off/toggle)"
    echo "  repo-prefix   Show or hide the repo name prefix on workspace labels (on/off/toggle)"
    echo "  config        Get/set hub options (e.g. claude_binary)"
    echo "  log           Show the hub action log (path + open in less; --window opens GUI viewer)"
    echo "  testing-banner Show a 'stand by' HUD while an automated session tests hub (start/stop/run)"
    echo "  claude-hooks  Manage Claude Code notification hooks (install/uninstall/status)"
    echo "  help          Show this help"
    echo
    echo -e "${bold}Examples:${reset}"
    echo "  hub install        # install shell alias and dependencies"
    echo "  hub up             # start the workspace environment"
    echo "  hub down           # tear down the workspace environment"
    echo "  hub new            # open the workspace creation dialog"
    echo "  hub new --path .   # create a workspace at CWD (no worktree)"
    echo "  hub new --worktree my-fix          # new worktree off CWD repo"
    echo "  hub new --no-repo --name scratch   # no-repo workspace"
    echo "  hub new --worktree my-fix --prompt 'fix the login redirect bug'"
    echo "  hub config                         # list all config"
    echo "  hub config set claude_binary 'claude --dangerously-skip-permissions'"
    echo "  hub list           # list all workspaces"
    echo "  hub list -v        # list with paths and root repos"
    echo "  hub remove         # remove the current workspace"
    echo "  hub remove A       # remove workspace A"
    echo "  hub remove A -y    # remove workspace A without confirmation"
    echo "  hub rename         # rename the current workspace"
    echo "  hub rename A       # rename workspace A"
    echo "  hub open           # interactive: focus or launch an app"
    echo "  hub open 1         # focus app 1 (or launch if not running)"
    echo "  hub open 1 --force # always launch a new window of app 1"
    echo "  hub open --all     # launch any missing apps into current workspace"
    echo "  hub tree           # show tiling tree for the focused workspace"
    echo "  hub tree --all     # show tiling tree for all non-empty workspaces"
    echo "  hub tree --workspace A  # show tiling tree for workspace A"
    echo
    echo -e "${bold}App launcher config:${reset}"
    echo "  Use 'hub apps' to manage up to 5 slots. Slot 1 = terminal, slot 2 = browser."
    echo "  Presets auto-wire prompt_launch (for 'hub new --prompt') and url_launch (for URL handling)."
    echo "  Placeholders: {path} = workspace folder, {workspace} = workspace ID."
}

success() { echo -e "  ${green}✓${reset} $1"; }
warn()    { echo -e "  ${yellow}!${reset} $1"; }
fail()    { echo -e "  ${red}✗${reset} $1"; }
info()    { echo -e "  ${blue}→${reset} $1"; }

# hub_log KIND MESSAGE — append a timestamped ANSI-colored entry to the action log.
# KIND: INPUT | CMD | OUT | ERR
hub_log() {
    local kind="$1" msg="$2"
    local ts
    ts="$(date '+%Y-%m-%d %H:%M:%S')"
    mkdir -p "$(dirname "$HUB_LOG_FILE")"
    # Dim timestamp, color by kind: green=INPUT, cyan=CMD, white=OUT, red=ERR
    local kind_color reset_c=$'\033[0m' dim=$'\033[2m'
    case "$kind" in
        INPUT) kind_color=$'\033[32m' ;;  # green
        CMD)   kind_color=$'\033[36m' ;;  # cyan
        OUT)   kind_color=$'\033[37m' ;;  # white
        ERR)   kind_color=$'\033[31m' ;;  # red
        *)     kind_color=$'\033[37m' ;;
    esac
    printf "${dim}[%s]${reset_c} ${kind_color}%s:${reset_c} %s\n" \
        "$ts" "$kind" "$msg" >> "$HUB_LOG_FILE"
}

read_superset_config() {
    local repo_root="$1" key="$2"
    local cfg="$repo_root/.superset/config.json"
    [[ -f "$cfg" ]] || return 1
    jq -r --arg k "$key" '.[$k][0] // empty' "$cfg" 2>/dev/null
}

# --- Workspaces-file lock (mkdir is atomic on POSIX; no flock on macOS) ---

HUB_LOCK_DIR="$HOME/.config/hub/.lock"
HUB_CONFIG_LOCK_DIR="$HOME/.config/hub/.config-lock"

_hub_lock_acquire() {
    local lockdir="${1:-$HUB_LOCK_DIR}"
    local deadline=$(( SECONDS + 5 ))
    while ! mkdir "$lockdir" 2>/dev/null; do
        (( SECONDS >= deadline )) && { fail "Timed out waiting for hub lock"; return 1; }
        sleep 0.05
    done
}

_hub_lock_release() {
    rmdir "${1:-$HUB_LOCK_DIR}" 2>/dev/null || true
}

# --- Overlay helpers ---

OVERLAY_PID=""
OVERLAY_FIFO=""

start_overlay() {
    local title="${1:-hub}"
    if [[ -x "$OVERLAY_BIN" ]]; then
        OVERLAY_FIFO="$(mktemp -u "${TMPDIR:-/tmp}/hub-overlay.XXXXXX")"
        mkfifo "$OVERLAY_FIFO" || {
            OVERLAY_FIFO=""
            return
        }
        "$OVERLAY_BIN" "$title" < "$OVERLAY_FIFO" &
        OVERLAY_PID=$!
        exec 3>"$OVERLAY_FIFO"
    fi
}

update_overlay() {
    local text="$1"
    if [[ -n "${OVERLAY_PID:-}" ]] && kill -0 "$OVERLAY_PID" 2>/dev/null; then
        echo "$text" >&3
    fi
}

stop_overlay() {
    if [[ -n "${OVERLAY_PID:-}" ]] && kill -0 "$OVERLAY_PID" 2>/dev/null; then
        echo "QUIT" >&3
        exec 3>&-
        wait "$OVERLAY_PID" 2>/dev/null || true
    fi
    OVERLAY_PID=""
    if [[ -n "${OVERLAY_FIFO:-}" ]]; then
        rm -f "$OVERLAY_FIFO"
        OVERLAY_FIFO=""
    fi
}

# --- Testing banner (small top-right "stand by" HUD for automated sessions) ---
cmd_testing_banner() {
    local sub="${1:-}"
    shift || true

    case "$sub" in
        start)
            local msg="${1:-Claude Code is testing hub — stand by}"
            if [[ ! -x "$TESTING_BANNER_BIN" ]]; then
                fail "testing_banner not compiled. Run: hub install"
                return 1
            fi
            # Kill any stale banner so there's never a duplicate.
            cmd_testing_banner stop >/dev/null 2>&1 || true
            # Keep the banner alive independent of the caller — it reads stdin,
            # so give it a stdin that stays open until `stop` closes it.
            local fifo
            fifo="$(mktemp -u "${TMPDIR:-/tmp}/hub-testing-banner.XXXXXX")"
            mkfifo "$fifo"
            # Hold the fifo open by redirecting a detached `sleep` into it.
            (sleep 86400 > "$fifo") &
            local holder_pid=$!
            "$TESTING_BANNER_BIN" "$msg" < "$fifo" >/dev/null 2>&1 &
            local banner_pid=$!
            disown "$banner_pid" "$holder_pid" 2>/dev/null || true
            mkdir -p "$(dirname "$TESTING_BANNER_PIDFILE")"
            printf "%s\n%s\n%s\n" "$banner_pid" "$holder_pid" "$fifo" > "$TESTING_BANNER_PIDFILE"
            ;;
        stop)
            [[ -f "$TESTING_BANNER_PIDFILE" ]] || return 0
            local banner_pid holder_pid fifo
            { read -r banner_pid; read -r holder_pid; read -r fifo; } < "$TESTING_BANNER_PIDFILE"
            [[ -n "$holder_pid" ]] && kill "$holder_pid" 2>/dev/null || true
            [[ -n "$banner_pid" ]] && kill "$banner_pid" 2>/dev/null || true
            [[ -n "$fifo" ]] && rm -f "$fifo"
            rm -f "$TESTING_BANNER_PIDFILE"
            ;;
        run)
            # Run a command with the banner up, stop on exit regardless of status.
            cmd_testing_banner start "Claude Code is testing hub — stand by"
            local rc=0
            "$@"
            rc=$?
            cmd_testing_banner stop
            return $rc
            ;;
        ""|help|--help|-h)
            echo "Usage:"
            echo "  hub testing-banner start [\"message\"]   Show the banner"
            echo "  hub testing-banner stop                   Hide the banner"
            echo "  hub testing-banner run -- <cmd> [args…]  Show banner, run cmd, then hide"
            ;;
        *)
            fail "Unknown testing-banner subcommand: $sub"
            return 1
            ;;
    esac
}

# --- Progress banner: user-facing HUD shown during hub workspace setup ---
# progress_banner_start [msg]  — launch the banner
# progress_banner_update msg   — update the message while running
# progress_banner_stop         — dismiss the banner

progress_banner_start() {
    local msg="${1:-Setting up workspace…}"
    [[ ! -x "$PROGRESS_BANNER_BIN" ]] && return 0
    progress_banner_stop 2>/dev/null || true
    local fifo
    fifo="$(mktemp -u "${TMPDIR:-/tmp}/hub-progress-banner.XXXXXX")"
    mkfifo "$fifo"
    (sleep 86400 > "$fifo") &
    local holder_pid=$!
    "$PROGRESS_BANNER_BIN" "$msg" < "$fifo" >/dev/null 2>&1 &
    local banner_pid=$!
    disown "$banner_pid" "$holder_pid" 2>/dev/null || true
    mkdir -p "$(dirname "$PROGRESS_BANNER_PIDFILE")"
    printf "%s\n%s\n%s\n" "$banner_pid" "$holder_pid" "$fifo" > "$PROGRESS_BANNER_PIDFILE"
}

progress_banner_update() {
    local msg="$1"
    [[ ! -f "$PROGRESS_BANNER_PIDFILE" ]] && return 0
    local banner_pid holder_pid fifo
    { read -r banner_pid; read -r holder_pid; read -r fifo; } < "$PROGRESS_BANNER_PIDFILE"
    # If the user dismissed the banner (✕), the process is gone — clean up and skip.
    if ! kill -0 "$banner_pid" 2>/dev/null; then
        [[ -n "$holder_pid" ]] && kill "$holder_pid" 2>/dev/null || true
        [[ -n "$fifo" ]] && rm -f "$fifo"
        rm -f "$PROGRESS_BANNER_PIDFILE"
        return 0
    fi
    [[ -n "$fifo" && -p "$fifo" ]] && (printf "%s\n" "$msg" > "$fifo") & disown 2>/dev/null || true
}

progress_banner_error() {
    local msg="${1:-Failed}"
    [[ ! -f "$PROGRESS_BANNER_PIDFILE" ]] && return 0
    local banner_pid holder_pid fifo
    { read -r banner_pid; read -r holder_pid; read -r fifo; } < "$PROGRESS_BANNER_PIDFILE"
    if ! kill -0 "$banner_pid" 2>/dev/null; then
        rm -f "$PROGRESS_BANNER_PIDFILE"
        return 0
    fi
    # Send ERROR: — the banner will auto-dismiss after 2.5s
    [[ -n "$fifo" && -p "$fifo" ]] && (printf "ERROR:%s\n" "$msg" > "$fifo") & disown 2>/dev/null || true
    sleep 2.6
    [[ -n "$holder_pid" ]] && kill "$holder_pid" 2>/dev/null || true
    [[ -n "$fifo" ]] && rm -f "$fifo"
    rm -f "$PROGRESS_BANNER_PIDFILE"
}

progress_banner_stop() {
    [[ -f "$PROGRESS_BANNER_PIDFILE" ]] || return 0
    local banner_pid holder_pid fifo
    { read -r banner_pid; read -r holder_pid; read -r fifo; } < "$PROGRESS_BANNER_PIDFILE"
    rm -f "$PROGRESS_BANNER_PIDFILE"
    # Send QUIT while holder_pid is still alive (it keeps the fifo readable).
    # Then kill the holder so EOF closes the pipe, and allow ~0.15s for the
    # fade-out animation before killing the process as a fallback.
    if [[ -n "$fifo" && -p "$fifo" ]]; then
        printf "QUIT\n" > "$fifo" &
        local write_pid=$!
        sleep 0.05
        kill "$write_pid" 2>/dev/null || true
    fi
    [[ -n "$holder_pid" ]] && kill "$holder_pid" 2>/dev/null || true
    sleep 0.2
    [[ -n "$banner_pid" ]] && kill "$banner_pid" 2>/dev/null || true
    [[ -n "$fifo" ]] && rm -f "$fifo"
}

# --- App switcher: Cmd-Tab-style cycle over the mini launch bar apps ---
# First Alt-N press launches the Swift modal and blocks until the user releases
# Option (commit) or presses Esc (cancel). Subsequent Alt-N presses while the
# modal is up just signal it (SIGUSR1) to advance the highlight, then return.
# The atomic mkdir lock both prevents a second modal and stores the modal's pid.
cmd_app_switcher() {
    [[ -x "$APP_SWITCHER_BIN" ]] || return 0
    [[ -f "$APPS_FILE" ]] || return 0
    # No apps configured → nothing to switch between.
    local app_count
    app_count="$(jq 'length' "$APPS_FILE" 2>/dev/null || echo 0)"
    [[ "$app_count" -gt 0 ]] || return 0

    # Try to become the owner. If mkdir fails, a modal is already running.
    if ! mkdir "$APP_SWITCHER_LOCK_DIR" 2>/dev/null; then
        # Advance the existing modal. The pid file may not exist yet during a
        # cold-start race, so retry briefly before giving up.
        local pid="" tries=0
        while [[ -z "$pid" && $tries -lt 20 ]]; do
            pid="$(cat "$APP_SWITCHER_LOCK_DIR/pid" 2>/dev/null || true)"
            [[ -n "$pid" ]] && break
            sleep 0.02
            tries=$((tries + 1))
        done
        [[ -n "$pid" ]] && kill -USR1 "$pid" 2>/dev/null || true
        return 0
    fi

    # We own the lock — run the modal to completion.
    rm -f "$APP_SWITCHER_RESULT"
    "$APP_SWITCHER_BIN" &
    local sw_pid=$!
    echo "$sw_pid" > "$APP_SWITCHER_LOCK_DIR/pid"
    wait "$sw_pid" 2>/dev/null || true

    # Launch whatever was selected (force a new window, like Cmd-F1..F5).
    local slot=""
    [[ -f "$APP_SWITCHER_RESULT" ]] && slot="$(cat "$APP_SWITCHER_RESULT" 2>/dev/null || true)"

    rm -rf "$APP_SWITCHER_LOCK_DIR"
    rm -f "$APP_SWITCHER_RESULT"

    if [[ -n "$slot" ]]; then
        cmd_open "$slot" --force
    fi
}

# --- Menu bar toggle (AppleScript, non-blocking) ---

MENU_BAR_PID=""

toggle_menu_bar() {
    local hidden="$1"
    if [[ "$hidden" == "true" ]]; then
        osascript "$APPLESCRIPT" "Always" &>/dev/null &
    else
        osascript "$APPLESCRIPT" "Never" &>/dev/null &
    fi
    MENU_BAR_PID=$!
}

wait_for_menu_bar() {
    if [[ -n "${MENU_BAR_PID:-}" ]]; then
        wait "$MENU_BAR_PID" 2>/dev/null || true
        killall "System Settings" 2>/dev/null || true
        MENU_BAR_PID=""
    fi
}

# Hide the Dock and menu bar. Blocks until the menu-bar AppleScript finishes.
_fullscreen_apply() {
    toggle_menu_bar true
    defaults write com.apple.dock autohide -bool true
    defaults write com.apple.dock autohide-delay -float 1000
    defaults write com.apple.dock autohide-time-modifier -float 0
    killall Dock
    wait_for_menu_bar
}

# Restore the Dock and menu bar.
_fullscreen_restore() {
    toggle_menu_bar false
    defaults write com.apple.dock autohide -bool false
    defaults delete com.apple.dock autohide-delay 2>/dev/null || true
    defaults delete com.apple.dock autohide-time-modifier 2>/dev/null || true
    killall Dock
    wait_for_menu_bar
}

# --- Brew helpers ---

check_brew_package() {
    local pkg="$1"
    local cask="$2"
    if [[ "$cask" == "true" ]]; then
        brew list --cask "$pkg" &>/dev/null
    else
        brew list "$pkg" &>/dev/null
    fi
}

install_brew_package() {
    local pkg="$1"
    local cask="$2"
    if [[ "$cask" == "true" ]]; then
        brew install --cask "$pkg"
    else
        brew install "$pkg"
    fi
}

# --- Compile overlay ---

compile_swift() {
    local name="$1"
    local src="$2"
    local bin="$3"

    if [[ ! -f "$src" ]]; then
        warn "$name source not found — skipping"
        return
    fi

    if [[ -f "$bin" ]] && [[ "$bin" -nt "$src" ]]; then
        info "$name up to date"
        return
    fi

    mkdir -p "$(dirname "$bin")"
    if swiftc -O -o "$bin" -framework Cocoa "$src" 2>/dev/null; then
        success "$name compiled: $bin"
    else
        warn "$name compilation failed"
    fi
}

compile_all() {
    echo -e "${bold}Compiling Swift binaries...${reset}"
    compile_swift "overlay" "$OVERLAY_SRC" "$OVERLAY_BIN"
    compile_swift "new_workspace_dialog" "$DIALOG_SRC" "$DIALOG_BIN"
    compile_swift "confirm_dialog" "$CONFIRM_SRC" "$CONFIRM_BIN"
    compile_swift "rename_dialog" "$RENAME_SRC" "$RENAME_BIN"
    compile_swift "dashboard_dialog" "$DASHBOARD_SRC" "$DASHBOARD_BIN"
    compile_swift "browser_ctl" "$BROWSER_CTL_SRC" "$BROWSER_CTL_BIN"
    compile_swift "output_window" "$OUTPUT_WINDOW_SRC" "$OUTPUT_WINDOW_BIN"
    compile_swift "spatial_order" "$SPATIAL_ORDER_SRC" "$SPATIAL_ORDER_BIN"
    compile_swift "testing_banner" "$TESTING_BANNER_SRC" "$TESTING_BANNER_BIN"
    compile_swift "progress_banner" "$PROGRESS_BANNER_SRC" "$PROGRESS_BANNER_BIN"
    compile_swift "app_switcher" "$APP_SWITCHER_SRC" "$APP_SWITCHER_BIN"
    compile_swift "log_viewer" "$LOG_VIEWER_SRC" "$LOG_VIEWER_BIN"
    if [[ -f "$REPO_DIR/assets/hub-logo.png" ]]; then
        cp "$REPO_DIR/assets/hub-logo.png" "$HOME/.config/hub/hub-logo.png"
        success "hub-logo.png deployed"
    fi
    build_http_handler
}

build_http_handler() {
    local src="$HTTP_HANDLER_SRC"
    local app="$HTTP_HANDLER_APP"
    local bin="$app/Contents/MacOS/HubHTTPHandler"
    local plist="$app/Contents/Info.plist"

    if [[ ! -f "$src" ]]; then
        warn "http_handler source not found — skipping"
        return
    fi

    if [[ -f "$bin" ]] && [[ "$bin" -nt "$src" ]] && [[ "$bin" -nt "${BASH_SOURCE[0]}" ]]; then
        info "HubHTTPHandler.app up to date"
        return
    fi

    mkdir -p "$app/Contents/MacOS"
    mkdir -p "$app/Contents/Resources"

    cat > "$plist" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>sh.hub.http-handler</string>
    <key>CFBundleName</key>
    <string>HubHTTPHandler</string>
    <key>CFBundleDisplayName</key>
    <string>Hub HTTP Handler</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleExecutable</key>
    <string>HubHTTPHandler</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>HTTP URL</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>http</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleURLName</key>
            <string>HTTPS URL</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>https</string>
            </array>
        </dict>
    </array>
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.html</string>
                <string>public.xhtml</string>
            </array>
        </dict>
    </array>
    <key>LSHandlerRank</key>
    <string>Alternate</string>
    <key>LSUIElement</key>
    <true/>
</dict>
</plist>
PLIST

    if swiftc -O -o "$bin" -framework Cocoa "$src" 2>/dev/null; then
        # Register with Launch Services so it appears in Default Web Browser list
        /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister \
            -f "$app" 2>/dev/null || true
        # Restart if already running so the new binary takes effect
        if pgrep -qf "HubHTTPHandler.app/Contents/MacOS/HubHTTPHandler"; then
            pkill -f "HubHTTPHandler.app/Contents/MacOS/HubHTTPHandler" 2>/dev/null || true
            sleep 0.3
            open -a "$app" &
        fi
        success "HubHTTPHandler.app built and registered: $app"
    else
        warn "HubHTTPHandler.app compilation failed"
    fi
}

# --- Shared libraries ---

APPS_FLOW_LIB="$SCRIPT_DIR/lib/apps_flow.sh"
[ -f "$APPS_FLOW_LIB" ] && source "$APPS_FLOW_LIB"

# --- Commands ---

extract_app_icons() {
    mkdir -p "$ICONS_DIR"
    local count=0
    while IFS= read -r icon_name; do
        [ -z "$icon_name" ] && continue
        local out="$ICONS_DIR/${icon_name}.png"
        # Use osascript to resolve the app path by display name (same lookup SketchyBar uses)
        local app_path
        app_path=$(osascript -e "POSIX path of (path to application \"$icon_name\")" 2>/dev/null || true)
        [ -z "$app_path" ] && continue
        app_path="${app_path%$'\n'}"
        # Use the icon declared in Info.plist; fall back to first icns found
        local icns_name icns
        icns_name=$(/usr/libexec/PlistBuddy -c "Print :CFBundleIconFile" "${app_path}Contents/Info.plist" 2>/dev/null || true)
        [[ "$icns_name" != *.icns ]] && icns_name="${icns_name}.icns"
        icns="${app_path}Contents/Resources/${icns_name}"
        if [ ! -f "$icns" ]; then
            icns=$(find "${app_path}Contents/Resources" -maxdepth 1 -name "*.icns" 2>/dev/null | head -1)
        fi
        [ -z "$icns" ] && continue
        sips -s format png "$icns" --out "$out" --resampleHeightWidthMax 36 &>/dev/null && count=$((count+1))
    done < <(jq -r '.[].icon // .[].name' "$APPS_FILE" 2>/dev/null)
    [ "$count" -gt 0 ] && success "Extracted $count app icon(s) to $ICONS_DIR"
}

cmd_install() {
    echo -e "${bold}Installing hub...${reset}\n"

    # --- Check dependencies ---
    echo -e "${bold}Checking dependencies...${reset}"
    local missing=()
    local missing_cask=()

    if check_brew_package aerospace true; then
        success "aerospace is installed"
    else
        fail "aerospace is not installed"
        missing+=(aerospace)
        missing_cask+=(true)
    fi

    if check_brew_package sketchybar false; then
        success "sketchybar is installed"
    else
        fail "sketchybar is not installed"
        missing+=(sketchybar)
        missing_cask+=(false)
    fi

    if check_brew_package borders false; then
        success "borders (JankyBorders) is installed"
    else
        fail "borders (JankyBorders) is not installed"
        missing+=(borders)
        missing_cask+=(false)
    fi

    if command -v jq &>/dev/null; then
        success "jq is installed"
    else
        fail "jq is not installed"
        missing+=(jq)
        missing_cask+=(false)
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo
        echo -e "Missing packages: ${bold}${missing[*]}${reset}"
        if [[ "${HUB_NONINTERACTIVE:-}" == "1" ]]; then answer="n"; else read -rp "Install them now? [y/N] " answer; fi
        if [[ "$answer" =~ ^[Yy]$ ]]; then
            for i in "${!missing[@]}"; do
                echo -e "\nInstalling ${bold}${missing[$i]}${reset}..."
                install_brew_package "${missing[$i]}" "${missing_cask[$i]}"
                success "${missing[$i]} installed"
            done
        else
            echo "Skipping package installation. Some features may not work."
        fi
    fi

    # --- Deploy aerospace config ---
    echo
    echo -e "${bold}Deploying configs...${reset}"
    if [[ -f "$AEROSPACE_CONFIG" ]]; then
        if grep -q "# AeroSpace config managed by hub" "$AEROSPACE_CONFIG" 2>/dev/null; then
            success "aerospace.toml already managed by hub, updating"
        else
            warn "existing aerospace.toml found, backing up to ${AEROSPACE_CONFIG}.bak"
            cp "$AEROSPACE_CONFIG" "${AEROSPACE_CONFIG}.bak"
        fi
    fi
    local outer_top=$BAR_PADDING_NORMAL
    [[ -f "$HOME/.config/hub/bar_tall" ]] && outer_top=$BAR_PADDING_TALL
    sed -e "s|__HUB_SCRIPT__|$REPO_DIR/scripts/hub|g" \
        -e "s|__HUB_OUTER_TOP__|$outer_top|g" \
        "$CONFIG_DIR/aerospace.toml" > "$AEROSPACE_CONFIG"
    success "aerospace.toml deployed to $AEROSPACE_CONFIG"

    # Write hub script path for runtime use by HubHTTPHandler and other compiled binaries
    echo "$REPO_DIR/scripts/hub" > "$HOME/.config/hub/hub_path"

    # --- Deploy sketchybar config ---
    if [[ -d "$SKETCHYBAR_CONFIG_DIR" ]]; then
        rm -rf "$SKETCHYBAR_CONFIG_DIR"
        info "removed existing sketchybar config"
    fi
    mkdir -p "$SKETCHYBAR_CONFIG_DIR/plugins"
    sed "s|__HUB_SCRIPT__|$REPO_DIR/scripts/hub|g" "$CONFIG_DIR/sketchybar/sketchybarrc" > "$SKETCHYBAR_CONFIG_DIR/sketchybarrc"
    for f in "$CONFIG_DIR/sketchybar/plugins/"*.sh; do
        sed "s|__HUB_SCRIPT__|$REPO_DIR/scripts/hub|g" "$f" > "$SKETCHYBAR_CONFIG_DIR/plugins/$(basename "$f")"
    done
    chmod +x "$SKETCHYBAR_CONFIG_DIR/sketchybarrc" "$SKETCHYBAR_CONFIG_DIR/plugins/"*.sh
    success "sketchybar config deployed to $SKETCHYBAR_CONFIG_DIR"

    # --- Deploy app presets database ---
    mkdir -p "$(dirname "$APPS_FILE")"
    if [[ -f "$APP_PRESETS_SRC" ]]; then
        cp "$APP_PRESETS_SRC" "$APP_PRESETS_FILE"
        success "App presets deployed to $APP_PRESETS_FILE"
    fi

    # --- Configure app launcher slots ---
    if [[ ! -f "$APPS_FILE" ]]; then
        echo
        echo -e "${bold}Let's configure your app launcher.${reset}"
        echo "  The launcher gives you up to 5 slots, each bound to Ctrl+Alt+<1..5>."
        echo "  You can customize this any time with: hub apps"
        echo
        local _start
        if [[ "${HUB_NONINTERACTIVE:-}" == "1" ]]; then _start="n"; else read -rp "  Start guided setup now? [Y/n] " _start; fi
        if [[ -z "$_start" || "$_start" =~ ^[Yy] ]]; then
            echo "[]" > "$APPS_FILE"
            local _slot
            for _slot in 1 2 3 4 5; do
                echo
                echo -e "${bold}─── Slot $_slot of 5 ───${reset}"
                if ! apps_add_guided "$_slot"; then
                    info "Stopping guided setup. Add more later with: hub apps add"
                    break
                fi
                echo
                if [ "$_slot" -lt 5 ]; then
                    local _more
                    read -rp "  Add another app? [Y/n] " _more
                    [[ "$_more" =~ ^[Nn] ]] && { info "Stopping. Add more later with: hub apps add"; break; }
                fi
            done
        else
            echo "[]" > "$APPS_FILE"
            info "Created empty apps.json. Add apps with: hub apps add"
        fi
    else
        info "apps.json already exists — manage slots with: hub apps list / add / edit / remove"
    fi

    # --- Extract app icons for sketchybar (works even when apps are not running) ---
    extract_app_icons

    # --- Global gitignore for worktrees/ ---
    echo
    echo -e "${bold}Configuring global gitignore...${reset}"
    local global_gitignore
    global_gitignore="$(git config --global core.excludesFile 2>/dev/null || echo "")"
    if [[ -z "$global_gitignore" ]]; then
        global_gitignore="$HOME/.gitignore_global"
        git config --global core.excludesFile "$global_gitignore"
        success "Set core.excludesFile to $global_gitignore"
    else
        global_gitignore="${global_gitignore/#\~/$HOME}"
        success "Using existing core.excludesFile: $global_gitignore"
    fi
    if [[ ! -f "$global_gitignore" ]]; then
        touch "$global_gitignore"
    fi
    if ! grep -q '^worktrees/$' "$global_gitignore" 2>/dev/null; then
        echo "worktrees/" >> "$global_gitignore"
        success "Added worktrees/ to $global_gitignore"
    else
        info "worktrees/ already in $global_gitignore"
    fi

    # --- Compile Swift binaries ---
    echo
    compile_all

    # --- Install shell alias ---
    echo
    echo -e "${bold}Installing shell alias...${reset}"

    local shell_name
    case "$SHELL" in
        */zsh)  shell_name=zsh ;;
        */bash) shell_name=bash ;;
        */fish) shell_name=fish ;;
        *)
            fail "Unsupported shell: $SHELL"
            echo "Add this alias manually: alias hub='$REPO_DIR/scripts/hub'"
            return
            ;;
    esac
    success "Detected shell: $shell_name"

    local snippet_path="$REPO_DIR/.hub-shell-integration"
    local script_path
    script_path="$(printf '%q' "$REPO_DIR/scripts/hub")"

    if [[ "$shell_name" == "fish" ]]; then
        echo "alias hub $script_path" > "$snippet_path"
    else
        echo "alias hub=$script_path" > "$snippet_path"
    fi
    success "Created $snippet_path"

    local config_file
    case "$shell_name" in
        zsh)  config_file="$HOME/.zshrc" ;;
        bash)
            if [[ "$(uname)" == "Darwin" ]]; then
                config_file="$HOME/.bash_profile"
            else
                config_file="$HOME/.bashrc"
            fi
            ;;
        fish) config_file="$HOME/.config/fish/config.fish" ;;
    esac

    if [[ -f "$config_file" ]] && grep -q '.hub-shell-integration' "$config_file" 2>/dev/null; then
        warn "Already installed in $config_file"
    else
        if [[ "$shell_name" == "fish" ]]; then
            mkdir -p "$(dirname "$config_file")"
            printf '\n# hub workspace integration\nsource %s\n' "'$snippet_path'" >> "$config_file"
        else
            printf '\n# hub workspace integration\nsource %s\n' "$snippet_path" >> "$config_file"
        fi
        success "Added to $config_file"
    fi

    # --- Deploy Claude slash commands ---
    # Generic commands live in commands/; private/company-specific ones live in
    # the gitignored commands.local/. Both are deployed to ~/.claude/commands/.
    echo
    echo -e "${bold}Deploying Claude commands...${reset}"
    local _cmd_dst="$HOME/.claude/commands"
    mkdir -p "$_cmd_dst"
    local _cmd_file
    for _cmd_file in "$REPO_DIR/commands/"*.md "$REPO_DIR/commands.local/"*.md; do
        [[ -f "$_cmd_file" ]] || continue
        cp "$_cmd_file" "$_cmd_dst/$(basename "$_cmd_file")"
        success "Deployed $(basename "$_cmd_file")"
    done

    # --- Reload running services ---
    echo
    echo -e "${bold}Reloading services...${reset}"
    if pgrep -q sketchybar; then
        sketchybar --reload 2>/dev/null || true
        success "SketchyBar reloaded"
    fi
    if pgrep -q AeroSpace; then
        aerospace reload-config 2>/dev/null || true
        success "AeroSpace config reloaded"
    fi

    echo
    rm -f "$KEYS_CACHE"

    echo -e "${green}${bold}Installation complete!${reset}"
    echo
    echo "To activate, run:"
    echo "  source $config_file"
    echo
    echo "Or open a new terminal."
    echo
    echo -e "  Tip: run ${bold}hub apps${reset} to list or modify your app launcher slots."
    echo -e "  Then use ${bold}Ctrl+Alt+O${reset} or ${bold}hub open${reset} to launch apps into the current workspace."
}

cmd_new() {
    # Bare `hub new` (no flags) ⇒ launch dialog. Any flag ⇒ non-interactive.
    if [[ $# -gt 0 ]]; then
        _cmd_new_cli "$@"
        return $?
    fi

    if [[ ! -x "$DIALOG_BIN" ]]; then
        fail "new_workspace_dialog not compiled. Run: hub install"
        exit 1
    fi

    # Clean up any stale result
    rm -f /tmp/hub-new-workspace

    # Launch the dialog and wait
    "$DIALOG_BIN"

    # Read result
    local result
    result="$(cat /tmp/hub-new-workspace 2>/dev/null || echo "cancel")"
    rm -f /tmp/hub-new-workspace

    if [[ "$result" == "cancel" || -z "$result" ]]; then
        echo "Cancelled."
        return
    fi

    # Parse: name\tpath\troot_repo\tworkspace_id\tcolor\tsetup_cmd\tapps\tprompt_b64
    # ("-" = empty for color/setup_cmd/apps; prompt_b64 is empty when no prompt)
    local ws_name ws_path ws_root ws_id ws_color ws_setup_cmd ws_apps ws_prompt_b64
    IFS=$'\t' read -r ws_name ws_path ws_root ws_id ws_color ws_setup_cmd ws_apps ws_prompt_b64 <<< "$result"
    [[ "$ws_color" == "-" ]] && ws_color=""
    [[ "$ws_setup_cmd" == "-" ]] && ws_setup_cmd=""
    [[ "$ws_apps" == "-" ]] && ws_apps=""

    # Prompt is base64-encoded by the dialog so newlines and tabs survive
    # the tab-delimited result format.
    local ws_prompt=""
    if [[ -n "$ws_prompt_b64" ]]; then
        ws_prompt="$(printf '%s' "$ws_prompt_b64" | base64 -d 2>/dev/null || true)"
    fi

    if [[ -z "$ws_name" || -z "$ws_id" ]]; then
        fail "Invalid dialog result"
        return
    fi

    # "-" means no repo — treat path as home dir, no iTerm cd, no recent_repos entry
    local no_repo=false
    if [[ "$ws_path" == "-" || -z "$ws_path" ]]; then
        no_repo=true
        ws_path="$HOME"
        ws_root=""
    fi

    _create_workspace "$ws_name" "$ws_path" "$ws_root" "$ws_id" "$ws_color" "$ws_setup_cmd" "$ws_apps" "$no_repo" "$ws_prompt" "false"
}

_create_workspace() {
    local ws_name="$1"
    local ws_path="$2"
    local ws_root="$3"
    local ws_id="$4"
    local ws_color="$5"
    local ws_setup_cmd="$6"
    local ws_apps="$7"
    local no_repo="${8:-false}"
    local ws_prompt="${9:-}"
    local ws_apps_set="${10:-false}"

    hub_log "INPUT" "new workspace name='$ws_name' id='$ws_id' path='$ws_path'"
    success "Creating workspace: $ws_name (workspace $ws_id)"
    [[ "$no_repo" == "false" ]] && info "Path: $ws_path"

    progress_banner_start "Creating workspace ${ws_name}..."
    # Ensure the banner is always dismissed even on unexpected early exit.
    trap 'progress_banner_stop 2>/dev/null || true; trap - EXIT' EXIT

    # Save to workspaces.json — hold the lock for the entire read→check→write
    mkdir -p "$(dirname "$WORKSPACES_FILE")"
    _hub_lock_acquire || { progress_banner_error "Failed to acquire lock"; return 1; }

    local existing="[]"
    [[ -f "$WORKSPACES_FILE" ]] && existing="$(cat "$WORKSPACES_FILE")"

    # Auto-allocate ID inside the lock so no concurrent caller can grab the same one
    if [[ -z "$ws_id" ]]; then
        ws_id="$(_alloc_workspace_id "$existing")" || {
            _hub_lock_release
            progress_banner_error "No free workspace IDs"
            fail "No free workspace IDs available"
            return 1
        }
    fi

    if echo "$existing" | jq -e --arg id "$ws_id" '.[] | select(.workspace_id == $id)' >/dev/null 2>&1; then
        _hub_lock_release
        progress_banner_error "Workspace ID already in use"
        fail "Workspace ID '$ws_id' is already in use"
        return 1
    fi
    if echo "$existing" | jq -e --arg n "$ws_name" '.[] | select(.name == $n)' >/dev/null 2>&1; then
        _hub_lock_release
        progress_banner_error "'$ws_name' already exists"
        fail "A workspace named '$ws_name' already exists"
        return 1
    fi

    local updated
    if [[ -n "$ws_color" ]]; then
        updated="$(echo "$existing" | jq --arg name "$ws_name" --arg path "$ws_path" \
            --arg root "$ws_root" --arg id "$ws_id" --arg color "$ws_color" \
            '. + [{name: $name, path: $path, root_repo: $root, workspace_id: $id, color: $color}]')"
    else
        updated="$(echo "$existing" | jq --arg name "$ws_name" --arg path "$ws_path" \
            --arg root "$ws_root" --arg id "$ws_id" \
            '. + [{name: $name, path: $path, root_repo: $root, workspace_id: $id}]')"
    fi

    echo "$updated" > "$WORKSPACES_FILE"
    _hub_lock_release
    success "Saved to $WORKSPACES_FILE"

    # Build the prompt wrapper now that ws_id is finalized — HUB_WORKSPACE_ID
    # can be baked in for exact workspace identification by the notify hook.
    local prompt_cmd
    prompt_cmd="$(_build_prompt_cmd "$ws_prompt" "$ws_apps" "$ws_apps_set" "$ws_id")"

    # Update recent_repos.json (skip for no-repo workspaces)
    if [[ "$no_repo" == "false" ]]; then
        local recent_repo="${ws_root:-$ws_path}"
        local existing_recent="[]"
        if [[ -f "$RECENT_REPOS_FILE" ]]; then
            existing_recent="$(cat "$RECENT_REPOS_FILE")"
        fi
        echo "$existing_recent" | jq --arg r "$recent_repo" \
            '[$r] + (map(select(. != $r))) | .[0:20]' > "$RECENT_REPOS_FILE"
    fi

    # Update sketchybar label
    update_sketchybar_label "$ws_id" "$ws_name"

    # Switch to the workspace
    aerospace workspace "$ws_id"
    success "Switched to workspace $ws_id"

    # Open checked apps sequentially; collect new window IDs for layout arrangement
    local _opened_wids=()
    if [[ -n "$ws_apps" ]]; then
        IFS=',' read -ra _slots <<< "$ws_apps"
        for _slot in "${_slots[@]}"; do
            OPEN_APP_SLOT_WID=""
            OPEN_APP_SLOT_CORRALLED=false
            open_app_slot "$_slot" "$ws_id" "$ws_path" false true "$prompt_cmd"
            if [[ -n "$OPEN_APP_SLOT_WID" ]]; then
                _opened_wids+=("$OPEN_APP_SLOT_WID")
            fi
        done
    fi

    # Run worktree setup command in background output_window.
    # Use zsh --no-rcs + manual source of ~/.zshrc so user-exported env vars
    # (e.g. BUNDLE_WITHOUT) are available when hub is launched from AeroSpace
    # with a minimal environment, without the interactive-shell noise from zsh -i.
    if [[ -n "$ws_setup_cmd" && -n "$ws_root" ]]; then
        progress_banner_update "Setting up worktree…"
        local full_setup_cmd="$ws_root/$ws_setup_cmd"
        local _wrap="source \"\$HOME/.zshrc\" 2>/dev/null; cd $(printf '%q' "$ws_path") && $full_setup_cmd"
        if [[ -x "$OUTPUT_WINDOW_BIN" ]]; then
            ( set +e; /bin/zsh --no-rcs -c "$_wrap" 2>&1; echo "EXIT:$?" ) | "$OUTPUT_WINDOW_BIN" "Hub: Setting up workspace $ws_name" &
            disown
        else
            ( /bin/zsh --no-rcs -c "$_wrap" ) &
            disown
        fi

        (
            sleep 0.3
            local ow_wid
            ow_wid="$(aerospace list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null \
                | grep '|output_window$' | cut -d'|' -f1 | head -1 || echo "")"
            [[ -n "$ow_wid" ]] && aerospace move-node-to-workspace --window-id "$ow_wid" "$ws_id" 2>/dev/null || true
        ) &
        disown
    fi

    # Arrange windows in the new workspace based on count
    if [[ ${#_opened_wids[@]} -ge 1 ]]; then
        progress_banner_update "Organizing windows…"
        (sleep 0.3; arrange_workspace "$ws_id") &
        disown
    fi

    progress_banner_stop
    trap - EXIT

    hub_log "OUT" "workspace '$ws_name' created on workspace $ws_id"
    echo
    echo -e "${green}${bold}Workspace '$ws_name' created on workspace $ws_id!${reset}"
}

_print_new_usage() {
    cat <<'EOF'
Usage: hub new [flags]

Bare `hub new` opens the creation dialog. Pass any flag to run silently.

Flags:
  --path PATH        Workspace directory or repo root (default: $PWD)
  --worktree NAME    Create/reuse worktree NAME off the repo at --path
  --no-repo          No-repo workspace (path = $HOME). Conflicts with --path/--worktree.
  --name NAME        Workspace name (default: worktree name or basename of path)
  --id ID            Workspace ID, e.g. A or 5 (default: first free)
  --color HEX        Workspace color (default: WORKTREE_COLOR from .envrc.local)
  --apps LIST        Comma-separated app slot numbers, e.g. 1,3 (default: all configured)
  --no-apps          Open zero apps. Conflicts with --apps.
  --prompt TEXT      After opening the terminal slot (slot 1), run claude with the prompt.
                     The prompt is staged in a temp file to avoid escaping issues.
                     Requires a terminal with prompt_launch set (auto-wired by hub apps for
                     iTerm2, Terminal, Ghostty, WezTerm).
  -h, --help         Show this help

Examples:
  hub new                              # open creation dialog
  hub new --path .                     # workspace at CWD, no worktree
  hub new --worktree my-fix            # new worktree 'my-fix' off CWD repo
  hub new --no-repo --name scratch     # no-repo workspace
  hub new --worktree my-fix --prompt 'fix the login redirect bug'
EOF
}

# Allocate the first unused workspace ID, mirroring nextWorkspaceID() in
# lib/new_workspace_dialog.swift (alphabet at line 436-437).
_alloc_workspace_id() {
    local existing="${1:-}"
    if [[ -z "$existing" ]]; then
        existing="$(cat "$WORKSPACES_FILE" 2>/dev/null || echo "[]")"
    fi
    local used
    used="$(echo "$existing" | jq -c '[.[].workspace_id]' 2>/dev/null || echo "[]")"
    local ids=(1 2 3 4 5 6 7 8 9 A B C D E F G I M N O P Q R S T U V W X Y Z)
    local id
    for id in "${ids[@]}"; do
        if ! echo "$used" | jq -e --arg id "$id" 'index($id) // empty' >/dev/null 2>&1; then
            echo "$id"
            return 0
        fi
    done
    return 1
}

_is_valid_workspace_id() {
    case "$1" in
        1|2|3|4|5|6|7|8|9|A|B|C|D|E|F|G|I|M|N|O|P|Q|R|S|T|U|V|W|X|Y|Z) return 0 ;;
        *) return 1 ;;
    esac
}

_read_envrc_color() {
    local path="$1"
    local envrc="$path/.envrc.local"
    [[ -f "$envrc" ]] || return 0
    grep '^[[:space:]]*WORKTREE_COLOR=' "$envrc" 2>/dev/null \
        | head -1 \
        | sed -E 's/^[[:space:]]*WORKTREE_COLOR=//;s/[[:space:]]*$//;s/^"(.*)"$/\1/'
}

_default_apps_list() {
    local apps_file="$HOME/.config/hub/apps.json"
    [[ -f "$apps_file" ]] || return 0
    local count
    count="$(jq 'length' "$apps_file" 2>/dev/null || echo "0")"
    [[ "$count" -gt 0 ]] || return 0
    seq 1 "$count" | paste -sd, -
}

# Resolve a repo's default branch. Prefers origin/HEAD; falls back to main, then master.
# Echoes branch name on success, nothing on failure.
_default_branch() {
    local repo_root="$1"
    local ref
    if ref="$(git -C "$repo_root" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)"; then
        echo "${ref#*/}"
        return 0
    fi
    for candidate in main master; do
        if git -C "$repo_root" rev-parse --verify "refs/heads/$candidate" >/dev/null 2>&1; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

_cmd_new_cli() {
    local opt_path="" opt_worktree="" opt_name="" opt_id="" opt_color="" opt_prompt=""
    local opt_apps="" opt_no_repo=false opt_no_apps=false opt_apps_set=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) _print_new_usage; return 0 ;;
            --path) opt_path="$2"; shift 2 ;;
            --path=*) opt_path="${1#*=}"; shift ;;
            --worktree) opt_worktree="$2"; shift 2 ;;
            --worktree=*) opt_worktree="${1#*=}"; shift ;;
            --name) opt_name="$2"; shift 2 ;;
            --name=*) opt_name="${1#*=}"; shift ;;
            --id) opt_id="$2"; shift 2 ;;
            --id=*) opt_id="${1#*=}"; shift ;;
            --color) opt_color="$2"; shift 2 ;;
            --color=*) opt_color="${1#*=}"; shift ;;
            --apps) opt_apps="$2"; opt_apps_set=true; shift 2 ;;
            --apps=*) opt_apps="${1#*=}"; opt_apps_set=true; shift ;;
            --no-apps) opt_no_apps=true; shift ;;
            --no-repo) opt_no_repo=true; shift ;;
            --prompt) opt_prompt="$2"; shift 2 ;;
            --prompt=*) opt_prompt="${1#*=}"; shift ;;
            *)
                fail "Unknown flag: $1"
                _print_new_usage >&2
                return 2
                ;;
        esac
    done

    # Mutual exclusion
    if [[ "$opt_no_repo" == "true" && ( -n "$opt_path" || -n "$opt_worktree" ) ]]; then
        fail "--no-repo cannot be combined with --path or --worktree"
        return 2
    fi
    if [[ "$opt_no_apps" == "true" && "$opt_apps_set" == "true" ]]; then
        fail "--no-apps cannot be combined with --apps"
        return 2
    fi
    if [[ -n "$opt_prompt" && "$opt_no_apps" == "true" ]]; then
        fail "--prompt requires app slots to be opened (remove --no-apps)"
        return 2
    fi

    local ws_name="" ws_path="" ws_root="" ws_id="" ws_color=""
    local ws_setup_cmd="" ws_apps="" no_repo=false

    if [[ "$opt_no_repo" == "true" ]]; then
        no_repo=true
        ws_path="$HOME"
        ws_root=""
        if [[ -z "$opt_name" ]]; then
            fail "--no-repo requires --name"
            return 2
        fi
        ws_name="$opt_name"
    else
        # Resolve path (default $PWD)
        local resolved_path="${opt_path:-$PWD}"
        if [[ ! -d "$resolved_path" ]]; then
            fail "Path does not exist: $resolved_path"
            return 2
        fi
        # Canonicalize
        resolved_path="$(cd "$resolved_path" && pwd -P)"

        # Detect repo root (if any)
        local repo_root=""
        if git -C "$resolved_path" rev-parse --git-dir >/dev/null 2>&1; then
            repo_root="$(git -C "$resolved_path" rev-parse --show-toplevel 2>/dev/null || echo "")"
        fi

        if [[ -n "$opt_worktree" ]]; then
            if [[ -z "$repo_root" ]]; then
                fail "--worktree requires a git repository (none found at $resolved_path)"
                return 2
            fi
            local worktrees_dir="$repo_root/worktrees"
            mkdir -p "$worktrees_dir"
            local worktree_path="$worktrees_dir/$opt_worktree"

            if [[ -d "$worktree_path" ]]; then
                # Reuse existing worktree directory as-is.
                info "Reusing existing worktree: $worktree_path"
            else
                progress_banner_start "Creating worktree ${opt_worktree}..."
                local git_err
                if git -C "$repo_root" rev-parse --verify "refs/heads/$opt_worktree" >/dev/null 2>&1; then
                    git_err="$(git -C "$repo_root" worktree add "$worktree_path" "$opt_worktree" 2>&1)" || {
                        progress_banner_stop
                        fail "git worktree add failed: $git_err"
                        return 1
                    }
                else
                    local base_branch
                    base_branch="$(_default_branch "$repo_root" || true)"
                    if [[ -n "$base_branch" ]]; then
                        git_err="$(git -C "$repo_root" worktree add -b "$opt_worktree" "$worktree_path" "$base_branch" 2>&1)" || {
                            progress_banner_stop
                            fail "git worktree add failed: $git_err"
                            return 1
                        }
                    else
                        git_err="$(git -C "$repo_root" worktree add -b "$opt_worktree" "$worktree_path" 2>&1)" || {
                            progress_banner_stop
                            fail "git worktree add failed: $git_err"
                            return 1
                        }
                    fi
                fi
                progress_banner_stop
            fi
            ws_path="$worktree_path"
            ws_root="$repo_root"
            ws_name="${opt_name:-$opt_worktree}"
        else
            ws_path="$resolved_path"
            ws_root="$repo_root"
            if [[ -n "$opt_name" ]]; then
                ws_name="$opt_name"
            else
                ws_name="$(basename "$ws_path")"
            fi
        fi
    fi

    if [[ -z "$ws_name" ]]; then
        fail "Workspace name is empty"
        return 2
    fi

    # Reject duplicate workspace names (matches dialog validation)
    if [[ -f "$WORKSPACES_FILE" ]]; then
        if jq -e --arg n "$ws_name" '.[] | select(.name == $n)' "$WORKSPACES_FILE" >/dev/null 2>&1; then
            fail "A workspace named '$ws_name' already exists"
            return 1
        fi
    fi

    # Resolve workspace ID — explicit IDs are validated here; auto-allocation
    # happens inside _create_workspace under the lock to avoid races
    if [[ -n "$opt_id" ]]; then
        if ! _is_valid_workspace_id "$opt_id"; then
            fail "Invalid workspace ID: $opt_id (allowed: 1-9, A-G, I, M-Z)"
            return 2
        fi
        ws_id="$opt_id"
    else
        ws_id=""  # _create_workspace will allocate inside the lock
    fi

    # Color: explicit, else .envrc.local, else empty
    if [[ -n "$opt_color" ]]; then
        ws_color="$opt_color"
    elif [[ "$no_repo" == "false" ]]; then
        ws_color="$(_read_envrc_color "$ws_path" 2>/dev/null || true)"
    fi

    # Setup command from .superset/config.json (only if we have a repo root)
    if [[ -n "$ws_root" ]]; then
        ws_setup_cmd="$(read_superset_config "$ws_root" "setup" 2>/dev/null || echo "")"
    fi

    # Apps: explicit, --no-apps, or all configured slots
    if [[ "$opt_no_apps" == "true" ]]; then
        ws_apps=""
    elif [[ "$opt_apps_set" == "true" ]]; then
        ws_apps="$opt_apps"
    else
        ws_apps="$(_default_apps_list)"
    fi

    _create_workspace "$ws_name" "$ws_path" "$ws_root" "$ws_id" "$ws_color" "$ws_setup_cmd" "$ws_apps" "$no_repo" "$opt_prompt" "$opt_apps_set"
}

# Build the Claude prompt wrapper for terminal launch. Writes a per-workspace
# launcher script to ~/.config/hub/pending-prompts/<ws_id> — a stable,
# deterministic path so terminals like Ghostty only need to authorize it once
# per workspace ID slot (which gets reused). Emits the script path on stdout,
# or "" if the prompt is empty / no terminal slot has prompt_launch configured.
# Warnings go to stderr.
#
# Args: $1 = prompt text, $2 = ws_apps list, $3 = apps_set ("true" if user
# passed an explicit --apps list), $4 = ws_id (baked into wrapper for exact
# workspace identification by the notify hook)
_build_prompt_cmd() {
    local prompt="$1"
    local ws_apps="$2"
    local apps_set="${3:-false}"
    local ws_id="${4:-}"
    [[ -z "$prompt" ]] && return 0

    local prompt_slot=""
    if [[ -f "$APPS_FILE" ]]; then
        prompt_slot="$(jq -r 'to_entries[] | select((.value.prompt_launch // "") != "") | (.key + 1) | tostring' "$APPS_FILE" 2>/dev/null | head -1)"
    fi
    if [[ -z "$prompt_slot" ]]; then
        warn "prompt has no effect: no terminal slot with prompt_launch found in apps.json (run: hub apps)" >&2
        return 0
    fi
    if [[ "$apps_set" == "true" ]] && ! echo ",$ws_apps," | grep -q ",$prompt_slot,"; then
        warn "prompt has no effect: terminal slot ($prompt_slot) not in apps list" >&2
        return 0
    fi

    local pending_dir wrapper_script claude_bin
    pending_dir="$HOME/.config/hub/pending-prompts"
    mkdir -p "$pending_dir"
    # Stable path keyed to the workspace ID — Ghostty authorizes once per slot
    # (IDs like 1, A, B … are reused, so the dialog fires at most once per slot).
    wrapper_script="$pending_dir/${ws_id}"
    claude_bin="$(_config_get claude_binary "claude")"
    # The prompt text is embedded directly in the script (not a separate temp
    # HUB_WORKSPACE_ID is exported so the notify hook gets an exact workspace match.
    # The prompt is written to a sidecar file so the wrapper script stays free of
    # shell-special chars. exec replaces the wrapper process immediately — no stray
    # pending-prompt process in ps. The final exec "$SHELL" -i keeps the terminal open.
    local prompt_file="${wrapper_script}.prompt"
    printf '%s' "$prompt" > "$prompt_file"
    local quoted_id quoted_bin quoted_pf
    quoted_id=$(printf '%q' "$ws_id")
    quoted_bin=$(printf '%q' "$claude_bin")
    quoted_pf=$(printf '%q' "$prompt_file")
    cat > "$wrapper_script" <<WRAPPER
#!/bin/zsh
source "\$HOME/.zshrc" 2>/dev/null
export HUB_WORKSPACE_ID=${quoted_id}
exec "\$SHELL" -i -c '${quoted_bin} "\$1"; exec "\$SHELL" -i' zsh "\$(cat ${quoted_pf})"
WRAPPER
    chmod +x "$wrapper_script"
    printf '%s' "$wrapper_script"
}

rebuild_labels_file() {
    local labels_file="$HOME/.config/hub/sketchybar_labels"
    if [[ -f "$WORKSPACES_FILE" ]]; then
        # Format: workspace_id:name:color:repo_basename
        jq -r '.[] | [.workspace_id, .name, (.color // ""), ((.root_repo // "") | if . == "" then "" else (. | gsub(".*/"; "")) end)] | join(":")' \
            "$WORKSPACES_FILE" > "$labels_file" 2>/dev/null || true
    fi
}

update_sketchybar_label() {
    local ws_id="$1"
    local ws_name="$2"
    local label="$ws_id $ws_name"
    sketchybar --set "space.$ws_id" "label=$label" drawing=on 2>/dev/null || true
    rebuild_labels_file
}

remove_sketchybar_label() {
    local ws_id="$1"
    sketchybar --set "space.$ws_id" "label=$ws_id" drawing=off 2>/dev/null || true
    rebuild_labels_file
}

cmd_rename() {
    local ws_id="${1:-}"

    # If no ID given, use the currently focused workspace
    if [[ -z "$ws_id" ]]; then
        ws_id="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
        if [[ -z "$ws_id" ]]; then
            fail "Could not determine current workspace"
            exit 1
        fi
    fi

    if [[ ! -f "$WORKSPACES_FILE" ]]; then
        fail "No workspaces defined"
        exit 1
    fi

    local ws_name
    ws_name="$(jq -r --arg id "$ws_id" \
        '.[] | select(.workspace_id == $id) | .name' \
        "$WORKSPACES_FILE" 2>/dev/null)" || true

    if [[ -z "$ws_name" ]]; then
        fail "No workspace found with ID '$ws_id'"
        exit 1
    fi

    if [[ ! -x "$RENAME_BIN" ]]; then
        fail "rename_dialog not compiled. Run: hub install"
        exit 1
    fi

    rm -f /tmp/hub-rename
    "$RENAME_BIN" "$ws_id" "$ws_name"
    local dialog_exit=$?

    if [[ $dialog_exit -ne 0 || ! -f /tmp/hub-rename ]]; then
        info "Rename cancelled"
        return
    fi

    local new_name
    new_name="$(cat /tmp/hub-rename)"
    rm -f /tmp/hub-rename

    if [[ -z "$new_name" || "$new_name" == "$ws_name" ]]; then
        info "Name unchanged"
        return
    fi

    _hub_lock_acquire || return 1
    local updated
    updated="$(jq --arg id "$ws_id" --arg name "$new_name" \
        '[.[] | if .workspace_id == $id then .name = $name else . end]' \
        "$WORKSPACES_FILE")"
    echo "$updated" > "$WORKSPACES_FILE"
    _hub_lock_release

    update_sketchybar_label "$ws_id" "$new_name"

    hub_log "INPUT" "rename workspace $ws_id: '$ws_name' → '$new_name'"
    success "Renamed workspace $ws_id: '$ws_name' → '$new_name'"
}

cmd_next() { _cycle_hub_workspace 1; }
cmd_prev() { _cycle_hub_workspace -1; }

_cycle_hub_workspace() {
    local dir="$1"

    local all_ids=("1" "2" "3" "4" "5" "6" "7" "8" "9"
                   "A" "B" "C" "D" "E" "F" "G" "I" "M"
                   "N" "O" "P" "Q" "R" "S" "T" "U" "V" "W" "X" "Y" "Z")

    local registered=()
    if [[ -f "$WORKSPACES_FILE" ]]; then
        while IFS= read -r id; do
            [[ -n "$id" ]] && registered+=("$id")
        done < <(jq -r '.[].workspace_id' "$WORKSPACES_FILE" 2>/dev/null)
    fi

    local ordered=()
    for id in "${all_ids[@]}"; do
        for reg in "${registered[@]}"; do
            if [[ "$id" == "$reg" ]]; then
                ordered+=("$id")
                break
            fi
        done
    done

    [[ ${#ordered[@]} -eq 0 ]] && return

    local current
    current="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"

    local idx=-1
    for i in "${!ordered[@]}"; do
        if [[ "${ordered[$i]}" == "$current" ]]; then
            idx=$i
            break
        fi
    done

    local target_idx
    if [[ $idx -eq -1 ]]; then
        target_idx=$(( dir == 1 ? 0 : ${#ordered[@]} - 1 ))
    else
        target_idx=$(( (idx + dir + ${#ordered[@]}) % ${#ordered[@]} ))
    fi

    aerospace workspace "${ordered[$target_idx]}"
}

cmd_list() {
    local verbose=false
    for arg in "$@"; do
        [[ "$arg" == "-v" ]] && verbose=true
    done

    if [[ ! -f "$WORKSPACES_FILE" ]]; then
        echo "No workspaces defined."
        return
    fi

    local count
    count="$(jq 'length' "$WORKSPACES_FILE" 2>/dev/null || echo 0)"

    if [[ "$count" == "0" ]]; then
        echo "No workspaces defined."
        return
    fi

    if [[ "$verbose" == "true" ]]; then
        local max_name=4 max_path=4 max_root=9
        while IFS=$'\t' read -r _ ws_name ws_path ws_root; do
            (( ${#ws_name} > max_name )) && max_name=${#ws_name}
            (( ${#ws_path} > max_path )) && max_path=${#ws_path}
            (( ${#ws_root} > max_root )) && max_root=${#ws_root}
        done < <(jq -r 'sort_by(.workspace_id)[] | [.workspace_id, .name, .path, (.root_repo // "")] | @tsv' "$WORKSPACES_FILE")

        printf "${bold}%-4s  %-${max_name}s  %-${max_path}s  %s${reset}\n" "ID" "NAME" "PATH" "ROOT REPO"
        printf "%-4s  %-${max_name}s  %-${max_path}s  %s\n" \
            "$(printf '%0.s-' $(seq 1 4))" \
            "$(printf '%0.s-' $(seq 1 "$max_name"))" \
            "$(printf '%0.s-' $(seq 1 "$max_path"))" \
            "$(printf '%0.s-' $(seq 1 "$max_root"))"

        jq -r 'sort_by(.workspace_id)[] | [.workspace_id, .name, .path, (.root_repo // "")] | @tsv' \
            "$WORKSPACES_FILE" | while IFS=$'\t' read -r ws_id ws_name ws_path ws_root; do
            printf "%-4s  %-${max_name}s  %-${max_path}s  %s\n" "$ws_id" "$ws_name" "$ws_path" "$ws_root"
        done
    else
        printf "${bold}%-4s  %s${reset}\n" "ID" "NAME"
        printf "%-4s  %s\n" "----" "----"

        jq -r 'sort_by(.workspace_id)[] | [.workspace_id, .name] | @tsv' \
            "$WORKSPACES_FILE" | while IFS=$'\t' read -r ws_id ws_name; do
            printf "%-4s  %s\n" "$ws_id" "$ws_name"
        done
    fi
}

cmd_tree() {
    if [[ ! -x "$SPATIAL_ORDER_BIN" ]]; then
        fail "spatial_order binary not found at $SPATIAL_ORDER_BIN — run: hub install"
    fi
    "$SPATIAL_ORDER_BIN" --tree "$@"
}

cmd_status() {
    local compact=false
    for arg in "$@"; do [[ "$arg" == "--compact" ]] && compact=true; done

    echo -e "${bold}hub status${reset}"
    echo

    # --- Hub up/down (HubHTTPHandler is the hub-specific long-running process) ---
    if pgrep -qf "HubHTTPHandler.app/Contents/MacOS/HubHTTPHandler"; then
        echo -e "${bold}Hub:${reset}  ${green}✓ up${reset}"
    else
        echo -e "${bold}Hub:${reset}  ${red}✗ down${reset}  (run: hub up)"
    fi
    echo

    # --- Services ---
    echo -e "${bold}Services:${reset}"
    if aerospace list-workspaces --all &>/dev/null; then
        echo -e "  ${green}✓${reset} AeroSpace"
    else
        echo -e "  ${red}✗${reset} AeroSpace"
    fi
    if pgrep -q sketchybar; then
        echo -e "  ${green}✓${reset} SketchyBar"
    else
        echo -e "  ${red}✗${reset} SketchyBar"
    fi
    if pgrep -q borders; then
        echo -e "  ${green}✓${reset} JankyBorders"
    else
        echo -e "  ${red}✗${reset} JankyBorders"
    fi
    echo

    # --- Current workspace ---
    local current_ws
    current_ws="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
    local current_name=""
    if [[ -n "$current_ws" && -f "$WORKSPACES_FILE" ]]; then
        current_name="$(jq -r --arg id "$current_ws" \
            '.[] | select(.workspace_id == $id) | .name' \
            "$WORKSPACES_FILE" 2>/dev/null)"
    fi
    if [[ -n "$current_ws" ]]; then
        if [[ -n "$current_name" ]]; then
            echo -e "${bold}Current workspace:${reset} $current_ws  $current_name"
        else
            echo -e "${bold}Current workspace:${reset} $current_ws"
        fi
    fi

    # --- Active (non-empty) workspaces ---
    local active_ws
    active_ws="$(aerospace list-workspaces --monitor all --empty no 2>/dev/null || echo "")"
    local active_count=0
    [[ -n "$active_ws" ]] && active_count="$(echo "$active_ws" | wc -l | tr -d ' ')"
    echo -e "${bold}Active workspaces:${reset} $active_count  ($(echo "$active_ws" | tr '\n' ' ' | sed 's/ $//'))"
    echo

    # --- Label length ---
    local maxlen=-1
    [[ -f /tmp/hub_label_maxlen ]] && maxlen="$(cat /tmp/hub_label_maxlen 2>/dev/null || echo -1)"
    echo -e "${bold}Label length:${reset}"
    if [[ "$maxlen" -lt 0 ]]; then
        echo -e "  unlimited  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
    elif [[ "$maxlen" -eq 0 ]]; then
        echo -e "  workspace number only  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
    else
        echo -e "  $maxlen chars"
    fi
    echo

    # --- Workspaces ---
    if [[ "$compact" == "true" ]]; then
        cmd_list
    else
        cmd_list -v
    fi
}

cmd_remove() {
    local ws_id="${1:-}"
    local auto_yes=false

    # Parse flags
    for arg in "$@"; do
        if [[ "$arg" == "-y" ]]; then
            auto_yes=true
        fi
    done

    # If no ID given, use the currently focused workspace
    if [[ -z "$ws_id" || "$ws_id" == "-y" ]]; then
        ws_id="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
        if [[ -z "$ws_id" ]]; then
            fail "Could not determine current workspace"
            exit 1
        fi
    fi

    # Look up workspace info (may not exist if workspace was never registered with hub)
    local ws_info=""
    if [[ -f "$WORKSPACES_FILE" ]]; then
        ws_info="$(jq -r --arg id "$ws_id" \
            '.[] | select(.workspace_id == $id) | [.name, .path, .root_repo] | @tsv' \
            "$WORKSPACES_FILE" 2>/dev/null)" || true
    fi

    local ws_name ws_path ws_root
    if [[ -n "$ws_info" ]]; then
        IFS=$'\t' read -r ws_name ws_path ws_root <<< "$ws_info"
    else
        fail "Workspace '$ws_id' not found"
        exit 1
    fi

    # Count windows
    local windows
    windows="$(aerospace list-windows --workspace "$ws_id" --format '%{window-id}' 2>/dev/null || echo "")"
    local window_count=0
    if [[ -n "$windows" ]]; then
        window_count="$(echo "$windows" | wc -l | tr -d ' ')"
    fi

    local confirm_msg="Remove workspace '$ws_name' (ID: $ws_id)?"
    if [[ "$window_count" -gt 0 ]]; then
        confirm_msg="Remove workspace '$ws_name' (ID: $ws_id)? Open windows will be closed. Any that don't close immediately will be moved to the Z General workspace."
    fi

    # Determine if this is a worktree (path differs from root repo, path exists on disk)
    local is_worktree=false
    if [[ -n "$ws_root" && "$ws_path" != "$ws_root" && "$ws_path" != "-" && -d "$ws_path" ]]; then
        is_worktree=true
    fi

    local ws_branch=""
    if [[ "$is_worktree" == "true" ]]; then
        ws_branch="$(git -C "$ws_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
    fi

    # Confirm: show GUI dialog unless -y
    local remove_worktree=true
    local delete_branch=false
    if [[ "$auto_yes" != "true" ]]; then
        if [[ ! -x "$CONFIRM_BIN" ]]; then
            fail "confirm_dialog not compiled. Run: hub install"
            exit 1
        fi
        rm -f /tmp/hub-confirm-state
        local dialog_args=("Remove Workspace" "$confirm_msg")
        if [[ "$is_worktree" == "true" ]]; then
            dialog_args+=("Remove / teardown worktree")
            dialog_args+=("!Delete branch")
        fi
        local dialog_exit=0
        "$CONFIRM_BIN" "${dialog_args[@]}" || dialog_exit=$?
        if [[ "$dialog_exit" -ne 0 ]]; then
            echo "Cancelled."; return
        fi
        # Read worktree checkbox states
        if [[ "$is_worktree" == "true" && -f /tmp/hub-confirm-state ]]; then
            local v1 v2
            v1="$(grep "^cb1=" /tmp/hub-confirm-state | cut -d= -f2)"
            v2="$(grep "^cb2=" /tmp/hub-confirm-state | cut -d= -f2)"
            [[ "$v1" == "0" ]] && remove_worktree=false
            [[ "$v2" == "1" ]] && delete_branch=true
            rm -f /tmp/hub-confirm-state
        fi
    fi

    hub_log "INPUT" "remove workspace '$ws_name' (id=$ws_id, worktree=$is_worktree)"
    progress_banner_start "Removing workspace ${ws_name}..."

    # Instant cleanup — before any slow teardown
    if [[ -f "$WORKSPACES_FILE" ]]; then
        _hub_lock_acquire || return 1
        local updated
        updated="$(jq --arg id "$ws_id" '[.[] | select(.workspace_id != $id)]' "$WORKSPACES_FILE")"
        echo "$updated" > "$WORKSPACES_FILE"
        _hub_lock_release
    fi

    remove_sketchybar_label "$ws_id"

    if [[ -n "$windows" ]]; then
        progress_banner_update "Closing windows..."
        while IFS= read -r wid; do
            aerospace move-node-to-workspace --window-id "$wid" Z 2>/dev/null || true
        done <<< "$windows"
    fi

    aerospace workspace Z 2>/dev/null || true

    # Attempt to close the moved windows (best-effort; some apps may not close)
    if [[ -n "$windows" ]]; then
        (
            sleep 0.5
            while IFS= read -r wid; do
                aerospace close --window-id "$wid" 2>/dev/null || true
            done <<< "$windows"
        ) &
        disown
    fi

    # Background teardown piped to output_window
    if [[ "$is_worktree" == "true" && "$remove_worktree" == "true" ]]; then
        progress_banner_update "Removing worktree..."
        local teardown_cmd
        teardown_cmd="$(read_superset_config "$ws_root" "teardown" 2>/dev/null || echo "")"

        local bg_script
        if [[ -n "$teardown_cmd" ]]; then
            bg_script="source \"\$HOME/.zshrc\" 2>/dev/null; cd $(printf '%q' "$ws_path") && eval $(printf '%q' "$ws_root/$teardown_cmd"); git -C $(printf '%q' "$ws_root") worktree remove $(printf '%q' "$ws_path") --force 2>/dev/null; git -C $(printf '%q' "$ws_root") worktree prune 2>/dev/null"
        else
            bg_script="git -C $(printf '%q' "$ws_root") worktree remove $(printf '%q' "$ws_path") --force 2>/dev/null; git -C $(printf '%q' "$ws_root") worktree prune 2>/dev/null"
        fi
        if [[ "$delete_branch" == "true" && -n "$ws_branch" ]]; then
            bg_script+=" ; git -C $(printf '%q' "$ws_root") branch -D $(printf '%q' "$ws_branch") 2>/dev/null"
        fi

        if [[ -x "$OUTPUT_WINDOW_BIN" ]]; then
            ( set +e; /bin/zsh --no-rcs -c "$bg_script" 2>&1; echo "EXIT:$?" ) | "$OUTPUT_WINDOW_BIN" "Hub: Removing workspace $ws_name" &
            disown
        else
            ( eval "$bg_script" ) &
            disown
        fi

        (
            sleep 0.3
            local ow_wid
            ow_wid="$(aerospace list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null \
                | grep '|output_window$' | cut -d'|' -f1 | head -1 || echo "")"
            [[ -n "$ow_wid" ]] && aerospace move-node-to-workspace --window-id "$ow_wid" Z 2>/dev/null || true
        ) &
        disown
    fi

    progress_banner_stop

    hub_log "OUT" "workspace '$ws_name' (id=$ws_id) removed"
    echo
    echo -e "${green}${bold}Workspace '$ws_name' (ID: $ws_id) removed.${reset}"
}


get_workspace_path() {
    local ws_id="$1"
    if [[ -f "$WORKSPACES_FILE" ]]; then
        jq -r --arg id "$ws_id" '.[] | select(.workspace_id == $id) | .path // empty' \
            "$WORKSPACES_FILE" 2>/dev/null
    fi
}

# Return window-ids in left-to-right spatial order, one per line.
# aerospace list-windows returns windows in a non-spatial (creation-ish) order
# after flatten, so we sort by x-coordinate from CGWindowList instead.
spatial_order_ltr() {
    local ws_id="$1"
    local wids=()
    while IFS= read -r wid; do
        [[ -n "$wid" ]] && wids+=("$wid")
    done < <(aerospace list-windows --workspace "$ws_id" --format '%{window-id}' 2>/dev/null || true)
    [[ ${#wids[@]} -eq 0 ]] && return 0
    "$SPATIAL_ORDER_BIN" "${wids[@]}" 2>/dev/null || true
}

# arrange_workspace WS_ID [NEWEST_WID]
# Arranges all windows on WS_ID into a structured layout:
#   2: W1 | W2  (flat h_tiles)
#   3: W1 | (W2/W3 stacked vertically)
#   4: (W1/W2) | (W3/W4)  (two columns of two)
#   5: (W1/W2) | (W3/W4/W5)
# When NEWEST_WID is provided, moves it to the rightmost position before
# applying the layout (handles the "just opened" case).
# Outside that range (1 window, >5 windows) is a no-op.
arrange_workspace() {
    local ws_id="$1" newest_wid="${2:-}"

    # Guard on count before doing any AeroSpace mutations.
    local wids=()
    while IFS= read -r wid; do
        [[ -n "$wid" ]] && wids+=("$wid")
    done < <(aerospace list-windows --workspace "$ws_id" --format '%{window-id}' 2>/dev/null || true)
    local n=${#wids[@]}
    [[ $n -lt 2 || $n -gt 5 ]] && return 0

    # Flatten to a single h-split so all windows are direct siblings.
    aerospace flatten-workspace-tree --workspace "$ws_id" 2>/dev/null || true
    # Ensure workspace is focused so geometry is available (off-screen workspaces have bogus x/y).
    aerospace workspace "$ws_id" 2>/dev/null || true

    # Force horizontal layout so geometry reflects a flat h-split.
    aerospace focus --window-id "${wids[0]}" 2>/dev/null || true
    aerospace layout h_tiles 2>/dev/null || true

    # Read spatial left-to-right order from geometry (list-windows is NOT spatial after flatten).
    local ordered
    ordered="$(spatial_order_ltr "$ws_id")"
    local w=()
    while IFS= read -r wid; do
        [[ -n "$wid" ]] && w+=("$wid")
    done <<< "$ordered"
    [[ ${#w[@]} -lt 2 ]] && return 0

    # If a newest window was specified, move it to the rightmost position.
    if [[ -n "$newest_wid" ]]; then
        local newest_idx=0
        for ((i=0; i<${#w[@]}; i++)); do
            [[ "${w[$i]}" == "$newest_wid" ]] && newest_idx=$i && break
        done
        local moves=$(( ${#w[@]} - 1 - newest_idx ))
        if (( moves > 0 )); then
            aerospace focus --window-id "$newest_wid" 2>/dev/null || true
            for ((i=0; i<moves; i++)); do aerospace move right 2>/dev/null || true; done
        fi
        # Re-read spatial order after the move (geometry has changed).
        ordered="$(spatial_order_ltr "$ws_id")"
        w=()
        while IFS= read -r wid; do
            [[ -n "$wid" ]] && w+=("$wid")
        done <<< "$ordered"
        [[ ${#w[@]} -lt 2 ]] && return 0
    fi

    if [[ $n -eq 3 ]]; then
        # Goal: W1 | (W2/W3)
        aerospace focus --window-id "${w[2]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
    elif [[ $n -eq 4 ]]; then
        # Goal: (W1/W2) | (W3/W4)
        aerospace focus --window-id "${w[1]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
        aerospace focus --window-id "${w[3]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
    elif [[ $n -eq 5 ]]; then
        # Goal: (W1/W2) | (W3/W4/W5)
        aerospace focus --window-id "${w[1]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
        aerospace focus --window-id "${w[3]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
        aerospace focus --window-id "${w[4]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
    fi

    # Return focus to leftmost window.
    aerospace focus --window-id "${w[0]}" 2>/dev/null || true
}

# arrange_after_open WS_ID — moves the newest (highest ID) window rightmost, then arranges.
# Only acts on workspaces with 2-4 windows (same range as before).
arrange_after_open() {
    local ws_id="$1"
    local wids=()
    while IFS= read -r wid; do
        [[ -n "$wid" ]] && wids+=("$wid")
    done < <(aerospace list-windows --workspace "$ws_id" --format '%{window-id}' 2>/dev/null || true)
    local n=${#wids[@]}
    [[ $n -lt 2 || $n -gt 4 ]] && return 0
    local newest_wid
    newest_wid="$(printf '%s\n' "${wids[@]}" | sort -n | tail -1)"
    arrange_workspace "$ws_id" "$newest_wid"
}

# arrange_workspace_windows WS_ID WID... — arranges by current geometry, ignoring the wid list.
arrange_workspace_windows() { local ws_id="$1"; arrange_workspace "$ws_id"; }

# _launch_and_corral APP_NAME LAUNCH_CMD WS_ID [LAUNCH_DIR]
# Runs LAUNCH_CMD, waits (up to 8s) for a NEW window of APP_NAME to appear, then
# moves it to WS_ID (if it didn't already land there) and focuses it. This is the
# shared core used by both the keyboard launcher (open_app_slot) and URL opens
# (cmd_open_url) so windows always end up on the intended workspace, regardless
# of where the app decides to place them.
# Sets OPEN_APP_SLOT_WID (the new window id, or "" if none appeared) and
# OPEN_APP_SLOT_CORRALLED (true if a move was needed).
_launch_and_corral() {
    local app_name="$1" launch_cmd="$2" ws_id="$3" launch_dir="${4:-}"

    hub_log "CMD" "launch $app_name on workspace $ws_id: $launch_cmd"

    # Snapshot existing window IDs for this app
    local before_ids
    before_ids="$(aerospace list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null | grep "|${app_name}$" | cut -d'|' -f1 || echo "")"

    # cd into the workspace path first so apps like Ghostty that inherit the
    # parent process cwd (rather than honoring --working-directory) start in the
    # right directory.
    local cd_prefix=""
    [[ -n "$launch_dir" && -d "$launch_dir" ]] && cd_prefix="cd $(printf '%q' "$launch_dir") && "
    bash -c "${cd_prefix}${launch_cmd}" >/dev/null 2>/tmp/hub_open_err &

    # Poll for a new window (up to 8 seconds)
    local new_wid=""
    for _ in $(seq 1 32); do
        sleep 0.25
        local after_ids
        after_ids="$(aerospace list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null | grep "|${app_name}$" | cut -d'|' -f1 || echo "")"
        while IFS= read -r wid; do
            [[ -z "$wid" ]] && continue
            if ! echo "$before_ids" | grep -qxF "$wid"; then
                new_wid="$wid"
                break 2
            fi
        done <<< "$after_ids"
    done

    # Move to the correct workspace if needed, then focus
    if [[ -n "$new_wid" ]]; then
        local win_ws
        win_ws="$(aerospace list-windows --all --format '%{window-id}|%{workspace}' 2>/dev/null | grep "^${new_wid}|" | cut -d'|' -f2 || echo "")"
        if [[ "$win_ws" != "$ws_id" ]]; then
            progress_banner_update "Corralling ${app_name}..."
            aerospace move-node-to-workspace --window-id "$new_wid" "$ws_id" 2>/dev/null || true
            OPEN_APP_SLOT_CORRALLED=true
        fi
        aerospace focus --window-id "$new_wid" 2>/dev/null || true
        OPEN_APP_SLOT_WID="$new_wid"
        hub_log "OUT" "$app_name launched: window $new_wid on workspace $ws_id"
        # Capture any launch errors
        local _err
        _err="$(cat /tmp/hub_open_err 2>/dev/null || true)"
        [[ -n "$_err" ]] && hub_log "ERR" "$app_name launch stderr: $_err" || true
    else
        OPEN_APP_SLOT_WID=""
        hub_log "ERR" "$app_name: window did not appear within 8s"
        local _err
        _err="$(cat /tmp/hub_open_err 2>/dev/null || true)"
        [[ -n "$_err" ]] && hub_log "ERR" "$app_name launch stderr: $_err" || true
    fi
    # Never let the trailing conditional's exit status (1 when _err is empty)
    # propagate out under `set -e` and abort the caller mid-workspace-setup.
    return 0
}

# cmd_open_url URL [WS_ID] — open URL in the slot-2 browser and corral the new
# window to WS_ID (defaults to the currently focused workspace). Called by the
# http_handler daemon so URLs opened via `open <url>` land where the user is.
cmd_open_url() {
    local url="$1"
    local ws_id="${2:-}"
    [[ -z "$ws_id" ]] && ws_id="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
    [[ -z "$url" || -z "$ws_id" ]] && return 1
    hub_log "INPUT" "open-url $url (workspace $ws_id)"

    # Resolve the slot-2 (index 1) browser launch command, preferring url_launch.
    local app_info
    app_info="$(jq -r 'if length > 1 then .[1] | [.name, (.url_launch // .launch)] | @tsv else empty end' \
        "$APPS_FILE" 2>/dev/null)" || return 1
    [[ -z "$app_info" ]] && return 1
    local app_name launch_cmd
    IFS=$'\t' read -r app_name launch_cmd <<< "$app_info"

    # Substitute {url}; if the launch command has no placeholder, append the URL.
    local esc_url="${url//\'/\'\\\'\'}"
    if [[ "$launch_cmd" == *"{url}"* ]]; then
        launch_cmd="${launch_cmd//\{url\}/$esc_url}"
    else
        launch_cmd="$launch_cmd '$esc_url'"
    fi

    OPEN_APP_SLOT_WID=""
    OPEN_APP_SLOT_CORRALLED=false
    _launch_and_corral "$app_name" "$launch_cmd" "$ws_id"
    if [[ -n "$OPEN_APP_SLOT_WID" ]]; then
        local _ws_id_copy="$ws_id"
        (sleep 0.2; arrange_after_open "$_ws_id_copy") &
        disown
    fi
}

open_app_slot() {
    local slot="$1"
    local ws_id="$2"
    local ws_path="$3"
    local verbose="${4:-false}"   # true = print status lines
    local force_new="${5:-false}" # true = always launch new window
    local prompt_cmd="${6:-}"

    local app_info
    app_info="$(jq -r --argjson i "$((slot - 1))" \
        'if $i >= 0 and $i < length then .[$i] | [.name, .launch, (.icon // .name), (.prompt_launch // "")] | @tsv else empty end' \
        "$APPS_FILE" 2>/dev/null)" || return 0

    [[ -z "$app_info" ]] && return 0

    local app_name launch_cmd app_icon app_prompt_launch
    IFS=$'\t' read -r app_name launch_cmd app_icon app_prompt_launch <<< "$app_info"

    # Smart mode: if app has windows on current workspace, cycle focus between
    # them. Otherwise fall through to launch a new window on this workspace.
    # (We intentionally do NOT jump to another workspace where this app runs —
    # each hub workspace is self-contained, so Chrome on ws 3 ≠ Chrome on ws 10.)
    if [[ "$force_new" != "true" ]]; then
        local cur_wins
        cur_wins="$(aerospace list-windows --workspace "$ws_id" --format '%{window-id}|%{app-name}' 2>/dev/null \
            | grep "|${app_name}$" | cut -d'|' -f1 || echo "")"
        if [[ -n "$cur_wins" ]]; then
            local focused_wid
            focused_wid="$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null || echo "")"
            local target="" first="" take_next=false
            while IFS= read -r wid; do
                [[ -z "$wid" ]] && continue
                [[ -z "$first" ]] && first="$wid"
                if [[ "$take_next" == "true" ]]; then
                    target="$wid"
                    break
                fi
                [[ "$wid" == "$focused_wid" ]] && take_next=true
            done <<< "$cur_wins"
            [[ -z "$target" ]] && target="$first"
            aerospace focus --window-id "$target" 2>/dev/null || true
            hub_log "INPUT" "open slot $slot → focus $app_name (window $target) on workspace $ws_id"
            [[ "$verbose" == "true" ]] && success "$app_name focused" || true
            return 0
        fi
        # Fall through: no window on this workspace, launch one here
    fi

    hub_log "INPUT" "open slot $slot → launch $app_name on workspace $ws_id"
    [[ "$verbose" == "true" ]] && info "Opening $app_name..." || true
    progress_banner_update "Opening ${app_name}..."

    # When a prompt is active and this slot has a prompt_launch, use it instead
    # of the plain launch command. HUB_WORKSPACE_ID and the exec-interactive-shell
    # tail are baked into the wrapper by _build_prompt_cmd.
    if [[ -n "$prompt_cmd" && -n "$app_prompt_launch" ]]; then
        launch_cmd="$app_prompt_launch"
    fi

    # Substitute {path}, {workspace}, and {prompt_cmd} in launch command
    launch_cmd="${launch_cmd//\{path\}/$ws_path}"
    launch_cmd="${launch_cmd//\{workspace\}/$ws_id}"
    launch_cmd="${launch_cmd//\{prompt_cmd\}/$prompt_cmd}"

    # Launch, wait for the new window, and corral it onto this workspace.
    _launch_and_corral "$app_name" "$launch_cmd" "$ws_id" "$ws_path"

    if [[ -n "$OPEN_APP_SLOT_WID" ]]; then
        [[ "$verbose" == "true" ]] && success "$app_name opened" || true
    else
        [[ "$verbose" == "true" ]] && warn "$app_name: window did not appear in time" || true
    fi
}

cmd_log() {
    local open_window=false
    for arg in "$@"; do
        [[ "$arg" == "--window" ]] && open_window=true
    done

    if [[ "$open_window" == "true" ]]; then
        if [[ ! -x "$LOG_VIEWER_BIN" ]]; then
            fail "log_viewer not compiled. Run: hub install"
            exit 1
        fi
        if [[ ! -f "$HUB_LOG_FILE" ]]; then
            mkdir -p "$(dirname "$HUB_LOG_FILE")"
            touch "$HUB_LOG_FILE"
        fi
        # Kill any existing log_viewer windows so ctrl-alt-l always lands on the
        # current workspace rather than piling up multiple viewer instances.
        pkill -x log_viewer 2>/dev/null || true
        sleep 0.1
        "$LOG_VIEWER_BIN" "$HUB_LOG_FILE" &
        disown
        return
    fi

    echo "$HUB_LOG_FILE"
    if [[ ! -f "$HUB_LOG_FILE" ]]; then
        echo "(no log entries yet)"
        return
    fi
    # -S: don't wrap long lines  -R: pass ANSI colors  +F: start in follow mode
    less -SR +F "$HUB_LOG_FILE"
}

_config_get() {
    local key="$1" default="${2:-}"
    local val=""
    if [[ -f "$HUB_CONFIG_FILE" ]]; then
        val="$(jq -r --arg k "$key" '.[$k] // ""' "$HUB_CONFIG_FILE" 2>/dev/null || true)"
    fi
    echo "${val:-$default}"
}

_VALID_CONFIG_KEYS=("claude_binary")

_validate_config_key() {
    local key="$1"
    local k
    for k in "${_VALID_CONFIG_KEYS[@]}"; do
        [[ "$k" == "$key" ]] && return 0
    done
    local joined
    joined="$(IFS=', '; echo "${_VALID_CONFIG_KEYS[*]}")"
    fail "Unknown config key: $key (allowed: $joined)"
    return 2
}

cmd_config() {
    local subcommand="${1:-list}"
    shift || true

    case "$subcommand" in
        list|"")
            if [[ ! -f "$HUB_CONFIG_FILE" ]]; then
                echo "(no configuration set)"
                return 0
            fi
            local count
            count="$(jq 'length' "$HUB_CONFIG_FILE" 2>/dev/null || echo "0")"
            if [[ "$count" -eq 0 ]]; then
                echo "(no configuration set)"
                return 0
            fi
            jq -r 'to_entries[] | "\(.key) = \(.value)"' "$HUB_CONFIG_FILE"
            ;;
        get)
            local key="${1:-}"
            if [[ -z "$key" ]]; then
                fail "Usage: hub config get <key>"
                return 2
            fi
            _validate_config_key "$key" || return $?
            local val
            val="$(_config_get "$key")"
            if [[ -z "$val" ]]; then
                echo "(not set)"
            else
                echo "$val"
            fi
            ;;
        set)
            local key="${1:-}" value="${2:-}"
            if [[ -z "$key" || $# -lt 2 ]]; then
                fail "Usage: hub config set <key> <value>"
                return 2
            fi
            _validate_config_key "$key" || return $?
            mkdir -p "$(dirname "$HUB_CONFIG_FILE")"
            _hub_lock_acquire "$HUB_CONFIG_LOCK_DIR" || return 1
            local existing="{}"
            [[ -f "$HUB_CONFIG_FILE" ]] && existing="$(cat "$HUB_CONFIG_FILE")"
            echo "$existing" | jq --arg k "$key" --arg v "$value" '. + {($k): $v}' > "$HUB_CONFIG_FILE"
            _hub_lock_release "$HUB_CONFIG_LOCK_DIR"
            success "$key = $value"
            ;;
        unset)
            local key="${1:-}"
            if [[ -z "$key" ]]; then
                fail "Usage: hub config unset <key>"
                return 2
            fi
            _validate_config_key "$key" || return $?
            if [[ -f "$HUB_CONFIG_FILE" ]]; then
                _hub_lock_acquire "$HUB_CONFIG_LOCK_DIR" || return 1
                local updated
                updated="$(jq --arg k "$key" 'del(.[$k])' "$HUB_CONFIG_FILE")"
                echo "$updated" > "$HUB_CONFIG_FILE"
                _hub_lock_release "$HUB_CONFIG_LOCK_DIR"
            fi
            success "$key unset"
            ;;
        *)
            fail "Unknown config subcommand: $subcommand (allowed: list, get, set, unset)"
            return 2
            ;;
    esac
}

cmd_open() {
    local slot=""
    local open_all=false
    local force_new=false

    for arg in "$@"; do
        case "$arg" in
            --all) open_all=true ;;
            --force|--new) force_new=true ;;
            [1-5]) slot="$arg" ;;
        esac
    done

    if [[ ! -f "$APPS_FILE" ]]; then
        fail "No apps.json found. Run: hub install"
        exit 1
    fi

    local ws_id
    ws_id="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
    if [[ -z "$ws_id" ]]; then
        fail "Could not determine current workspace"
        exit 1
    fi

    local ws_path
    ws_path="$(get_workspace_path "$ws_id")"
    [[ -z "$ws_path" ]] && ws_path="$HOME"

    # Load app list
    local app_names=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && app_names+=("$line")
    done < <(jq -r '.[].name' "$APPS_FILE" 2>/dev/null)

    local app_count="${#app_names[@]}"

    # If called from a keybinding (no terminal), just run silently
    if [[ ! -t 0 && ! -t 1 ]]; then
        local _opened=false
        if [[ -n "$slot" ]]; then
            OPEN_APP_SLOT_WID=""
            open_app_slot "$slot" "$ws_id" "$ws_path" false "$force_new"
            [[ -n "$OPEN_APP_SLOT_WID" ]] && _opened=true
        else
            for ((i=1; i<=app_count; i++)); do
                OPEN_APP_SLOT_WID=""
                open_app_slot "$i" "$ws_id" "$ws_path" false "$force_new"
                [[ -n "$OPEN_APP_SLOT_WID" ]] && _opened=true
            done
        fi
        if [[ "$_opened" == "true" ]]; then
            local _ws_id_copy="$ws_id"
            (sleep 0.2; arrange_after_open "$_ws_id_copy") &
            disown
        fi
        refresh_app_indicators
        return
    fi

    # Terminal: show list and prompt if no slot/--all given
    if [[ -z "$slot" && "$open_all" == "false" ]]; then
        local ws_apps
        ws_apps="$(aerospace list-windows --workspace "$ws_id" --format '%{app-name}' 2>/dev/null || echo "")"

        local verb="Open/focus"
        [[ "$force_new" == "true" ]] && verb="Launch new"
        echo -e "${bold}${verb} which app for workspace $ws_id?${reset}"
        for ((i=1; i<=app_count; i++)); do
            local name="${app_names[$((i-1))]}"
            if echo "$ws_apps" | grep -qxF "$name"; then
                echo -e "  ${green}$i${reset}  $name ${green}(open here)${reset}"
            else
                echo -e "  ${blue}$i${reset}  $name"
            fi
        done
        echo
        echo -e "  ${bold}a${reset}  Open all"
        echo -e "  ${bold}q${reset}  Quit"
        echo
        read -rp "Choice [1-${app_count}/a/q] " choice

        case "$choice" in
            [1-5]) slot="$choice" ;;
            a|A|--all) open_all=true ;;
            *) echo "Cancelled."; return ;;
        esac
    fi

    local _opened=false
    if [[ "$open_all" == "true" ]]; then
        for ((i=1; i<=app_count; i++)); do
            OPEN_APP_SLOT_WID=""
            open_app_slot "$i" "$ws_id" "$ws_path" true "$force_new"
            [[ -n "$OPEN_APP_SLOT_WID" ]] && _opened=true
        done
    else
        OPEN_APP_SLOT_WID=""
        open_app_slot "$slot" "$ws_id" "$ws_path" true "$force_new"
        [[ -n "$OPEN_APP_SLOT_WID" ]] && _opened=true
    fi

    # Only refocus original workspace after launching new windows — smart-open
    # may have intentionally jumped to another workspace.
    if [[ "$force_new" == "true" || "$open_all" == "true" ]]; then
        aerospace workspace "$ws_id" 2>/dev/null || true
    fi

    if [[ "$_opened" == "true" ]]; then
        local _ws_id_copy="$ws_id"
        (sleep 0.2; arrange_after_open "$_ws_id_copy") &
        disown
    fi
    refresh_app_indicators
}

refresh_app_indicators() {
    local plugin="$HOME/.config/sketchybar/plugins/app_launcher.sh"
    [[ -x "$plugin" ]] && "$plugin" >/dev/null 2>&1
}

KEYS_CACHE="$HOME/.config/hub/keys_cache"

build_keys_output() {
    local cyan='\033[36m'
    local dim='\033[2m'

    for mode in main service; do
        local keys
        keys="$(aerospace config --get "mode.${mode}.binding" --keys 2>/dev/null)" || continue
        [[ -z "$keys" ]] && continue

        echo -e "${bold}${blue}${mode} mode${reset}"
        if [[ "$mode" == "service" ]]; then
            echo -e "  ${dim}activated by ${bold}alt-shift-semicolon${reset}"
        fi
        echo -e "${dim}$(printf '%.0s─' {1..40})${reset}"

        while IFS= read -r key; do
            [[ -z "$key" ]] && continue
            local cmd
            cmd="$(aerospace config --get "mode.${mode}.binding.${key}" 2>/dev/null)" || continue
            cmd="${cmd#exec-and-forget  }"
            cmd="${cmd//$REPO_DIR\/scripts\/hub/hub}"
            printf "  ${cyan}${bold}%-28s${reset}  %s\n" "$key" "$cmd"
        done <<< "$keys"
        echo
    done
}

cache_keys() {
    mkdir -p "$(dirname "$KEYS_CACHE")"
    build_keys_output > "$KEYS_CACHE"
}

cmd_dashboard() {
    if [[ ! -x "$DASHBOARD_BIN" ]]; then
        fail "dashboard_dialog not compiled. Run: hub install"
        exit 1
    fi

    local status_tmp keys_tmp
    status_tmp="$(mktemp /tmp/hub-dashboard-status.XXXXXX)"
    keys_tmp="$(mktemp /tmp/hub-dashboard-keys.XXXXXX)"
    rm -f "${status_tmp}.done" "${keys_tmp}.done"

    # Populate files in background; write .done sentinels when each is ready
    ( cmd_status --compact > "$status_tmp" && touch "${status_tmp}.done" ) &
    ( cmd_keys > "$keys_tmp" && touch "${keys_tmp}.done" ) &

    # Launch dialog immediately — it polls for the .done sentinels
    "$DASHBOARD_BIN" "$status_tmp" "$keys_tmp"

    rm -f "$status_tmp" "${status_tmp}.done" "$keys_tmp" "${keys_tmp}.done"
}

cmd_keys() {
    if [[ -f "$KEYS_CACHE" ]]; then
        cat "$KEYS_CACHE"
    else
        build_keys_output | tee "$KEYS_CACHE"
    fi
}

cmd_repo_prefix() {
    local action="${1:-toggle}"
    local prefix_file="$HOME/.config/hub/repo_prefix"
    local current="off"
    [[ -f "$prefix_file" ]] && current="$(cat "$prefix_file" 2>/dev/null || echo off)"
    [[ "$current" != "on" ]] && current="off"

    case "$action" in
        on)  current="on" ;;
        off) current="off" ;;
        toggle) [[ "$current" == "on" ]] && current="off" || current="on" ;;
        "")
            echo -e "${bold}Repo prefix:${reset} $current"
            echo -e "  ${yellow}Usage: hub repo-prefix [on|off|toggle]${reset}"
            return 0
            ;;
        *) fail "Usage: hub repo-prefix [on|off|toggle]"; return 1 ;;
    esac

    echo "$current" > "$prefix_file"
    rebuild_labels_file
    local plugin="$HOME/.config/sketchybar/plugins/aerospace.sh"
    [[ -x "$plugin" ]] && "$plugin" >/dev/null 2>&1
}

cmd_label_length() {
    local direction="${1:-}"
    local maxlen_file="$HOME/.config/hub/label_maxlen"
    # -1 = unlimited, 0 = code only, N>0 = max N chars of name
    local current=-1
    [[ -f "$maxlen_file" ]] && current=$(cat "$maxlen_file" 2>/dev/null || echo -1)

    # Find longest label to cap the max
    local longest=0
    local labels_file="$HOME/.config/hub/sketchybar_labels"
    if [[ -f "$labels_file" ]]; then
        while IFS=: read -r _ name _; do
            (( ${#name} > longest )) && longest=${#name}
        done < "$labels_file"
    fi

    case "$direction" in
        +|up|grow)
            if [[ "$current" -lt 0 ]]; then
                current=-1  # already unlimited, stay unlimited
            else
                current=$(( current + 2 ))
            fi
            ;;
        -|down|shrink)
            if [[ "$current" -lt 0 ]]; then
                # First shrink from unlimited: start at longest - 2
                if [[ "$longest" -gt 0 ]]; then
                    current=$(( longest - 2 ))
                    (( current < 0 )) && current=0
                fi
            else
                current=$(( current - 2 ))
                (( current < 0 )) && current=0
            fi
            ;;
        min)
            current=0
            ;;
        max)
            current=-1
            ;;
        "")
            # No argument: display current label length
            echo -e "${bold}Label length:${reset}"
            if [[ "$current" -lt 0 ]]; then
                echo -e "  unlimited  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
            elif [[ "$current" -eq 0 ]]; then
                echo -e "  workspace number only  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
            else
                echo -e "  $current chars  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
            fi
            echo -e "  ${yellow}Usage: hub label-length [+|-|grow|shrink|min|max|<number>]${reset}"
            return 0
            ;;
        *)
            if [[ "$direction" =~ ^[0-9]+$ ]]; then
                current="$direction"
            else
                fail "Usage: hub label-length [+|-|grow|shrink|min|max|<number>]"
                return 1
            fi
            ;;
    esac

    # Clamp: -1 = unlimited, 0 = code only, positive = capped at longest
    if [[ "$current" -gt 0 ]]; then
        if [[ "$longest" -gt 0 ]] && (( current >= longest )); then
            current=-1
        fi
    fi
    echo "$current" > "$maxlen_file"

    local plugin="$HOME/.config/sketchybar/plugins/aerospace.sh"
    [[ -x "$plugin" ]] && "$plugin" >/dev/null 2>&1
}

cmd_bar_height() {
    local action="${1:-}"
    local state_file="$HOME/.config/hub/bar_tall"
    local is_tall=false
    [[ -f "$state_file" ]] && is_tall=true

    case "$action" in
        tall)
            touch "$state_file"
            sed -i '' "s/outer\.top =.*/outer.top =        $BAR_PADDING_TALL/" "$AEROSPACE_CONFIG"
            aerospace reload-config
            (sleep 2 && sketchybar --reload) &
            ;;
        normal)
            rm -f "$state_file"
            sed -i '' "s/outer\.top =.*/outer.top =        $BAR_PADDING_NORMAL/" "$AEROSPACE_CONFIG"
            aerospace reload-config
            (sleep 2 && sketchybar --reload) &
            ;;
        toggle)
            if $is_tall; then
                cmd_bar_height normal
            else
                cmd_bar_height tall
            fi
            ;;
        "")
            echo -e "${bold}Bar height:${reset}"
            if $is_tall; then
                echo -e "  tall (notch-avoidance mode)"
            else
                echo -e "  normal"
            fi
            echo -e "  ${yellow}Usage: hub bar-height [tall|normal|toggle]${reset}"
            ;;
        *)
            fail "Usage: hub bar-height [tall|normal|toggle]"
            return 1
            ;;
    esac
}

cmd_fullscreen() {
    local action="${1:-}"
    local is_on=false
    [[ -f "$FULLSCREEN_STATE_FILE" ]] && is_on=true

    case "$action" in
        on)
            touch "$FULLSCREEN_STATE_FILE"
            hub_log INPUT "fullscreen on"
            _fullscreen_apply
            success "Fullscreen on (dock and menu bar hidden)"
            ;;
        off)
            rm -f "$FULLSCREEN_STATE_FILE"
            hub_log INPUT "fullscreen off"
            _fullscreen_restore
            success "Fullscreen off (dock and menu bar restored)"
            ;;
        toggle)
            if $is_on; then cmd_fullscreen off; else cmd_fullscreen on; fi
            ;;
        "")
            echo -e "${bold}Fullscreen:${reset}"
            if $is_on; then
                echo -e "  on (dock and menu bar hidden)"
            else
                echo -e "  off"
            fi
            echo -e "  ${yellow}Usage: hub fullscreen [on|off|toggle]${reset}"
            ;;
        *)
            fail "Usage: hub fullscreen [on|off|toggle]"
            return 1
            ;;
    esac
}

ensure_general_workspace() {
    mkdir -p "$(dirname "$WORKSPACES_FILE")"
    _hub_lock_acquire || return 1
    local existing="[]"
    [[ -f "$WORKSPACES_FILE" ]] && existing="$(cat "$WORKSPACES_FILE")"
    local already
    already="$(echo "$existing" | jq -r '.[] | select(.workspace_id == "Z") | .workspace_id' 2>/dev/null || echo "")"
    if [[ -z "$already" ]]; then
        local updated
        updated="$(echo "$existing" | jq '. + [{name: "General", path: $ENV.HOME, root_repo: "", workspace_id: "Z"}]')"
        echo "$updated" > "$WORKSPACES_FILE"
        _hub_lock_release
        update_sketchybar_label "Z" "General"
        success "Created General workspace (Z)"
    else
        _hub_lock_release
    fi
}

cmd_up() {
    echo -e "${bold}Starting hub environment...${reset}\n"

    # Show overlay for startup
    start_overlay "Starting hub"

    # Apply fullscreen state if previously active
    if [[ -f "$FULLSCREEN_STATE_FILE" ]]; then
        update_overlay "Hiding dock and menu bar…\\nSystem Settings will open briefly."
        _fullscreen_apply
        success "Fullscreen restored (dock and menu bar hidden)"
    fi

    # Launch HubHTTPHandler as persistent daemon
    if ! pgrep -qf "HubHTTPHandler.app/Contents/MacOS/HubHTTPHandler"; then
        open -a "$HTTP_HANDLER_APP" &>/dev/null &
        disown
        success "HubHTTPHandler started"
    else
        success "HubHTTPHandler already running"
    fi

    # Start or re-enable AeroSpace
    if pgrep -q AeroSpace; then
        aerospace enable on
        aerospace reload-config
        success "AeroSpace enabled and config reloaded"
    else
        open -a AeroSpace
        success "AeroSpace started"
    fi

    # Rebuild workspace labels cache (/tmp is cleared on reboot)
    rebuild_labels_file

    # Reap any orphaned sketchybar plugin scripts left over from prior sessions.
    # A wedged LaunchServices (after sleep/wake or display reconfig) can hang
    # `app_launcher.sh` indefinitely; without this, those zombies pile up and
    # can prevent the bar from rendering correctly on restart.
    pkill -f "$SKETCHYBAR_CONFIG_DIR/plugins/" 2>/dev/null || true

    # Ensure sketchybar is running and reload config
    if ! pgrep -q sketchybar; then
        sketchybar &>/dev/null &
        disown
        success "SketchyBar started"
    else
        sketchybar --reload 2>/dev/null
        success "SketchyBar reloaded"
    fi

    if ! pgrep -q borders; then
        borders active_color=0xff00ff00 width=10.0 style=round &>/dev/null &
        disown
        success "JankyBorders started"
    else
        success "JankyBorders already running"
    fi

    update_overlay "✓  Done"
    sleep 0.8
    stop_overlay

    # Set HubHTTPHandler as default browser, saving previous for restore
    if [[ -x "$BROWSER_CTL_BIN" ]]; then
        local prev_browser
        prev_browser="$("$BROWSER_CTL_BIN" get 2>/dev/null || true)"
        if [[ -n "$prev_browser" && "$prev_browser" != "$HUB_BROWSER_ID" ]]; then
            echo "$prev_browser" > "$PREV_BROWSER_FILE"
        fi
        "$BROWSER_CTL_BIN" set "$HUB_BROWSER_ID" 2>/dev/null || true
        success "Default browser set to HubHTTPHandler"
    else
        warn "browser_ctl not found — skipping default browser change"
    fi

    echo
    ensure_general_workspace
    cache_keys &
    disown

    echo -e "${green}${bold}hub is up!${reset}"
    echo
    echo -e "  Tip: use ${bold}Ctrl+Alt+O${reset} to open configured apps, or ${bold}hub open${reset} from the CLI."
    echo -e "  Edit ${bold}~/.config/hub/apps.json${reset} to customize your app slots."
}

cmd_reboot() {
    cmd_down
    echo
    cmd_install
    echo
    cmd_up
}

cmd_down() {
    echo -e "${bold}Shutting down hub environment...${reset}\n"

    # Stop borders
    if pgrep -q borders; then
        killall borders 2>/dev/null || true
        success "JankyBorders stopped"
    else
        warn "JankyBorders was not running"
    fi

    # Stop sketchybar and wait for it to fully exit before continuing,
    # otherwise pgrep still finds it in a subsequent hub status call.
    if pgrep -q sketchybar; then
        killall sketchybar 2>/dev/null || true
        local _i=0
        while pgrep -q sketchybar && [[ $_i -lt 20 ]]; do sleep 0.1; ((_i++)); done
        success "SketchyBar stopped"
    else
        warn "SketchyBar was not running"
    fi

    # Stop AeroSpace
    if pgrep -q AeroSpace; then
        aerospace enable off
        success "AeroSpace disabled"
    else
        warn "AeroSpace was not running"
    fi

    # Stop HubHTTPHandler daemon
    if pgrep -qf "HubHTTPHandler.app/Contents/MacOS/HubHTTPHandler"; then
        pkill -f "HubHTTPHandler.app/Contents/MacOS/HubHTTPHandler" 2>/dev/null || true
        success "HubHTTPHandler stopped"
    else
        warn "HubHTTPHandler was not running"
    fi

    # Restore dock and menu bar if fullscreen was active.
    # Note: the fullscreen state file is preserved so the next `hub up` re-applies it.
    if [[ -f "$FULLSCREEN_STATE_FILE" ]]; then
        start_overlay "Restoring System Settings"
        update_overlay "Unhiding dock and menu bar…\\nSystem Settings will open briefly."
        _fullscreen_restore
        success "Dock and menu bar restored"
        update_overlay "✓  Done"
        sleep 0.8
        stop_overlay
    fi

    # Restore previous default browser
    if [[ -x "$BROWSER_CTL_BIN" ]] && [[ -f "$PREV_BROWSER_FILE" ]]; then
        local prev_browser
        prev_browser="$(cat "$PREV_BROWSER_FILE")"
        if [[ -n "$prev_browser" ]]; then
            "$BROWSER_CTL_BIN" set "$prev_browser" 2>/dev/null || true
            rm -f "$PREV_BROWSER_FILE"
            success "Default browser restored to $prev_browser"
        fi
    else
        warn "No saved browser to restore"
    fi

    echo
    echo -e "${green}${bold}hub shut down complete.${reset}"
}

# --- App launcher slot management ---

cmd_apps() {
    local sub="${1:-list}"
    shift || true

    case "$sub" in
        ls|list)
            apps_list
            ;;
        presets)
            apps_list_presets
            ;;
        add)
            local slot=""
            for arg in "$@"; do
                case "$arg" in
                    [1-5]) slot="$arg" ;;
                esac
            done
            if [ -z "$slot" ]; then
                if [ ! -f "$APPS_FILE" ]; then
                    slot=1
                else
                    local count
                    count=$(jq 'length' "$APPS_FILE" 2>/dev/null || echo 0)
                    if [ "$count" -ge "$APPS_MAX_SLOTS" ]; then
                        fail "All $APPS_MAX_SLOTS slots are filled. Use 'hub apps edit <slot>' or 'hub apps remove <slot>'."
                        return 1
                    fi
                    slot=$((count + 1))
                fi
            fi
            info "Adding app to slot $slot"
            apps_add_guided "$slot"
            ;;
        edit)
            local slot="${1:-}"
            if [ -z "$slot" ] || ! [[ "$slot" =~ ^[1-5]$ ]]; then
                fail "Usage: hub apps edit <slot 1-5>"
                return 1
            fi
            info "Editing slot $slot (pick a new app to replace it)"
            apps_add_guided "$slot"
            ;;
        rm|remove)
            local slot="${1:-}"
            local assume_yes=false
            for arg in "$@"; do
                [ "$arg" = "-y" ] && assume_yes=true
            done
            if [ -z "$slot" ] || ! [[ "$slot" =~ ^[1-5]$ ]]; then
                fail "Usage: hub apps remove <slot 1-5> [-y]"
                return 1
            fi
            if ! $assume_yes; then
                local yn
                read -rp "Remove slot $slot? [y/N] " yn
                [[ "$yn" =~ ^[Yy] ]] || { info "Cancelled."; return; }
            fi
            apps_remove_slot "$slot"
            ;;
        reset)
            local assume_yes=false
            for arg in "$@"; do
                [ "$arg" = "-y" ] && assume_yes=true
            done
            if ! $assume_yes; then
                local yn
                read -rp "Remove ALL app slots? [y/N] " yn
                [[ "$yn" =~ ^[Yy] ]] || { info "Cancelled."; return; }
            fi
            echo "[]" > "$APPS_FILE"
            success "Cleared all app slots"
            apps_refresh
            ;;
        help|-h|--help)
            echo -e "${bold}Usage:${reset} hub apps <subcommand>"
            echo
            echo "  list            Show configured app slots (default)"
            echo "  add [slot]      Add an app to the next free slot (or specified slot 1-5)"
            echo "  edit <slot>     Replace the app in slot 1-5"
            echo "  remove <slot>   Remove the app from slot 1-5"
            echo "  reset           Clear all slots"
            echo "  presets         List every app preset shipped with hub"
            echo
            echo "Slot roles: slot 1 = terminal (supports hub new --prompt),"
            echo "            slot 2 = browser (supports URL handling)."
            echo "Presets auto-wire prompt_launch and url_launch when available."
            ;;
        *)
            fail "Unknown subcommand: $sub"
            echo "Run: hub apps help"
            return 1
            ;;
    esac
}

# --- Claude notification hooks ---

cmd_claude_hooks() {
    local subcommand="${1:-}"

    # The hub script lives at scripts/hub; hook scripts are siblings at scripts/hooks/
    # hub_path stores the absolute path to the hub script written during install.
    local HOOKS_SOURCE_DIR
    local _hub_script
    _hub_script="$(cat "$HOME/.config/hub/hub_path" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
    HOOKS_SOURCE_DIR="$(cd "$(dirname "$_hub_script")/hooks" 2>/dev/null && pwd || echo "")"

    local HOOKS_TARGET_DIR="$HOME/.claude/hooks"
    local SETTINGS_FILE="$HOME/.claude/settings.json"
    local NOTIFY_SRC="$HOOKS_SOURCE_DIR/notify.sh"
    local CLEAR_SRC="$HOOKS_SOURCE_DIR/notify-clear.sh"
    local NOTIFY_DST="$HOOKS_TARGET_DIR/hub-notify.sh"
    local CLEAR_DST="$HOOKS_TARGET_DIR/hub-notify-clear.sh"

    local HOOKS_CONFIG
    read -r -d '' HOOKS_CONFIG <<'HOOKS_JSON' || true
{
  "PermissionRequest": [{"hooks": [{"type": "command", "command": "~/.claude/hooks/hub-notify.sh"}]}],
  "Stop":              [{"hooks": [{"type": "command", "command": "~/.claude/hooks/hub-notify.sh"}]}],
  "UserPromptSubmit":  [{"hooks": [{"type": "command", "command": "~/.claude/hooks/hub-notify-clear.sh"}]}],
  "PreToolUse":        [{"hooks": [{"type": "command", "command": "~/.claude/hooks/hub-notify-clear.sh"}]}],
  "PostToolUse":       [{"hooks": [{"type": "command", "command": "~/.claude/hooks/hub-notify-clear.sh"}]}],
  "PostToolUseFailure":[{"hooks": [{"type": "command", "command": "~/.claude/hooks/hub-notify-clear.sh"}]}],
  "SessionStart":      [{"hooks": [{"type": "command", "command": "~/.claude/hooks/hub-notify-clear.sh"}]}]
}
HOOKS_JSON

    our_hook_commands() {
        echo "~/.claude/hooks/hub-notify.sh"
        echo "~/.claude/hooks/hub-notify-clear.sh"
    }

    strip_our_hooks() {
        local json="$1"
        local our_cmds_json
        our_cmds_json=$(our_hook_commands | jq -R -s 'split("\n") | map(select(length > 0))')
        echo "$json" | jq --argjson ours "$our_cmds_json" '
            if .hooks then
                .hooks |= with_entries(
                    .value |= map(
                        select([.hooks[].command] | all(. as $cmd | $ours | index($cmd) | not))
                    )
                    | select(.value | length > 0)
                )
                | if (.hooks | length) == 0 then del(.hooks) else . end
            else . end
        '
    }

    case "$subcommand" in
    install)
        if ! command -v jq &>/dev/null; then
            fail "jq is required but not found. Install it with: brew install jq"
            exit 1
        fi
        if [[ ! -f "$NOTIFY_SRC" || ! -f "$CLEAR_SRC" ]]; then
            fail "Hook scripts not found in $HOOKS_SOURCE_DIR"
            exit 1
        fi
        echo "Installing Claude notification hooks..."
        echo
        mkdir -p "$HOOKS_TARGET_DIR"
        ln -sf "$NOTIFY_SRC" "$NOTIFY_DST"
        success "hub-notify.sh — linked"
        ln -sf "$CLEAR_SRC" "$CLEAR_DST"
        success "hub-notify-clear.sh — linked"
        echo
        mkdir -p "$(dirname "$SETTINGS_FILE")"
        local existing="{}"
        [[ -f "$SETTINGS_FILE" ]] && existing=$(cat "$SETTINGS_FILE")
        local merged
        merged=$(strip_our_hooks "$existing" | jq --argjson new_hooks "$HOOKS_CONFIG" '
            .hooks //= {} |
            reduce ($new_hooks | to_entries[]) as $event (
                .;
                reduce $event.value[] as $entry (
                    .;
                    .hooks[$event.key] = ((.hooks[$event.key] // []) + [$entry])
                )
            )
        ')
        echo "$merged" | jq '.' >"$SETTINGS_FILE"
        success "Settings merged into $SETTINGS_FILE"
        echo
        echo "Done! Notification hooks are active."
        echo
        echo 'Toggles (all on by default; set to "0" to disable):'
        echo "  HUB_CLAUDE_NOTIFY_COLOR — amber border on sketchybar workspace pill"
        echo "  HUB_CLAUDE_NOTIFY_SOUND — play alert sound (or set to a file path)"
        ;;
    uninstall|remove)
        if ! command -v jq &>/dev/null; then
            fail "jq is required but not found. Install it with: brew install jq"
            exit 1
        fi
        echo "Uninstalling Claude notification hooks..."
        echo
        for dst in "$NOTIFY_DST" "$CLEAR_DST"; do
            local name; name=$(basename "$dst")
            if [[ -L "$dst" ]]; then
                rm "$dst"
                success "$name — removed"
            elif [[ -f "$dst" ]]; then
                warn "$name — exists but is not a symlink, skipping"
            else
                info "$name — not present"
            fi
        done
        echo
        if [[ -f "$SETTINGS_FILE" ]]; then
            strip_our_hooks "$(cat "$SETTINGS_FILE")" | jq '.' >"$SETTINGS_FILE"
            success "Cleaned hook entries from $SETTINGS_FILE"
        else
            info "No settings file found, nothing to clean"
        fi
        echo
        echo "Done. Notification hooks removed."
        ;;
    status)
        echo "Claude notification hooks status:"
        echo
        for pair in "hub-notify.sh:$NOTIFY_SRC" "hub-notify-clear.sh:$CLEAR_SRC"; do
            local name="${pair%%:*}" src="${pair#*:}"
            local dst="$HOOKS_TARGET_DIR/$name"
            if [[ -L "$dst" ]] && [[ "$(readlink "$dst")" = "$src" ]]; then
                success "$name — linked"
            elif [[ -f "$dst" ]]; then
                warn "$name — present (not a managed symlink)"
            else
                fail "$name — not installed"
            fi
        done
        echo
        if [[ -f "$SETTINGS_FILE" ]] && command -v jq &>/dev/null; then
            local count
            count=$(jq '[.hooks // {} | to_entries[] | .value[] | .hooks[] | select(.command | test("hub-notify"))] | length' "$SETTINGS_FILE" 2>/dev/null || echo 0)
            info "settings.json: $count hook entries referencing hub-notify scripts"
        elif [[ -f "$SETTINGS_FILE" ]]; then
            info "settings.json: exists (install jq for detailed check)"
        else
            info "settings.json: not found"
        fi
        ;;
    *)
        echo "Usage: hub claude-hooks <install|uninstall|status>"
        echo
        echo "Manage Claude Code notification hooks."
        echo "On Stop/PermissionRequest: amber workspace pill, sound."
        echo "On user activity: restores normal pill. Type '.', 'dismiss', or 'clear' to clear silently."
        echo
        echo "Toggles (env vars, all on by default):"
        echo "  HUB_CLAUDE_NOTIFY_COLOR — amber border on sketchybar workspace pill"
        echo "  HUB_CLAUDE_NOTIFY_SOUND — alert sound (path or 0)"
        ;;
    esac
}

# --- Main ---
command="${1:-}"

shift || true
case "$command" in
    install)  cmd_install ;;
    new)      cmd_new "$@" ;;
    list)     cmd_list "$@" ;;
    tree)     cmd_tree "$@" ;;
    status)   cmd_status ;;
    remove)   cmd_remove "$@" ;;
    rename)   cmd_rename "$@" ;;
    next)     cmd_next ;;
    prev)     cmd_prev ;;
    apps)     cmd_apps "$@" ;;
    open)     cmd_open "$@" ;;
    open-url) cmd_open_url "$@" ;;
    app-switcher) cmd_app_switcher "$@" ;;
    up)       cmd_up ;;
    down)     cmd_down ;;
    reboot)   cmd_reboot ;;
    keys)         cmd_keys ;;
    dashboard)    cmd_dashboard ;;
    label-length) cmd_label_length "$@" ;;
    bar-height)   cmd_bar_height "$@" ;;
    bar-reload)   sketchybar --reload ;;
    repo-prefix)  cmd_repo_prefix "$@" ;;
    fullscreen)   cmd_fullscreen "$@" ;;
    arrange-open-window) arrange_after_open "${1:-}" ;;
    log)            cmd_log "$@" ;;
    config)         cmd_config "$@" ;;
    testing-banner) cmd_testing_banner "$@" ;;
    claude-hooks)   cmd_claude_hooks "$@" ;;
    help|-h|--help) print_usage ;;
    '')
        print_usage
        ;;
    *)
        ext="hub-$command"
        if command -v "$ext" &>/dev/null; then
            exec "$ext" "$@"
        fi
        fail "Unknown command: $command"
        echo
        print_usage
        exit 1
        ;;
esac
