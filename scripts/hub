#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB_DIR="$REPO_DIR/lib"
CONFIG_DIR="$REPO_DIR/config"
AEROSPACE_CONFIG="$HOME/.aerospace.toml"
SKETCHYBAR_CONFIG_DIR="$HOME/.config/sketchybar"
OVERLAY_SRC="$LIB_DIR/overlay.swift"
OVERLAY_BIN="$HOME/.config/hub/overlay"
DIALOG_SRC="$LIB_DIR/new_workspace_dialog.swift"
DIALOG_BIN="$HOME/.config/hub/new_workspace_dialog"
CONFIRM_SRC="$LIB_DIR/confirm_dialog.swift"
CONFIRM_BIN="$HOME/.config/hub/confirm_dialog"
RENAME_SRC="$LIB_DIR/rename_dialog.swift"
RENAME_BIN="$HOME/.config/hub/rename_dialog"
DASHBOARD_SRC="$LIB_DIR/dashboard_dialog.swift"
DASHBOARD_BIN="$HOME/.config/hub/dashboard_dialog"
OUTPUT_WINDOW_SRC="$LIB_DIR/output_window.swift"
OUTPUT_WINDOW_BIN="$HOME/.config/hub/output_window"
HTTP_HANDLER_SRC="$LIB_DIR/http_handler.swift"
HTTP_HANDLER_APP="$HOME/Applications/HubHTTPHandler.app"
BROWSER_CTL_SRC="$LIB_DIR/browser_ctl.swift"
BROWSER_CTL_BIN="$HOME/.config/hub/browser_ctl"
PREV_BROWSER_FILE="$HOME/.config/hub/prev_browser"
HUB_BROWSER_ID="sh.hub.http-handler"
WORKSPACES_FILE="$HOME/.config/hub/workspaces.json"
RECENT_REPOS_FILE="$HOME/.config/hub/recent_repos.json"
APPS_FILE="$HOME/.config/hub/apps.json"
APPLESCRIPT="$LIB_DIR/hide_menu_bar.applescript"

# Colors
bold='\033[1m'
green='\033[32m'
yellow='\033[33m'
red='\033[31m'
blue='\033[34m'
reset='\033[0m'

print_usage() {
    echo -e "${bold}Usage:${reset} hub <command>"
    echo
    echo -e "${bold}Commands:${reset}"
    echo "  install       Install hub alias, check dependencies, compile binaries, and deploy configs"
    echo "  up            Start AeroSpace, SketchyBar, JankyBorders, hide the Dock and menu bar"
    echo "  down          Stop everything, restore the Dock and menu bar"
    echo "  reboot        Stop, reinstall, and restart the hub environment"
    echo "  new           Create a new workspace (opens dialog)"
    echo "  list          List all defined workspaces
  tree          Show the tiling tree for a workspace"
    echo "  status        Show current service state, workspace info, and label length"
    echo "  remove        Remove a workspace (current or by ID)"
    echo "  rename        Rename a workspace (current or by ID)"
    echo "  open          Open configured apps in current workspace"
    echo "  keys          List all AeroSpace key bindings (main and service mode)"
    echo "  dashboard     Show status and key bindings in a full-screen modal"
    echo "  label-length  Shrink or grow workspace label max length (+/-/grow/shrink/number)"
    echo "  repo-prefix   Show or hide the repo name prefix on workspace labels (on/off/toggle)"
    echo "  help          Show this help"
    echo
    echo -e "${bold}Examples:${reset}"
    echo "  hub install        # install shell alias and dependencies"
    echo "  hub up             # start the workspace environment"
    echo "  hub down           # tear down the workspace environment"
    echo "  hub new            # create a new workspace"
    echo "  hub list           # list all workspaces"
    echo "  hub list -v        # list with paths and root repos"
    echo "  hub remove         # remove the current workspace"
    echo "  hub remove A       # remove workspace A"
    echo "  hub remove A -y    # remove workspace A without confirmation"
    echo "  hub rename         # rename the current workspace"
    echo "  hub rename A       # rename workspace A"
    echo "  hub open           # interactive: focus or launch an app"
    echo "  hub open 1         # focus app 1 (or launch if not running)"
    echo "  hub open 1 --force # always launch a new window of app 1"
    echo "  hub open --all     # launch any missing apps into current workspace"
    echo "  hub tree           # show tiling tree for the focused workspace"
    echo "  hub tree --all     # show tiling tree for all non-empty workspaces"
    echo "  hub tree --workspace A  # show tiling tree for workspace A"
    echo
    echo -e "${bold}App launcher config:${reset}"
    echo "  Edit ~/.config/hub/apps.json to configure up to 5 app slots."
    echo "  Each entry: { \"name\": \"App Name\", \"launch\": \"<shell cmd>\", \"icon\": \"App Name\" }"
    echo "  Optional: \"url_launch\" for URL handlers (supports {url} placeholder)."
    echo "  Use {path}, {workspace}, and {url} as substitution variables."
}

success() { echo -e "  ${green}✓${reset} $1"; }
warn()    { echo -e "  ${yellow}!${reset} $1"; }
fail()    { echo -e "  ${red}✗${reset} $1"; }
info()    { echo -e "  ${blue}→${reset} $1"; }

read_superset_config() {
    local repo_root="$1" key="$2"
    local cfg="$repo_root/.superset/config.json"
    [[ -f "$cfg" ]] || return 1
    jq -r --arg k "$key" '.[$k][0] // empty' "$cfg" 2>/dev/null
}

# --- Overlay helpers ---

OVERLAY_PID=""
OVERLAY_FIFO=""

start_overlay() {
    local title="${1:-hub}"
    if [[ -x "$OVERLAY_BIN" ]]; then
        OVERLAY_FIFO="$(mktemp -u "${TMPDIR:-/tmp}/hub-overlay.XXXXXX")"
        mkfifo "$OVERLAY_FIFO" || {
            OVERLAY_FIFO=""
            return
        }
        "$OVERLAY_BIN" "$title" < "$OVERLAY_FIFO" &
        OVERLAY_PID=$!
        exec 3>"$OVERLAY_FIFO"
    fi
}

update_overlay() {
    local text="$1"
    if [[ -n "${OVERLAY_PID:-}" ]] && kill -0 "$OVERLAY_PID" 2>/dev/null; then
        echo "$text" >&3
    fi
}

stop_overlay() {
    if [[ -n "${OVERLAY_PID:-}" ]] && kill -0 "$OVERLAY_PID" 2>/dev/null; then
        echo "QUIT" >&3
        exec 3>&-
        wait "$OVERLAY_PID" 2>/dev/null || true
    fi
    OVERLAY_PID=""
    if [[ -n "${OVERLAY_FIFO:-}" ]]; then
        rm -f "$OVERLAY_FIFO"
        OVERLAY_FIFO=""
    fi
}

# --- Menu bar toggle (AppleScript, non-blocking) ---

MENU_BAR_PID=""

toggle_menu_bar() {
    local hidden="$1"
    if [[ "$hidden" == "true" ]]; then
        osascript "$APPLESCRIPT" "Always" &>/dev/null &
    else
        osascript "$APPLESCRIPT" "Never" &>/dev/null &
    fi
    MENU_BAR_PID=$!
}

wait_for_menu_bar() {
    if [[ -n "${MENU_BAR_PID:-}" ]]; then
        wait "$MENU_BAR_PID" 2>/dev/null || true
        killall "System Settings" 2>/dev/null || true
        MENU_BAR_PID=""
    fi
}

# --- Brew helpers ---

check_brew_package() {
    local pkg="$1"
    local cask="$2"
    if [[ "$cask" == "true" ]]; then
        brew list --cask "$pkg" &>/dev/null
    else
        brew list "$pkg" &>/dev/null
    fi
}

install_brew_package() {
    local pkg="$1"
    local cask="$2"
    if [[ "$cask" == "true" ]]; then
        brew install --cask "$pkg"
    else
        brew install "$pkg"
    fi
}

# --- Compile overlay ---

compile_swift() {
    local name="$1"
    local src="$2"
    local bin="$3"

    if [[ ! -f "$src" ]]; then
        warn "$name source not found — skipping"
        return
    fi

    if [[ -f "$bin" ]] && [[ "$bin" -nt "$src" ]]; then
        info "$name up to date"
        return
    fi

    mkdir -p "$(dirname "$bin")"
    if swiftc -O -o "$bin" -framework Cocoa "$src" 2>/dev/null; then
        success "$name compiled: $bin"
    else
        warn "$name compilation failed"
    fi
}

compile_all() {
    echo -e "${bold}Compiling Swift binaries...${reset}"
    compile_swift "overlay" "$OVERLAY_SRC" "$OVERLAY_BIN"
    compile_swift "new_workspace_dialog" "$DIALOG_SRC" "$DIALOG_BIN"
    compile_swift "confirm_dialog" "$CONFIRM_SRC" "$CONFIRM_BIN"
    compile_swift "rename_dialog" "$RENAME_SRC" "$RENAME_BIN"
    compile_swift "dashboard_dialog" "$DASHBOARD_SRC" "$DASHBOARD_BIN"
    compile_swift "browser_ctl" "$BROWSER_CTL_SRC" "$BROWSER_CTL_BIN"
    compile_swift "output_window" "$OUTPUT_WINDOW_SRC" "$OUTPUT_WINDOW_BIN"
    build_http_handler
}

build_http_handler() {
    local src="$HTTP_HANDLER_SRC"
    local app="$HTTP_HANDLER_APP"
    local bin="$app/Contents/MacOS/HubHTTPHandler"
    local plist="$app/Contents/Info.plist"

    if [[ ! -f "$src" ]]; then
        warn "http_handler source not found — skipping"
        return
    fi

    if [[ -f "$bin" ]] && [[ "$bin" -nt "$src" ]] && [[ "$bin" -nt "${BASH_SOURCE[0]}" ]]; then
        info "HubHTTPHandler.app up to date"
        return
    fi

    mkdir -p "$app/Contents/MacOS"
    mkdir -p "$app/Contents/Resources"

    cat > "$plist" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>sh.hub.http-handler</string>
    <key>CFBundleName</key>
    <string>HubHTTPHandler</string>
    <key>CFBundleDisplayName</key>
    <string>Hub HTTP Handler</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleExecutable</key>
    <string>HubHTTPHandler</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>HTTP URL</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>http</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleURLName</key>
            <string>HTTPS URL</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>https</string>
            </array>
        </dict>
    </array>
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.html</string>
                <string>public.xhtml</string>
            </array>
        </dict>
    </array>
    <key>LSHandlerRank</key>
    <string>Alternate</string>
    <key>LSUIElement</key>
    <true/>
</dict>
</plist>
PLIST

    if swiftc -O -o "$bin" -framework Cocoa "$src" 2>/dev/null; then
        # Register with Launch Services so it appears in Default Web Browser list
        /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister \
            -f "$app" 2>/dev/null || true
        success "HubHTTPHandler.app built and registered: $app"
    else
        warn "HubHTTPHandler.app compilation failed"
    fi
}

# --- Commands ---

cmd_install() {
    echo -e "${bold}Installing hub...${reset}\n"

    # --- Check dependencies ---
    echo -e "${bold}Checking dependencies...${reset}"
    local missing=()
    local missing_cask=()

    if check_brew_package aerospace true; then
        success "aerospace is installed"
    else
        fail "aerospace is not installed"
        missing+=(aerospace)
        missing_cask+=(true)
    fi

    if check_brew_package sketchybar false; then
        success "sketchybar is installed"
    else
        fail "sketchybar is not installed"
        missing+=(sketchybar)
        missing_cask+=(false)
    fi

    if check_brew_package borders false; then
        success "borders (JankyBorders) is installed"
    else
        fail "borders (JankyBorders) is not installed"
        missing+=(borders)
        missing_cask+=(false)
    fi

    if command -v jq &>/dev/null; then
        success "jq is installed"
    else
        fail "jq is not installed"
        missing+=(jq)
        missing_cask+=(false)
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo
        echo -e "Missing packages: ${bold}${missing[*]}${reset}"
        read -rp "Install them now? [y/N] " answer
        if [[ "$answer" =~ ^[Yy]$ ]]; then
            for i in "${!missing[@]}"; do
                echo -e "\nInstalling ${bold}${missing[$i]}${reset}..."
                install_brew_package "${missing[$i]}" "${missing_cask[$i]}"
                success "${missing[$i]} installed"
            done
        else
            echo "Skipping package installation. Some features may not work."
        fi
    fi

    # --- Deploy aerospace config ---
    echo
    echo -e "${bold}Deploying configs...${reset}"
    if [[ -f "$AEROSPACE_CONFIG" ]]; then
        if grep -q "# AeroSpace config managed by hub" "$AEROSPACE_CONFIG" 2>/dev/null; then
            success "aerospace.toml already managed by hub, updating"
        else
            warn "existing aerospace.toml found, backing up to ${AEROSPACE_CONFIG}.bak"
            cp "$AEROSPACE_CONFIG" "${AEROSPACE_CONFIG}.bak"
        fi
    fi
    sed "s|__HUB_SCRIPT__|$REPO_DIR/scripts/hub|g" "$CONFIG_DIR/aerospace.toml" > "$AEROSPACE_CONFIG"
    success "aerospace.toml deployed to $AEROSPACE_CONFIG"

    # Write hub script path for runtime use by HubHTTPHandler and other compiled binaries
    echo "$REPO_DIR/scripts/hub" > "$HOME/.config/hub/hub_path"

    # --- Deploy sketchybar config ---
    if [[ -d "$SKETCHYBAR_CONFIG_DIR" ]]; then
        rm -rf "$SKETCHYBAR_CONFIG_DIR"
        info "removed existing sketchybar config"
    fi
    mkdir -p "$SKETCHYBAR_CONFIG_DIR/plugins"
    sed "s|__HUB_SCRIPT__|$REPO_DIR/scripts/hub|g" "$CONFIG_DIR/sketchybar/sketchybarrc" > "$SKETCHYBAR_CONFIG_DIR/sketchybarrc"
    for f in "$CONFIG_DIR/sketchybar/plugins/"*.sh; do
        sed "s|__HUB_SCRIPT__|$REPO_DIR/scripts/hub|g" "$f" > "$SKETCHYBAR_CONFIG_DIR/plugins/$(basename "$f")"
    done
    chmod +x "$SKETCHYBAR_CONFIG_DIR/sketchybarrc" "$SKETCHYBAR_CONFIG_DIR/plugins/"*.sh
    success "sketchybar config deployed to $SKETCHYBAR_CONFIG_DIR"

    # --- Write default apps.json ---
    mkdir -p "$(dirname "$APPS_FILE")"
    if [[ ! -f "$APPS_FILE" ]]; then
        cat > "$APPS_FILE" << 'APPS_EOF'
[
  {
    "name": "iTerm2",
    "launch": "osascript -e 'tell application \"iTerm2\"' -e 'activate' -e 'set w to (create window with default profile)' -e 'tell current session of w' -e 'write text \"cd {path}\"' -e 'end tell' -e 'end tell'",
    "icon": "iTerm2"
  },
  {
    "name": "Google Chrome",
    "launch": "open -na 'Google Chrome' --args --new-window --profile-directory=hub",
    "icon": "Google Chrome"
  },
  {
    "name": "Code",
    "launch": "/usr/local/bin/code --new-window {path}",
    "icon": "Code"
  }
]
APPS_EOF
        success "Created default $APPS_FILE"
    else
        info "apps.json already exists — edit it to customize your app slots:"
        info "  $APPS_FILE"
    fi

    # --- Global gitignore for worktrees/ ---
    echo
    echo -e "${bold}Configuring global gitignore...${reset}"
    local global_gitignore
    global_gitignore="$(git config --global core.excludesFile 2>/dev/null || echo "")"
    if [[ -z "$global_gitignore" ]]; then
        global_gitignore="$HOME/.gitignore_global"
        git config --global core.excludesFile "$global_gitignore"
        success "Set core.excludesFile to $global_gitignore"
    else
        global_gitignore="${global_gitignore/#\~/$HOME}"
        success "Using existing core.excludesFile: $global_gitignore"
    fi
    if [[ ! -f "$global_gitignore" ]]; then
        touch "$global_gitignore"
    fi
    if ! grep -q '^worktrees/$' "$global_gitignore" 2>/dev/null; then
        echo "worktrees/" >> "$global_gitignore"
        success "Added worktrees/ to $global_gitignore"
    else
        info "worktrees/ already in $global_gitignore"
    fi

    # --- Compile Swift binaries ---
    echo
    compile_all

    # --- Install shell alias ---
    echo
    echo -e "${bold}Installing shell alias...${reset}"

    local shell_name
    case "$SHELL" in
        */zsh)  shell_name=zsh ;;
        */bash) shell_name=bash ;;
        */fish) shell_name=fish ;;
        *)
            fail "Unsupported shell: $SHELL"
            echo "Add this alias manually: alias hub='$REPO_DIR/scripts/hub'"
            return
            ;;
    esac
    success "Detected shell: $shell_name"

    local snippet_path="$REPO_DIR/.hub-shell-integration"
    local script_path
    script_path="$(printf '%q' "$REPO_DIR/scripts/hub")"

    if [[ "$shell_name" == "fish" ]]; then
        echo "alias hub $script_path" > "$snippet_path"
    else
        echo "alias hub=$script_path" > "$snippet_path"
    fi
    success "Created $snippet_path"

    local config_file
    case "$shell_name" in
        zsh)  config_file="$HOME/.zshrc" ;;
        bash)
            if [[ "$(uname)" == "Darwin" ]]; then
                config_file="$HOME/.bash_profile"
            else
                config_file="$HOME/.bashrc"
            fi
            ;;
        fish) config_file="$HOME/.config/fish/config.fish" ;;
    esac

    if [[ -f "$config_file" ]] && grep -q '.hub-shell-integration' "$config_file" 2>/dev/null; then
        warn "Already installed in $config_file"
    else
        if [[ "$shell_name" == "fish" ]]; then
            mkdir -p "$(dirname "$config_file")"
            printf '\n# hub workspace integration\nsource %s\n' "'$snippet_path'" >> "$config_file"
        else
            printf '\n# hub workspace integration\nsource %s\n' "$snippet_path" >> "$config_file"
        fi
        success "Added to $config_file"
    fi

    # --- Reload running services ---
    echo
    echo -e "${bold}Reloading services...${reset}"
    if pgrep -q sketchybar; then
        sketchybar --reload 2>/dev/null || true
        success "SketchyBar reloaded"
    fi
    if pgrep -q AeroSpace; then
        aerospace reload-config 2>/dev/null || true
        success "AeroSpace config reloaded"
    fi

    echo
    rm -f "$KEYS_CACHE"

    echo -e "${green}${bold}Installation complete!${reset}"
    echo
    echo "To activate, run:"
    echo "  source $config_file"
    echo
    echo "Or open a new terminal."
    echo
    echo -e "  Tip: edit ${bold}~/.config/hub/apps.json${reset} to configure your app launcher slots."
    echo -e "  Then use ${bold}Ctrl+Alt+O${reset} or ${bold}hub open${reset} to launch apps into the current workspace."
}

cmd_new() {
    if [[ ! -x "$DIALOG_BIN" ]]; then
        fail "new_workspace_dialog not compiled. Run: hub install"
        exit 1
    fi

    # Clean up any stale result
    rm -f /tmp/hub-new-workspace

    # Launch the dialog and wait
    "$DIALOG_BIN"

    # Read result
    local result
    result="$(cat /tmp/hub-new-workspace 2>/dev/null || echo "cancel")"
    rm -f /tmp/hub-new-workspace

    if [[ "$result" == "cancel" || -z "$result" ]]; then
        echo "Cancelled."
        return
    fi

    # Parse: name\tpath\troot_repo\tworkspace_id\tcolor\tsetup_cmd\tapps ("-" = empty)
    local ws_name ws_path ws_root ws_id ws_color ws_setup_cmd ws_apps
    IFS=$'\t' read -r ws_name ws_path ws_root ws_id ws_color ws_setup_cmd ws_apps <<< "$result"
    [[ "$ws_color" == "-" ]] && ws_color=""
    [[ "$ws_setup_cmd" == "-" ]] && ws_setup_cmd=""
    [[ "$ws_apps" == "-" ]] && ws_apps=""

    if [[ -z "$ws_name" || -z "$ws_id" ]]; then
        fail "Invalid dialog result"
        return
    fi

    # "-" means no repo — treat path as home dir, no iTerm cd, no recent_repos entry
    local no_repo=false
    if [[ "$ws_path" == "-" || -z "$ws_path" ]]; then
        no_repo=true
        ws_path="$HOME"
        ws_root=""
    fi

    success "Creating workspace: $ws_name (workspace $ws_id)"
    [[ "$no_repo" == "false" ]] && info "Path: $ws_path"

    # Save to workspaces.json
    mkdir -p "$(dirname "$WORKSPACES_FILE")"
    local existing="[]"
    if [[ -f "$WORKSPACES_FILE" ]]; then
        existing="$(cat "$WORKSPACES_FILE")"
    fi

    local updated
    if [[ -n "$ws_color" ]]; then
        updated="$(echo "$existing" | jq --arg name "$ws_name" --arg path "$ws_path" \
            --arg root "$ws_root" --arg id "$ws_id" --arg color "$ws_color" \
            '. + [{name: $name, path: $path, root_repo: $root, workspace_id: $id, color: $color}]')"
    else
        updated="$(echo "$existing" | jq --arg name "$ws_name" --arg path "$ws_path" \
            --arg root "$ws_root" --arg id "$ws_id" \
            '. + [{name: $name, path: $path, root_repo: $root, workspace_id: $id}]')"
    fi

    echo "$updated" > "$WORKSPACES_FILE"
    success "Saved to $WORKSPACES_FILE"

    # Update recent_repos.json (skip for no-repo workspaces)
    if [[ "$no_repo" == "false" ]]; then
        local recent_repo="${ws_root:-$ws_path}"
        local existing_recent="[]"
        if [[ -f "$RECENT_REPOS_FILE" ]]; then
            existing_recent="$(cat "$RECENT_REPOS_FILE")"
        fi
        echo "$existing_recent" | jq --arg r "$recent_repo" \
            '[$r] + (map(select(. != $r))) | .[0:20]' > "$RECENT_REPOS_FILE"
    fi

    # Update sketchybar label
    update_sketchybar_label "$ws_id" "$ws_name"

    # Switch to the workspace
    aerospace workspace "$ws_id"
    success "Switched to workspace $ws_id"

    # Open checked apps sequentially; collect new window IDs for layout arrangement
    local _opened_wids=()
    if [[ -n "$ws_apps" ]]; then
        IFS=',' read -ra _slots <<< "$ws_apps"
        for _slot in "${_slots[@]}"; do
            OPEN_APP_SLOT_WID=""
            open_app_slot "$_slot" "$ws_id" "$ws_path" false true
            [[ -n "$OPEN_APP_SLOT_WID" ]] && _opened_wids+=("$OPEN_APP_SLOT_WID") || true
        done
    fi

    # Run worktree setup command in background output_window.
    # Use zsh --no-rcs + manual source of ~/.zshrc so user-exported env vars
    # (e.g. BUNDLE_WITHOUT) are available when hub is launched from AeroSpace
    # with a minimal environment, without the interactive-shell noise from zsh -i.
    if [[ -n "$ws_setup_cmd" && -n "$ws_root" ]]; then
        local full_setup_cmd="$ws_root/$ws_setup_cmd"
        local _wrap="source \"\$HOME/.zshrc\" 2>/dev/null; cd $(printf '%q' "$ws_path") && $full_setup_cmd"
        if [[ -x "$OUTPUT_WINDOW_BIN" ]]; then
            ( set +e; /bin/zsh --no-rcs -c "$_wrap" 2>&1; echo "EXIT:$?" ) | "$OUTPUT_WINDOW_BIN" "Hub: Setting up workspace $ws_name" &
            disown
        else
            ( /bin/zsh --no-rcs -c "$_wrap" ) &
            disown
        fi

        (
            sleep 0.3
            local ow_wid
            ow_wid="$(aerospace list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null \
                | grep '|output_window$' | cut -d'|' -f1 | head -1 || echo "")"
            [[ -n "$ow_wid" ]] && aerospace move-node-to-workspace --window-id "$ow_wid" "$ws_id" 2>/dev/null || true
        ) &
        disown
    fi

    # Arrange windows in the new workspace based on count
    if [[ ${#_opened_wids[@]} -ge 1 ]]; then
        local _wids_copy=("${_opened_wids[@]}")
        (
            sleep 0.3
            arrange_workspace_windows "$ws_id" "${_wids_copy[@]}"
        ) &
        disown
    fi

    echo
    echo -e "${green}${bold}Workspace '$ws_name' created on workspace $ws_id!${reset}"
}

rebuild_labels_file() {
    local labels_file="/tmp/hub_sketchybar_labels"
    if [[ -f "$WORKSPACES_FILE" ]]; then
        # Format: workspace_id:name:color:repo_basename
        jq -r '.[] | [.workspace_id, .name, (.color // ""), ((.root_repo // "") | if . == "" then "" else (. | gsub(".*/"; "")) end)] | join(":")' \
            "$WORKSPACES_FILE" > "$labels_file" 2>/dev/null || true
    fi
}

update_sketchybar_label() {
    local ws_id="$1"
    local ws_name="$2"
    local label="$ws_id $ws_name"
    sketchybar --set "space.$ws_id" "label=$label" drawing=on 2>/dev/null || true
    rebuild_labels_file
}

remove_sketchybar_label() {
    local ws_id="$1"
    sketchybar --set "space.$ws_id" "label=$ws_id" drawing=off 2>/dev/null || true
    rebuild_labels_file
}

cmd_rename() {
    local ws_id="${1:-}"

    # If no ID given, use the currently focused workspace
    if [[ -z "$ws_id" ]]; then
        ws_id="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
        if [[ -z "$ws_id" ]]; then
            fail "Could not determine current workspace"
            exit 1
        fi
    fi

    if [[ ! -f "$WORKSPACES_FILE" ]]; then
        fail "No workspaces defined"
        exit 1
    fi

    local ws_name
    ws_name="$(jq -r --arg id "$ws_id" \
        '.[] | select(.workspace_id == $id) | .name' \
        "$WORKSPACES_FILE" 2>/dev/null)" || true

    if [[ -z "$ws_name" ]]; then
        fail "No workspace found with ID '$ws_id'"
        exit 1
    fi

    if [[ ! -x "$RENAME_BIN" ]]; then
        fail "rename_dialog not compiled. Run: hub install"
        exit 1
    fi

    rm -f /tmp/hub-rename
    "$RENAME_BIN" "$ws_id" "$ws_name"
    local dialog_exit=$?

    if [[ $dialog_exit -ne 0 || ! -f /tmp/hub-rename ]]; then
        info "Rename cancelled"
        return
    fi

    local new_name
    new_name="$(cat /tmp/hub-rename)"
    rm -f /tmp/hub-rename

    if [[ -z "$new_name" || "$new_name" == "$ws_name" ]]; then
        info "Name unchanged"
        return
    fi

    local updated
    updated="$(jq --arg id "$ws_id" --arg name "$new_name" \
        '[.[] | if .workspace_id == $id then .name = $name else . end]' \
        "$WORKSPACES_FILE")"
    echo "$updated" > "$WORKSPACES_FILE"

    update_sketchybar_label "$ws_id" "$new_name"

    success "Renamed workspace $ws_id: '$ws_name' → '$new_name'"
}

cmd_next() { _cycle_hub_workspace 1; }
cmd_prev() { _cycle_hub_workspace -1; }

_cycle_hub_workspace() {
    local dir="$1"

    local all_ids=("1" "2" "3" "4" "5" "6" "7" "8" "9"
                   "A" "B" "C" "D" "E" "F" "G" "I" "M"
                   "N" "O" "P" "Q" "R" "S" "T" "U" "V" "W" "X" "Y" "Z")

    local registered=()
    if [[ -f "$WORKSPACES_FILE" ]]; then
        while IFS= read -r id; do
            [[ -n "$id" ]] && registered+=("$id")
        done < <(jq -r '.[].workspace_id' "$WORKSPACES_FILE" 2>/dev/null)
    fi

    local ordered=()
    for id in "${all_ids[@]}"; do
        for reg in "${registered[@]}"; do
            if [[ "$id" == "$reg" ]]; then
                ordered+=("$id")
                break
            fi
        done
    done

    [[ ${#ordered[@]} -eq 0 ]] && return

    local current
    current="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"

    local idx=-1
    for i in "${!ordered[@]}"; do
        if [[ "${ordered[$i]}" == "$current" ]]; then
            idx=$i
            break
        fi
    done

    local target_idx
    if [[ $idx -eq -1 ]]; then
        target_idx=$(( dir == 1 ? 0 : ${#ordered[@]} - 1 ))
    else
        target_idx=$(( (idx + dir + ${#ordered[@]}) % ${#ordered[@]} ))
    fi

    aerospace workspace "${ordered[$target_idx]}"
}

cmd_list() {
    local verbose=false
    for arg in "$@"; do
        [[ "$arg" == "-v" ]] && verbose=true
    done

    if [[ ! -f "$WORKSPACES_FILE" ]]; then
        echo "No workspaces defined."
        return
    fi

    local count
    count="$(jq 'length' "$WORKSPACES_FILE" 2>/dev/null || echo 0)"

    if [[ "$count" == "0" ]]; then
        echo "No workspaces defined."
        return
    fi

    if [[ "$verbose" == "true" ]]; then
        local max_name=4 max_path=4 max_root=9
        while IFS=$'\t' read -r _ ws_name ws_path ws_root; do
            (( ${#ws_name} > max_name )) && max_name=${#ws_name}
            (( ${#ws_path} > max_path )) && max_path=${#ws_path}
            (( ${#ws_root} > max_root )) && max_root=${#ws_root}
        done < <(jq -r 'sort_by(.workspace_id)[] | [.workspace_id, .name, .path, (.root_repo // "")] | @tsv' "$WORKSPACES_FILE")

        printf "${bold}%-4s  %-${max_name}s  %-${max_path}s  %s${reset}\n" "ID" "NAME" "PATH" "ROOT REPO"
        printf "%-4s  %-${max_name}s  %-${max_path}s  %s\n" \
            "$(printf '%0.s-' $(seq 1 4))" \
            "$(printf '%0.s-' $(seq 1 "$max_name"))" \
            "$(printf '%0.s-' $(seq 1 "$max_path"))" \
            "$(printf '%0.s-' $(seq 1 "$max_root"))"

        jq -r 'sort_by(.workspace_id)[] | [.workspace_id, .name, .path, (.root_repo // "")] | @tsv' \
            "$WORKSPACES_FILE" | while IFS=$'\t' read -r ws_id ws_name ws_path ws_root; do
            printf "%-4s  %-${max_name}s  %-${max_path}s  %s\n" "$ws_id" "$ws_name" "$ws_path" "$ws_root"
        done
    else
        printf "${bold}%-4s  %s${reset}\n" "ID" "NAME"
        printf "%-4s  %s\n" "----" "----"

        jq -r 'sort_by(.workspace_id)[] | [.workspace_id, .name] | @tsv' \
            "$WORKSPACES_FILE" | while IFS=$'\t' read -r ws_id ws_name; do
            printf "%-4s  %s\n" "$ws_id" "$ws_name"
        done
    fi
}

cmd_tree() {
    local tool
    tool="$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../agents/bin/aerospace-tree"
    if [[ ! -x "$tool" ]]; then
        fail "aerospace-tree not found at $tool"
    fi
    "$tool" "$@"
}

cmd_status() {
    local compact=false
    for arg in "$@"; do [[ "$arg" == "--compact" ]] && compact=true; done

    echo -e "${bold}hub status${reset}"
    echo

    # --- Services ---
    echo -e "${bold}Services:${reset}"
    if aerospace list-workspaces --all &>/dev/null; then
        echo -e "  ${green}✓${reset} AeroSpace"
    else
        echo -e "  ${red}✗${reset} AeroSpace"
    fi
    if pgrep -q sketchybar; then
        echo -e "  ${green}✓${reset} SketchyBar"
    else
        echo -e "  ${red}✗${reset} SketchyBar"
    fi
    if pgrep -q borders; then
        echo -e "  ${green}✓${reset} JankyBorders"
    else
        echo -e "  ${red}✗${reset} JankyBorders"
    fi
    echo

    # --- Current workspace ---
    local current_ws
    current_ws="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
    local current_name=""
    if [[ -n "$current_ws" && -f "$WORKSPACES_FILE" ]]; then
        current_name="$(jq -r --arg id "$current_ws" \
            '.[] | select(.workspace_id == $id) | .name' \
            "$WORKSPACES_FILE" 2>/dev/null)"
    fi
    if [[ -n "$current_ws" ]]; then
        if [[ -n "$current_name" ]]; then
            echo -e "${bold}Current workspace:${reset} $current_ws  $current_name"
        else
            echo -e "${bold}Current workspace:${reset} $current_ws"
        fi
    fi

    # --- Active (non-empty) workspaces ---
    local active_ws
    active_ws="$(aerospace list-workspaces --monitor all --empty no 2>/dev/null || echo "")"
    local active_count=0
    [[ -n "$active_ws" ]] && active_count="$(echo "$active_ws" | wc -l | tr -d ' ')"
    echo -e "${bold}Active workspaces:${reset} $active_count  ($(echo "$active_ws" | tr '\n' ' ' | sed 's/ $//'))"
    echo

    # --- Label length ---
    local maxlen=-1
    [[ -f /tmp/hub_label_maxlen ]] && maxlen="$(cat /tmp/hub_label_maxlen 2>/dev/null || echo -1)"
    echo -e "${bold}Label length:${reset}"
    if [[ "$maxlen" -lt 0 ]]; then
        echo -e "  unlimited  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
    elif [[ "$maxlen" -eq 0 ]]; then
        echo -e "  workspace number only  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
    else
        echo -e "  $maxlen chars"
    fi
    echo

    # --- Workspaces ---
    if [[ "$compact" == "true" ]]; then
        cmd_list
    else
        cmd_list -v
    fi
}

cmd_remove() {
    local ws_id="${1:-}"
    local auto_yes=false

    # Parse flags
    for arg in "$@"; do
        if [[ "$arg" == "-y" ]]; then
            auto_yes=true
        fi
    done

    # If no ID given, use the currently focused workspace
    if [[ -z "$ws_id" || "$ws_id" == "-y" ]]; then
        ws_id="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
        if [[ -z "$ws_id" ]]; then
            fail "Could not determine current workspace"
            exit 1
        fi
    fi

    # Look up workspace info (may not exist if workspace was never registered with hub)
    local ws_info=""
    if [[ -f "$WORKSPACES_FILE" ]]; then
        ws_info="$(jq -r --arg id "$ws_id" \
            '.[] | select(.workspace_id == $id) | [.name, .path, .root_repo] | @tsv' \
            "$WORKSPACES_FILE" 2>/dev/null)" || true
    fi

    local ws_name ws_path ws_root
    if [[ -n "$ws_info" ]]; then
        IFS=$'\t' read -r ws_name ws_path ws_root <<< "$ws_info"
    else
        ws_name="$ws_id"
        ws_path=""
        ws_root=""
    fi

    # Count windows
    local windows
    windows="$(aerospace list-windows --workspace "$ws_id" --format '%{window-id}' 2>/dev/null || echo "")"
    local window_count=0
    if [[ -n "$windows" ]]; then
        window_count="$(echo "$windows" | wc -l | tr -d ' ')"
    fi

    local confirm_msg="Remove workspace '$ws_name' (ID: $ws_id)?"
    if [[ "$window_count" -gt 0 ]]; then
        confirm_msg="Remove workspace '$ws_name' (ID: $ws_id)? Open windows will be closed. Any that don't close immediately will be moved to the Z General workspace."
    fi

    # Determine if this is a worktree (path differs from root repo, path exists on disk)
    local is_worktree=false
    if [[ -n "$ws_root" && "$ws_path" != "$ws_root" && "$ws_path" != "-" && -d "$ws_path" ]]; then
        is_worktree=true
    fi

    local ws_branch=""
    if [[ "$is_worktree" == "true" ]]; then
        ws_branch="$(git -C "$ws_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
    fi

    # Confirm: show GUI dialog unless -y
    local remove_worktree=true
    local delete_branch=false
    if [[ "$auto_yes" != "true" ]]; then
        if [[ ! -x "$CONFIRM_BIN" ]]; then
            fail "confirm_dialog not compiled. Run: hub install"
            exit 1
        fi
        rm -f /tmp/hub-confirm-state
        local dialog_args=("Remove Workspace" "$confirm_msg")
        if [[ "$is_worktree" == "true" ]]; then
            dialog_args+=("Remove / teardown worktree")
            dialog_args+=("!Delete branch")
        fi
        local dialog_exit=0
        "$CONFIRM_BIN" "${dialog_args[@]}" || dialog_exit=$?
        if [[ "$dialog_exit" -ne 0 ]]; then
            echo "Cancelled."; return
        fi
        # Read worktree checkbox states
        if [[ "$is_worktree" == "true" && -f /tmp/hub-confirm-state ]]; then
            local v1 v2
            v1="$(grep "^cb1=" /tmp/hub-confirm-state | cut -d= -f2)"
            v2="$(grep "^cb2=" /tmp/hub-confirm-state | cut -d= -f2)"
            [[ "$v1" == "0" ]] && remove_worktree=false
            [[ "$v2" == "1" ]] && delete_branch=true
            rm -f /tmp/hub-confirm-state
        fi
    fi

    # Instant cleanup — before any slow teardown
    if [[ -f "$WORKSPACES_FILE" ]]; then
        local updated
        updated="$(jq --arg id "$ws_id" '[.[] | select(.workspace_id != $id)]' "$WORKSPACES_FILE")"
        echo "$updated" > "$WORKSPACES_FILE"
    fi

    remove_sketchybar_label "$ws_id"

    if [[ -n "$windows" ]]; then
        while IFS= read -r wid; do
            aerospace move-node-to-workspace --window-id "$wid" Z 2>/dev/null || true
        done <<< "$windows"
    fi

    aerospace workspace Z 2>/dev/null || true

    # Attempt to close the moved windows (best-effort; some apps may not close)
    if [[ -n "$windows" ]]; then
        (
            sleep 0.5
            while IFS= read -r wid; do
                aerospace close --window-id "$wid" 2>/dev/null || true
            done <<< "$windows"
        ) &
        disown
    fi

    # Background teardown piped to output_window
    if [[ "$is_worktree" == "true" && "$remove_worktree" == "true" ]]; then
        local teardown_cmd
        teardown_cmd="$(read_superset_config "$ws_root" "teardown" 2>/dev/null || echo "")"

        local bg_script
        if [[ -n "$teardown_cmd" ]]; then
            bg_script="source \"\$HOME/.zshrc\" 2>/dev/null; cd $(printf '%q' "$ws_path") && eval $(printf '%q' "$ws_root/$teardown_cmd"); git -C $(printf '%q' "$ws_root") worktree remove $(printf '%q' "$ws_path") --force 2>/dev/null; git -C $(printf '%q' "$ws_root") worktree prune 2>/dev/null"
        else
            bg_script="git -C $(printf '%q' "$ws_root") worktree remove $(printf '%q' "$ws_path") --force 2>/dev/null; git -C $(printf '%q' "$ws_root") worktree prune 2>/dev/null"
        fi
        if [[ "$delete_branch" == "true" && -n "$ws_branch" ]]; then
            bg_script+=" ; git -C $(printf '%q' "$ws_root") branch -D $(printf '%q' "$ws_branch") 2>/dev/null"
        fi

        if [[ -x "$OUTPUT_WINDOW_BIN" ]]; then
            ( set +e; /bin/zsh --no-rcs -c "$bg_script" 2>&1; echo "EXIT:$?" ) | "$OUTPUT_WINDOW_BIN" "Hub: Removing workspace $ws_name" &
            disown
        else
            ( eval "$bg_script" ) &
            disown
        fi

        (
            sleep 0.3
            local ow_wid
            ow_wid="$(aerospace list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null \
                | grep '|output_window$' | cut -d'|' -f1 | head -1 || echo "")"
            [[ -n "$ow_wid" ]] && aerospace move-node-to-workspace --window-id "$ow_wid" Z 2>/dev/null || true
        ) &
        disown
    fi

    echo
    echo -e "${green}${bold}Workspace '$ws_name' (ID: $ws_id) removed.${reset}"
}


get_workspace_path() {
    local ws_id="$1"
    if [[ -f "$WORKSPACES_FILE" ]]; then
        jq -r --arg id "$ws_id" '.[] | select(.workspace_id == $id) | .path // empty' \
            "$WORKSPACES_FILE" 2>/dev/null
    fi
}

# arrange_workspace_windows WS_ID WID1 WID2 ... WIDN
# Arranges N windows into a structured layout based on count:
#   1: single window (no-op after h_tiles)
#   2: W1 | W2  (flat h_tiles)
#   3: W1 | W2 (W2 and W3 stacked vertically in right column)
#         W3
#   4: W1  W3
#      W2  W4  (two columns of two)
#   5: W1  W3
#      W2  W4
#         W5  (left col 2, right col 3)
# After opening a new window on a workspace, re-arrange all windows to match the
# standard tiling layout (2=side-by-side, 3=right-column-split, 4=two-column-pairs).
# Called with just the workspace ID; queries AeroSpace for current window list.
arrange_after_open() {
    local ws_id="$1"
    local wids=()
    while IFS= read -r wid; do
        [[ -n "$wid" ]] && wids+=("$wid")
    done < <(aerospace list-windows --workspace "$ws_id" --format '%{window-id}' 2>/dev/null || true)
    local n=${#wids[@]}
    [[ $n -lt 2 || $n -gt 4 ]] && return 0
    arrange_workspace_windows "$ws_id" "${wids[@]}"
}

arrange_workspace_windows() {
    local ws_id="$1"; shift
    local wids=("$@")
    local n=${#wids[@]}
    [[ $n -lt 2 ]] && return 0

    # Flatten and switch to the workspace first
    aerospace flatten-workspace-tree --workspace "$ws_id" 2>/dev/null || true
    aerospace workspace "$ws_id" 2>/dev/null || true

    # After flatten, windows are in order they were added; focus each one to confirm DFS order.
    # We want them in order W1..Wn left-to-right in h_tiles as our starting point.
    # Focus W1 first, then set h_tiles.
    aerospace focus --window-id "${wids[0]}" 2>/dev/null || true
    aerospace layout h_tiles 2>/dev/null || true

    if [[ $n -eq 2 ]]; then
        : # flat h_tiles is the goal
    elif [[ $n -eq 3 ]]; then
        # After h_tiles: W1 | W2 | W3
        # Focus W3, join-with left → W3 merges with W2 under a shared parent
        aerospace focus --window-id "${wids[2]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
    elif [[ $n -eq 4 ]]; then
        # Goal: (W1/W2) | (W3/W4)
        # After h_tiles flatten: W1 W2 W3 W4 are side by side.
        # Stack W1+W2: focus W2, join-with left → W2 lands with W1
        aerospace focus --window-id "${wids[1]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
        # Stack W3+W4: focus W4, join-with left → W4 lands with W3
        aerospace focus --window-id "${wids[3]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
    elif [[ $n -eq 5 ]]; then
        # Goal: (W1/W2) | (W3/W4/W5)
        # Stack left column W1+W2
        aerospace focus --window-id "${wids[1]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
        # Stack right column W3+W4
        aerospace focus --window-id "${wids[3]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
        # Add W5 to the right column: join-with left puts it with the W3/W4 container
        aerospace focus --window-id "${wids[4]}" 2>/dev/null || true
        aerospace join-with left 2>/dev/null || true
        aerospace layout v_tiles 2>/dev/null || true
    fi

    # Return focus to first window
    aerospace focus --window-id "${wids[0]}" 2>/dev/null || true
}

open_app_slot() {
    local slot="$1"
    local ws_id="$2"
    local ws_path="$3"
    local verbose="${4:-false}"   # true = print status lines
    local force_new="${5:-false}" # true = always launch new window

    local app_info
    app_info="$(jq -r --argjson i "$((slot - 1))" \
        'if $i >= 0 and $i < length then .[$i] | [.name, .launch, (.icon // .name)] | @tsv else empty end' \
        "$APPS_FILE" 2>/dev/null)" || return 0

    [[ -z "$app_info" ]] && return 0

    local app_name launch_cmd app_icon
    IFS=$'\t' read -r app_name launch_cmd app_icon <<< "$app_info"

    # Smart mode: if app has windows on current workspace, cycle focus between
    # them. Otherwise fall through to launch a new window on this workspace.
    # (We intentionally do NOT jump to another workspace where this app runs —
    # each hub workspace is self-contained, so Chrome on ws 3 ≠ Chrome on ws 10.)
    if [[ "$force_new" != "true" ]]; then
        local cur_wins
        cur_wins="$(aerospace list-windows --workspace "$ws_id" --format '%{window-id}|%{app-name}' 2>/dev/null \
            | grep "|${app_name}$" | cut -d'|' -f1 || echo "")"
        if [[ -n "$cur_wins" ]]; then
            local focused_wid
            focused_wid="$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null || echo "")"
            local target="" first="" take_next=false
            while IFS= read -r wid; do
                [[ -z "$wid" ]] && continue
                [[ -z "$first" ]] && first="$wid"
                if [[ "$take_next" == "true" ]]; then
                    target="$wid"
                    break
                fi
                [[ "$wid" == "$focused_wid" ]] && take_next=true
            done <<< "$cur_wins"
            [[ -z "$target" ]] && target="$first"
            aerospace focus --window-id "$target" 2>/dev/null || true
            [[ "$verbose" == "true" ]] && success "$app_name focused" || true
            return 0
        fi
        # Fall through: no window on this workspace, launch one here
    fi

    [[ "$verbose" == "true" ]] && info "Opening $app_name..." || true

    # Snapshot existing window IDs for this app
    local before_ids
    before_ids="$(aerospace list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null | grep "|${app_name}$" | cut -d'|' -f1 || echo "")"

    # Substitute {path} and {workspace} in launch command
    launch_cmd="${launch_cmd//\{path\}/$ws_path}"
    launch_cmd="${launch_cmd//\{workspace\}/$ws_id}"

    # Launch the app
    bash -c "$launch_cmd" >/dev/null 2>/tmp/hub_open_err &

    # Poll for new window (up to 8 seconds)
    local new_wid=""
    for _ in $(seq 1 32); do
        sleep 0.25
        local after_ids
        after_ids="$(aerospace list-windows --all --format '%{window-id}|%{app-name}' 2>/dev/null | grep "|${app_name}$" | cut -d'|' -f1 || echo "")"

        while IFS= read -r wid; do
            [[ -z "$wid" ]] && continue
            if ! echo "$before_ids" | grep -qxF "$wid"; then
                new_wid="$wid"
                break 2
            fi
        done <<< "$after_ids"
    done

    # Move to correct workspace if needed
    if [[ -n "$new_wid" ]]; then
        local win_ws
        win_ws="$(aerospace list-windows --all --format '%{window-id}|%{workspace}' 2>/dev/null | grep "^${new_wid}|" | cut -d'|' -f2 || echo "")"
        if [[ "$win_ws" != "$ws_id" ]]; then
            aerospace move-node-to-workspace --window-id "$new_wid" "$ws_id" 2>/dev/null || true
            aerospace focus --window-id "$new_wid" 2>/dev/null || true
        fi
        [[ "$verbose" == "true" ]] && success "$app_name opened" || true
        OPEN_APP_SLOT_WID="$new_wid"
    else
        [[ "$verbose" == "true" ]] && warn "$app_name: window did not appear in time" || true
        OPEN_APP_SLOT_WID=""
    fi
}

cmd_open() {
    local slot=""
    local open_all=false
    local force_new=false

    for arg in "$@"; do
        case "$arg" in
            --all) open_all=true ;;
            --force|--new) force_new=true ;;
            [1-5]) slot="$arg" ;;
        esac
    done

    if [[ ! -f "$APPS_FILE" ]]; then
        fail "No apps.json found. Run: hub install"
        exit 1
    fi

    local ws_id
    ws_id="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
    if [[ -z "$ws_id" ]]; then
        fail "Could not determine current workspace"
        exit 1
    fi

    local ws_path
    ws_path="$(get_workspace_path "$ws_id")"
    [[ -z "$ws_path" ]] && ws_path="$HOME"

    # Load app list
    local app_names=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && app_names+=("$line")
    done < <(jq -r '.[].name' "$APPS_FILE" 2>/dev/null)

    local app_count="${#app_names[@]}"

    # If called from a keybinding (no terminal), just run silently
    if [[ ! -t 0 && ! -t 1 ]]; then
        local _opened=false
        if [[ -n "$slot" ]]; then
            OPEN_APP_SLOT_WID=""
            open_app_slot "$slot" "$ws_id" "$ws_path" false "$force_new"
            [[ -n "$OPEN_APP_SLOT_WID" ]] && _opened=true
        else
            for ((i=1; i<=app_count; i++)); do
                OPEN_APP_SLOT_WID=""
                open_app_slot "$i" "$ws_id" "$ws_path" false "$force_new"
                [[ -n "$OPEN_APP_SLOT_WID" ]] && _opened=true
            done
        fi
        if [[ "$_opened" == "true" ]]; then
            local _ws_id_copy="$ws_id"
            (sleep 0.2; arrange_after_open "$_ws_id_copy") &
            disown
        fi
        refresh_app_indicators
        return
    fi

    # Terminal: show list and prompt if no slot/--all given
    if [[ -z "$slot" && "$open_all" == "false" ]]; then
        local ws_apps
        ws_apps="$(aerospace list-windows --workspace "$ws_id" --format '%{app-name}' 2>/dev/null || echo "")"

        local verb="Open/focus"
        [[ "$force_new" == "true" ]] && verb="Launch new"
        echo -e "${bold}${verb} which app for workspace $ws_id?${reset}"
        for ((i=1; i<=app_count; i++)); do
            local name="${app_names[$((i-1))]}"
            if echo "$ws_apps" | grep -qxF "$name"; then
                echo -e "  ${green}$i${reset}  $name ${green}(open here)${reset}"
            else
                echo -e "  ${blue}$i${reset}  $name"
            fi
        done
        echo
        echo -e "  ${bold}a${reset}  Open all"
        echo -e "  ${bold}q${reset}  Quit"
        echo
        read -rp "Choice [1-${app_count}/a/q] " choice

        case "$choice" in
            [1-5]) slot="$choice" ;;
            a|A|--all) open_all=true ;;
            *) echo "Cancelled."; return ;;
        esac
    fi

    local _opened=false
    if [[ "$open_all" == "true" ]]; then
        for ((i=1; i<=app_count; i++)); do
            OPEN_APP_SLOT_WID=""
            open_app_slot "$i" "$ws_id" "$ws_path" true "$force_new"
            [[ -n "$OPEN_APP_SLOT_WID" ]] && _opened=true
        done
    else
        OPEN_APP_SLOT_WID=""
        open_app_slot "$slot" "$ws_id" "$ws_path" true "$force_new"
        [[ -n "$OPEN_APP_SLOT_WID" ]] && _opened=true
    fi

    # Only refocus original workspace after launching new windows — smart-open
    # may have intentionally jumped to another workspace.
    if [[ "$force_new" == "true" || "$open_all" == "true" ]]; then
        aerospace workspace "$ws_id" 2>/dev/null || true
    fi

    if [[ "$_opened" == "true" ]]; then
        local _ws_id_copy="$ws_id"
        (sleep 0.2; arrange_after_open "$_ws_id_copy") &
        disown
    fi
    refresh_app_indicators
}

refresh_app_indicators() {
    local plugin="$HOME/.config/sketchybar/plugins/app_launcher.sh"
    [[ -x "$plugin" ]] && "$plugin" >/dev/null 2>&1
}

KEYS_CACHE="$HOME/.config/hub/keys_cache"

build_keys_output() {
    local cyan='\033[36m'
    local dim='\033[2m'

    for mode in main service; do
        local keys
        keys="$(aerospace config --get "mode.${mode}.binding" --keys 2>/dev/null)" || continue
        [[ -z "$keys" ]] && continue

        echo -e "${bold}${blue}${mode} mode${reset}"
        if [[ "$mode" == "service" ]]; then
            echo -e "  ${dim}activated by ${bold}alt-shift-semicolon${reset}"
        fi
        echo -e "${dim}$(printf '%.0s─' {1..40})${reset}"

        while IFS= read -r key; do
            [[ -z "$key" ]] && continue
            local cmd
            cmd="$(aerospace config --get "mode.${mode}.binding.${key}" 2>/dev/null)" || continue
            cmd="${cmd#exec-and-forget  }"
            cmd="${cmd//$REPO_DIR\/scripts\/hub/hub}"
            printf "  ${cyan}${bold}%-28s${reset}  %s\n" "$key" "$cmd"
        done <<< "$keys"
        echo
    done
}

cache_keys() {
    mkdir -p "$(dirname "$KEYS_CACHE")"
    build_keys_output > "$KEYS_CACHE"
}

cmd_dashboard() {
    if [[ ! -x "$DASHBOARD_BIN" ]]; then
        fail "dashboard_dialog not compiled. Run: hub install"
        exit 1
    fi

    local status_tmp keys_tmp
    status_tmp="$(mktemp /tmp/hub-dashboard-status.XXXXXX)"
    keys_tmp="$(mktemp /tmp/hub-dashboard-keys.XXXXXX)"
    rm -f "${status_tmp}.done" "${keys_tmp}.done"

    # Populate files in background; write .done sentinels when each is ready
    ( cmd_status --compact > "$status_tmp" && touch "${status_tmp}.done" ) &
    ( cmd_keys > "$keys_tmp" && touch "${keys_tmp}.done" ) &

    # Launch dialog immediately — it polls for the .done sentinels
    "$DASHBOARD_BIN" "$status_tmp" "$keys_tmp"

    rm -f "$status_tmp" "${status_tmp}.done" "$keys_tmp" "${keys_tmp}.done"
}

cmd_keys() {
    if [[ -f "$KEYS_CACHE" ]]; then
        cat "$KEYS_CACHE"
    else
        build_keys_output | tee "$KEYS_CACHE"
    fi
}

cmd_repo_prefix() {
    local action="${1:-toggle}"
    local prefix_file="/tmp/hub_repo_prefix"
    local current="off"
    [[ -f "$prefix_file" ]] && current="$(cat "$prefix_file" 2>/dev/null || echo off)"
    [[ "$current" != "on" ]] && current="off"

    case "$action" in
        on)  current="on" ;;
        off) current="off" ;;
        toggle) [[ "$current" == "on" ]] && current="off" || current="on" ;;
        "")
            echo -e "${bold}Repo prefix:${reset} $current"
            echo -e "  ${yellow}Usage: hub repo-prefix [on|off|toggle]${reset}"
            return 0
            ;;
        *) fail "Usage: hub repo-prefix [on|off|toggle]"; return 1 ;;
    esac

    echo "$current" > "$prefix_file"
    rebuild_labels_file
    local plugin="$HOME/.config/sketchybar/plugins/aerospace.sh"
    [[ -x "$plugin" ]] && "$plugin" >/dev/null 2>&1
}

cmd_label_length() {
    local direction="${1:-}"
    local maxlen_file="/tmp/hub_label_maxlen"
    # -1 = unlimited, 0 = code only, N>0 = max N chars of name
    local current=-1
    [[ -f "$maxlen_file" ]] && current=$(cat "$maxlen_file" 2>/dev/null || echo -1)

    # Find longest label to cap the max
    local longest=0
    local labels_file="/tmp/hub_sketchybar_labels"
    if [[ -f "$labels_file" ]]; then
        while IFS=: read -r _ name _; do
            (( ${#name} > longest )) && longest=${#name}
        done < "$labels_file"
    fi

    case "$direction" in
        +|up|grow)
            if [[ "$current" -lt 0 ]]; then
                current=-1  # already unlimited, stay unlimited
            else
                current=$(( current + 2 ))
            fi
            ;;
        -|down|shrink)
            if [[ "$current" -lt 0 ]]; then
                # First shrink from unlimited: start at longest - 2
                if [[ "$longest" -gt 0 ]]; then
                    current=$(( longest - 2 ))
                    (( current < 0 )) && current=0
                fi
            else
                current=$(( current - 2 ))
                (( current < 0 )) && current=0
            fi
            ;;
        "")
            # No argument: display current label length
            echo -e "${bold}Label length:${reset}"
            if [[ "$current" -lt 0 ]]; then
                echo -e "  unlimited  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
            elif [[ "$current" -eq 0 ]]; then
                echo -e "  workspace number only  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
            else
                echo -e "  $current chars  ${yellow}(adjust with ctrl-alt-${green}-${yellow} and ctrl-alt-${green}+${yellow})${reset}"
            fi
            echo -e "  ${yellow}Usage: hub label-length [+|-|grow|shrink|<number>]${reset}"
            return 0
            ;;
        *)
            if [[ "$direction" =~ ^[0-9]+$ ]]; then
                current="$direction"
            else
                fail "Usage: hub label-length [+|-|grow|shrink|<number>]"
                return 1
            fi
            ;;
    esac

    # Clamp: -1 = unlimited, 0 = code only, positive = capped at longest
    if [[ "$current" -gt 0 ]]; then
        if [[ "$longest" -gt 0 ]] && (( current >= longest )); then
            current=-1
        fi
    fi
    echo "$current" > "$maxlen_file"

    local plugin="$HOME/.config/sketchybar/plugins/aerospace.sh"
    [[ -x "$plugin" ]] && "$plugin" >/dev/null 2>&1
}

ensure_general_workspace() {
    mkdir -p "$(dirname "$WORKSPACES_FILE")"
    local existing="[]"
    [[ -f "$WORKSPACES_FILE" ]] && existing="$(cat "$WORKSPACES_FILE")"
    local already
    already="$(echo "$existing" | jq -r '.[] | select(.workspace_id == "Z") | .workspace_id' 2>/dev/null || echo "")"
    if [[ -z "$already" ]]; then
        local updated
        updated="$(echo "$existing" | jq '. + [{name: "General", path: $ENV.HOME, root_repo: "", workspace_id: "Z"}]')"
        echo "$updated" > "$WORKSPACES_FILE"
        update_sketchybar_label "Z" "General"
        success "Created General workspace (Z)"
    fi
}

cmd_up() {
    echo -e "${bold}Starting hub environment...${reset}\n"

    # Show overlay while configuring system settings
    start_overlay "Configuring System Settings"
    update_overlay "Hiding dock and menu bar…\\nSystem Settings will open briefly."

    # Hide menu bar (non-blocking — runs in background)
    toggle_menu_bar true
    info "Setting menu bar auto-hide to ON (System Settings will open briefly)..."

    # Set HubHTTPHandler as default browser, saving previous for restore
    if [[ -x "$BROWSER_CTL_BIN" ]]; then
        local prev_browser
        prev_browser="$("$BROWSER_CTL_BIN" get 2>/dev/null || true)"
        if [[ -n "$prev_browser" && "$prev_browser" != "$HUB_BROWSER_ID" ]]; then
            echo "$prev_browser" > "$PREV_BROWSER_FILE"
        fi
        "$BROWSER_CTL_BIN" set "$HUB_BROWSER_ID" 2>/dev/null || true
        success "Default browser set to HubHTTPHandler"
    else
        warn "browser_ctl not found — skipping default browser change"
    fi

    # Launch HubHTTPHandler as persistent daemon
    if ! pgrep -qf "HubHTTPHandler.app/Contents/MacOS/HubHTTPHandler"; then
        open -a "$HTTP_HANDLER_APP" &>/dev/null &
        disown
        success "HubHTTPHandler started"
    else
        success "HubHTTPHandler already running"
    fi

    # Hide the Dock
    defaults write com.apple.dock autohide -bool true
    defaults write com.apple.dock autohide-delay -float 1000
    defaults write com.apple.dock autohide-time-modifier -float 0
    killall Dock
    success "Dock hidden"

    # Start or re-enable AeroSpace
    if pgrep -q AeroSpace; then
        aerospace enable on
        aerospace reload-config
        success "AeroSpace enabled and config reloaded"
    else
        open -a AeroSpace
        success "AeroSpace started"
    fi

    # Ensure sketchybar is running and reload config
    if ! pgrep -q sketchybar; then
        sketchybar &>/dev/null &
        disown
        success "SketchyBar started"
    else
        sketchybar --reload 2>/dev/null
        success "SketchyBar reloaded"
    fi

    if ! pgrep -q borders; then
        borders active_color=0xff00ff00 width=10.0 style=round &>/dev/null &
        disown
        success "JankyBorders started"
    else
        success "JankyBorders already running"
    fi

    # Wait for menu bar AppleScript to finish
    wait_for_menu_bar
    success "Menu bar hidden"

    update_overlay "✓  Done"
    sleep 0.8
    stop_overlay

    echo
    ensure_general_workspace
    cache_keys &
    disown

    echo -e "${green}${bold}hub is up!${reset}"
    echo
    echo -e "  Tip: use ${bold}Ctrl+Alt+O${reset} to open configured apps, or ${bold}hub open${reset} from the CLI."
    echo -e "  Edit ${bold}~/.config/hub/apps.json${reset} to customize your app slots."
}

cmd_reboot() {
    cmd_down
    echo
    cmd_install
    echo
    cmd_up
}

cmd_down() {
    echo -e "${bold}Shutting down hub environment...${reset}\n"

    # Stop borders
    if pgrep -q borders; then
        killall borders 2>/dev/null || true
        success "JankyBorders stopped"
    else
        warn "JankyBorders was not running"
    fi

    # Stop sketchybar
    if pgrep -q sketchybar; then
        killall sketchybar 2>/dev/null || true
        success "SketchyBar stopped"
    else
        warn "SketchyBar was not running"
    fi

    # Stop AeroSpace
    if pgrep -q AeroSpace; then
        aerospace enable off
        success "AeroSpace disabled"
    else
        warn "AeroSpace was not running"
    fi

    # Stop HubHTTPHandler daemon
    if pgrep -qf "HubHTTPHandler.app/Contents/MacOS/HubHTTPHandler"; then
        pkill -f "HubHTTPHandler.app/Contents/MacOS/HubHTTPHandler" 2>/dev/null || true
        success "HubHTTPHandler stopped"
    else
        warn "HubHTTPHandler was not running"
    fi

    # Restore previous default browser
    if [[ -x "$BROWSER_CTL_BIN" ]] && [[ -f "$PREV_BROWSER_FILE" ]]; then
        local prev_browser
        prev_browser="$(cat "$PREV_BROWSER_FILE")"
        if [[ -n "$prev_browser" ]]; then
            "$BROWSER_CTL_BIN" set "$prev_browser" 2>/dev/null || true
            rm -f "$PREV_BROWSER_FILE"
            success "Default browser restored to $prev_browser"
        fi
    else
        warn "No saved browser to restore"
    fi

    # Show overlay while restoring system settings
    start_overlay "Restoring System Settings"
    update_overlay "Unhiding dock and menu bar…\\nSystem Settings will open briefly."

    # Unhide menu bar (non-blocking)
    toggle_menu_bar false
    info "Setting menu bar auto-hide to OFF (System Settings will open briefly)..."

    # Restore the Dock
    defaults write com.apple.dock autohide -bool false
    defaults delete com.apple.dock autohide-delay 2>/dev/null || true
    defaults delete com.apple.dock autohide-time-modifier 2>/dev/null || true
    killall Dock
    success "Dock restored"

    # Wait for menu bar AppleScript to finish
    wait_for_menu_bar
    success "Menu bar restored"

    update_overlay "✓  Done"
    sleep 0.8
    stop_overlay

    echo
    echo -e "${green}${bold}hub shut down complete.${reset}"
}

# --- Main ---
command="${1:-}"

shift || true
case "$command" in
    install)  cmd_install ;;
    new)      cmd_new ;;
    list)     cmd_list "$@" ;;
    tree)     cmd_tree "$@" ;;
    status)   cmd_status ;;
    remove)   cmd_remove "$@" ;;
    rename)   cmd_rename "$@" ;;
    next)     cmd_next ;;
    prev)     cmd_prev ;;
    open)     cmd_open "$@" ;;
    up)       cmd_up ;;
    down)     cmd_down ;;
    reboot)   cmd_reboot ;;
    keys)         cmd_keys ;;
    dashboard)    cmd_dashboard ;;
    label-length) cmd_label_length "$@" ;;
    repo-prefix)  cmd_repo_prefix "$@" ;;
    arrange-open-window) arrange_after_open "${1:-}" ;;
    help|-h|--help) print_usage ;;
    '')
        print_usage
        ;;
    *)
        ext="hub-$command"
        if command -v "$ext" &>/dev/null; then
            exec "$ext" "$@"
        fi
        fail "Unknown command: $command"
        echo
        print_usage
        exit 1
        ;;
esac
