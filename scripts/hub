#!/usr/bin/env bash
set -euo pipefail
# bash 5.3 enables patsub_replacement by default, making & in ${var//pat/repl}
# act as a sed-style backreference. This breaks URL substitution (& in query
# strings gets replaced by the pattern text). Disable it globally.
shopt -u patsub_replacement 2>/dev/null || true

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB_DIR="$REPO_DIR/lib"
CONFIG_DIR="$REPO_DIR/config"

: "${HUB_HOME:=$HOME}"
: "${HUB_CONFIG_DIR:=$HUB_HOME/.config/hub}"
: "${HUB_RUNTIME_DIR:=${TMPDIR:-/tmp}/hub-${USER:-user}}"
: "${HUB_APPLICATIONS_DIR:=$HUB_HOME/Applications}"
mkdir -p "$HUB_RUNTIME_DIR" 2>/dev/null || true

: "${AEROSPACE_CONFIG:=$HUB_HOME/.aerospace.toml}"
HUB_BAR_SRC="$LIB_DIR/hub_bar.swift"
: "${HUB_BAR_BIN:=$HUB_CONFIG_DIR/hub_bar}"
: "${HUB_BAR_PIDFILE:=$HUB_CONFIG_DIR/hub_bar.pid}"
HUB_BAR_LAUNCH_LABEL="sh.hub.hub_bar"
DIALOG_SRC="$LIB_DIR/new_workspace_dialog.swift"
: "${DIALOG_BIN:=$HUB_CONFIG_DIR/new_workspace_dialog}"
CONFIRM_SRC="$LIB_DIR/confirm_dialog.swift"
: "${CONFIRM_BIN:=$HUB_CONFIG_DIR/confirm_dialog}"
RENAME_SRC="$LIB_DIR/rename_dialog.swift"
: "${RENAME_BIN:=$HUB_CONFIG_DIR/rename_dialog}"
DASHBOARD_SRC="$LIB_DIR/dashboard_dialog.swift"
: "${DASHBOARD_BIN:=$HUB_CONFIG_DIR/dashboard_dialog}"
OUTPUT_WINDOW_SRC="$LIB_DIR/output_window.swift"
: "${OUTPUT_WINDOW_BIN:=$HUB_CONFIG_DIR/output_window}"
HTTP_HANDLER_SRC="$LIB_DIR/http_handler.swift"
: "${HTTP_HANDLER_LEGACY_APP:=$HUB_APPLICATIONS_DIR/HubHTTPHandler.app}"
HTTP_HANDLER_EXECUTABLE="HubHTTPHandler"
HUB_APP_SRC="$LIB_DIR/hub_toggle_app.swift"
: "${HUB_APP_PATH:=$HUB_APPLICATIONS_DIR/Hub.app}"
HUB_APP_EXECUTABLE="Hub"
HUB_APP_ICON_SRC="$REPO_DIR/assets/hub-logo.png"
HUB_APP_BUNDLE_ID="sh.hub.app"
BROWSER_CTL_SRC="$LIB_DIR/browser_ctl.swift"
: "${BROWSER_CTL_BIN:=$HUB_CONFIG_DIR/browser_ctl}"
SPATIAL_ORDER_SRC="$LIB_DIR/spatial_order.swift"
: "${SPATIAL_ORDER_BIN:=$HUB_CONFIG_DIR/spatial_order}"
FLOAT_NUDGE_SRC="$LIB_DIR/float_nudge.swift"
: "${FLOAT_NUDGE_BIN:=$HUB_CONFIG_DIR/float_nudge}"
THEME_SRC="$LIB_DIR/theme.swift"
: "${TESTING_BANNER_PIDFILE:=$HUB_CONFIG_DIR/testing_banner.pid}"
PROGRESS_BANNER_SRC="$LIB_DIR/progress_banner.swift"
: "${PROGRESS_BANNER_BIN:=$HUB_CONFIG_DIR/progress_banner}"
: "${PROGRESS_BANNER_PIDFILE:=$HUB_CONFIG_DIR/progress_banner.pid}"
APP_SWITCHER_SRC="$LIB_DIR/app_switcher.swift"
: "${APP_SWITCHER_BIN:=$HUB_CONFIG_DIR/app_switcher}"
: "${APP_SWITCHER_LOCK_DIR:=$HUB_CONFIG_DIR/.app-switcher-lock}"
: "${APP_SWITCHER_RESULT:=$HUB_RUNTIME_DIR/app-switcher-result}"
: "${PREV_BROWSER_FILE:=$HUB_CONFIG_DIR/prev_browser}"
HUB_BROWSER_ID="sh.hub.http-handler"
: "${WORKSPACES_FILE:=$HUB_CONFIG_DIR/workspaces.json}"
: "${RECENT_REPOS_FILE:=$HUB_CONFIG_DIR/recent_repos.json}"
: "${APPS_FILE:=$HUB_CONFIG_DIR/apps.json}"
: "${ACTIONS_FILE:=$HUB_CONFIG_DIR/actions.json}"
: "${HUB_CONFIG_FILE:=$HUB_CONFIG_DIR/config.json}"
: "${ICONS_DIR:=$HUB_CONFIG_DIR/icons}"
APP_PRESETS_SRC="$CONFIG_DIR/app_presets.json"
: "${APP_PRESETS_FILE:=$HUB_CONFIG_DIR/app_presets.json}"
ACTION_PRESETS_SRC="$CONFIG_DIR/action_presets.json"
: "${ACTION_PRESETS_FILE:=$HUB_CONFIG_DIR/action_presets.json}"
APPLESCRIPT="$LIB_DIR/hide_menu_bar.applescript"
LOG_VIEWER_SRC="$LIB_DIR/log_viewer.swift"
: "${LOG_VIEWER_BIN:=$HUB_CONFIG_DIR/log_viewer}"
: "${HUB_LOG_FILE:=$HUB_CONFIG_DIR/hub.log}"
: "${FULLSCREEN_STATE_FILE:=$HUB_CONFIG_DIR/fullscreen}"
: "${KEYS_CACHE:=$HUB_CONFIG_DIR/keys_cache}"
: "${HUB_NEW_WORKSPACE_RESULT:=$HUB_RUNTIME_DIR/new-workspace}"
: "${HUB_RENAME_RESULT:=$HUB_RUNTIME_DIR/rename}"
: "${HUB_CONFIRM_STATE:=$HUB_RUNTIME_DIR/confirm-state}"
: "${HUB_OPEN_ERR:=$HUB_RUNTIME_DIR/open-err}"
: "${HUB_OVERLAY_PIDFILE:=$HUB_CONFIG_DIR/overlay.pid}"
export HUB_HOME HUB_CONFIG_DIR HUB_RUNTIME_DIR HUB_APPLICATIONS_DIR
export HUB_NEW_WORKSPACE_RESULT HUB_RENAME_RESULT HUB_CONFIRM_STATE APP_SWITCHER_RESULT
export APPS_FILE ACTIONS_FILE ACTION_PRESETS_FILE ICONS_DIR

# Hub Bar heights (px) — MUST match barHeightNormal/barHeightTall in lib/hub_bar.swift.
HUB_BAR_HEIGHT_NORMAL=40
HUB_BAR_HEIGHT_TALL=80
HUB_BAR_GAP=15  # px between bar bottom and first tiled window

# Ensure standard binary paths are available — AeroSpace's exec-and-forget
# inherits a minimal environment that omits /usr/local/bin and /opt/homebrew/bin.
# Append only; any caller-prepended paths (e.g. test stubs) must stay first.
for _hub_p in /usr/local/bin /opt/homebrew/sbin /opt/homebrew/bin; do
    [[ ":$PATH:" != *":$_hub_p:"* ]] && PATH="$PATH:$_hub_p"
done
export PATH
unset _hub_p

# Colors
bold='\033[1m'
green='\033[32m'
yellow='\033[33m'
red='\033[31m'
blue='\033[34m'
reset='\033[0m'

print_usage() {
    echo -e "${bold}Usage:${reset} hub <command>"
    echo
    echo -e "${bold}Commands:${reset}"
    echo "  install       Install Hub alias, check dependencies, compile binaries, and deploy configs"
    echo "  up            Start AeroSpace, Hub Bar, JankyBorders (restores fullscreen state if active)"
    echo "  down          Stop everything, restore the Dock and menu bar (preserves fullscreen state)"
    echo "  toggle        Run 'up' if hub is down, or 'down' if hub is up (used by the Dock icon)"
    echo "  reboot        Stop, reinstall, and restart the Hub environment"
    echo "  new           Create a new workspace (opens dialog; pass flags to run silently)"
    echo "  list          List all defined workspaces
  tree          Show the tiling tree for a workspace"
    echo "  status        Show current service state, workspace info, and label length"
    echo "  remove        Remove a workspace (current or by ID)"
    echo "  rename        Rename a workspace (current or by ID)"
    echo "  apps          Manage configured app launcher slots (list/add/edit/remove/reset)"
    echo "  actions       Manage custom actions shown in the Hub Bar overlay"
  echo "  open          Open configured apps in current workspace"
    echo "  app-switcher  Cmd-Tab-style cycle over launch-bar apps (Alt-N; hold Alt, tap N)"
    echo "  keys          List all AeroSpace key bindings (main and service mode)"
    echo "  dashboard     Show status and key bindings in a full-screen modal"
    echo "  bar-layout    Pills shrink to fit one row, or expand bar height (shrink/expand/toggle)"
    echo "  bar-reload    Restart the Hub Bar (fix rendering inconsistencies)"
    echo "  fullscreen    Hide/show the Dock and menu bar (on/off/toggle)"
    echo "  repo-prefix   Show or hide the repo name prefix on workspace labels (on/off/toggle)"
    echo "  config        Get/set Hub options (e.g. claude_binary)"
    echo "  log           Show the Hub action log (path + open in less; --window opens GUI viewer)"
    echo "  testing-banner Show a 'stand by' HUD while an automated session tests Hub (start/stop/run)"
    echo "  claude-hooks  Manage Claude Code notification hooks (install/uninstall/status)"
    echo "  help          Show this help"
    echo
    echo -e "${bold}Examples:${reset}"
    echo "  hub install        # install shell alias and dependencies"
    echo "  hub up             # start the workspace environment"
    echo "  hub down           # tear down the workspace environment"
    echo "  hub new            # open the workspace creation dialog"
    echo "  hub new --path .   # create a workspace at CWD (no worktree)"
    echo "  hub new --worktree my-fix          # new worktree off CWD repo"
    echo "  hub new --no-repo --name scratch   # no-repo workspace"
    echo "  hub new --worktree my-fix --prompt 'fix the login redirect bug'"
    echo "  hub config                         # list all config"
    echo "  hub config set claude_binary 'claude --dangerously-skip-permissions'"
    echo "  hub list           # list all workspaces"
    echo "  hub list -v        # list with paths and root repos"
    echo "  hub remove         # remove the current workspace"
    echo "  hub remove A       # remove workspace A"
    echo "  hub remove A -y    # remove workspace A without confirmation"
    echo "  hub rename         # rename the current workspace"
    echo "  hub rename A       # rename workspace A"
    echo "  hub open           # interactive: focus or launch an app"
    echo "  hub open 1         # focus app 1 (or launch if not running)"
    echo "  hub open 1 --force # always launch a new window of app 1"
    echo "  hub open --all     # launch any missing apps into current workspace"
    echo "  hub tree           # show tiling tree for the focused workspace"
    echo "  hub tree --all     # show tiling tree for all non-empty workspaces"
    echo "  hub tree --workspace A  # show tiling tree for workspace A"
    echo
    echo -e "${bold}App launcher config:${reset}"
    echo "  Use 'hub apps' to manage up to 5 slots. Slot 1 = terminal, slot 2 = browser."
    echo "  Presets auto-wire prompt_launch (for 'hub new --prompt') and url_launch (for URL handling)."
    echo "  Placeholders: {path} = workspace folder, {workspace} = workspace ID."
    echo "  Use 'hub actions' to manage text-slug actions in the Hub Bar overlay."
}

success() { echo -e "  ${green}✓${reset} $1"; }
warn()    { echo -e "  ${yellow}!${reset} $1"; }
fail()    { echo -e "  ${red}✗${reset} $1"; }
info()    { echo -e "  ${blue}→${reset} $1"; }

# hub_log KIND MESSAGE — append a timestamped ANSI-colored entry to the action log.
# KIND: INPUT | CMD | OUT | ERR
hub_log() {
    local kind="$1" msg="$2"
    local ts
    ts="$(date '+%Y-%m-%d %H:%M:%S')"
    mkdir -p "$(dirname "$HUB_LOG_FILE")"
    # Dim timestamp, color by kind: green=INPUT, cyan=CMD, white=OUT, red=ERR
    local kind_color reset_c=$'\033[0m' dim=$'\033[2m'
    case "$kind" in
        INPUT) kind_color=$'\033[32m' ;;  # green
        CMD)   kind_color=$'\033[36m' ;;  # cyan
        OUT)   kind_color=$'\033[37m' ;;  # white
        ERR)   kind_color=$'\033[31m' ;;  # red
        *)     kind_color=$'\033[37m' ;;
    esac
    printf "${dim}[%s]${reset_c} ${kind_color}%s:${reset_c} %s\n" \
        "$ts" "$kind" "$msg" >> "$HUB_LOG_FILE"
}

read_superset_config() {
    local repo_root="$1" key="$2"
    local cfg="$repo_root/.superset/config.json"
    [[ -f "$cfg" ]] || return 1
    jq -r --arg k "$key" '.[$k][0] // empty' "$cfg" 2>/dev/null
}

# --- Workspaces-file lock (mkdir is atomic on POSIX; no flock on macOS) ---

: "${HUB_LOCK_DIR:=$HUB_CONFIG_DIR/.lock}"
: "${HUB_CONFIG_LOCK_DIR:=$HUB_CONFIG_DIR/.config-lock}"

_hub_lock_acquire() {
    local lockdir="${1:-$HUB_LOCK_DIR}"
    local deadline=$(( SECONDS + 5 ))
    while ! mkdir "$lockdir" 2>/dev/null; do
        (( SECONDS >= deadline )) && { fail "Timed out waiting for Hub lock"; return 1; }
        sleep 0.05
    done
}

_hub_lock_release() {
    rmdir "${1:-$HUB_LOCK_DIR}" 2>/dev/null || true
}

# --- Overlay helpers ---

OVERLAY_PID=""
# ─── Shared HUD helpers ───────────────────────────────────────────────────────
# All progress/testing/install overlays run the same binary (progress_banner)
# and use the same FIFO + sleep-holder + pid-file idiom.
#
# _hud_start <pidfile> [extra_args...] <title>
#   Launch progress_banner with the given extra flags and initial title.
#   Writes "banner_pid\nholder_pid\nfifo" to <pidfile>.
#
# _hud_send <pidfile> <line>
#   Write one protocol line to a running HUD. No-op if banner is gone.
#
# _hud_stop <pidfile>
#   Send QUIT, tear down the FIFO, kill processes.

_hud_start() {
    local pidfile="$1"; shift
    [[ ! -x "$PROGRESS_BANNER_BIN" ]] && return 0
    # Kill any stale instance stored in this pidfile.
    _hud_stop "$pidfile" 2>/dev/null || true
    local fifo
    fifo="$(mktemp -u "${TMPDIR:-/tmp}/hub-hud.XXXXXX")"
    mkfifo "$fifo"
    # Keep the write-end open with a long-lived sleep so the banner doesn't see EOF prematurely.
    (sleep 86400 > "$fifo") &
    local holder_pid=$!
    "$PROGRESS_BANNER_BIN" "$@" < "$fifo" >/dev/null 2>&1 &
    local banner_pid=$!
    disown "$banner_pid" "$holder_pid" 2>/dev/null || true
    mkdir -p "$(dirname "$pidfile")"
    printf "%s\n%s\n%s\n" "$banner_pid" "$holder_pid" "$fifo" > "$pidfile"
}

_hud_send() {
    local pidfile="$1" msg="$2"
    [[ ! -f "$pidfile" ]] && return 0
    local banner_pid holder_pid fifo
    { read -r banner_pid; read -r holder_pid; read -r fifo; } < "$pidfile"
    # If the user dismissed via ✕, the process is gone — clean up and skip.
    if ! kill -0 "$banner_pid" 2>/dev/null; then
        [[ -n "$holder_pid" ]] && kill "$holder_pid" 2>/dev/null || true
        [[ -n "$fifo" ]] && rm -f "$fifo"
        rm -f "$pidfile"
        return 0
    fi
    [[ -n "$fifo" && -p "$fifo" ]] && (printf "%s\n" "$msg" > "$fifo") & disown 2>/dev/null || true
}

_hud_stop() {
    local pidfile="$1"
    [[ -f "$pidfile" ]] || return 0
    local banner_pid holder_pid fifo
    { read -r banner_pid; read -r holder_pid; read -r fifo; } < "$pidfile"
    rm -f "$pidfile"
    # Send QUIT while holder is still alive (keeps the fifo readable for writing).
    if [[ -n "$fifo" && -p "$fifo" ]]; then
        printf "QUIT\n" > "$fifo" &
        local write_pid=$!
        sleep 0.05
        kill "$write_pid" 2>/dev/null || true
    fi
    [[ -n "$holder_pid" ]] && kill "$holder_pid" 2>/dev/null || true
    # Allow ~0.15 s for the fade-out animation, then kill as fallback.
    sleep 0.2
    [[ -n "$banner_pid" ]] && kill "$banner_pid" 2>/dev/null || true
    [[ -n "$fifo" ]] && rm -f "$fifo"
}

# ─── Progress banner: user-facing HUD for workspace/app operations ────────────
# progress_start "<Title>"      — launch the hierarchical HUD
# progress_step  "<label>"      — complete previous step (✔), start a new one
# progress_error "<msg>"        — show error state (auto-dismisses after 2.5 s)
# progress_stop                 — complete final step, dismiss

progress_start() {
    local title="${1:-Setting up workspace…}"
    _hud_start "$PROGRESS_BANNER_PIDFILE" "$title"
    # Ensure the banner is always dismissed even on unexpected early exit.
    # (Callers that set their own EXIT trap must call progress_stop there too.)
}

progress_step() {
    _hud_send "$PROGRESS_BANNER_PIDFILE" "STEP	$1"
}

progress_error() {
    local msg="${1:-Failed}"
    [[ ! -f "$PROGRESS_BANNER_PIDFILE" ]] && return 0
    local banner_pid holder_pid fifo
    { read -r banner_pid; read -r holder_pid; read -r fifo; } < "$PROGRESS_BANNER_PIDFILE"
    if ! kill -0 "$banner_pid" 2>/dev/null; then
        rm -f "$PROGRESS_BANNER_PIDFILE"
        return 0
    fi
    [[ -n "$fifo" && -p "$fifo" ]] && (printf "ERROR:%s\n" "$msg" > "$fifo") & disown 2>/dev/null || true
    sleep 2.6
    [[ -n "$holder_pid" ]] && kill "$holder_pid" 2>/dev/null || true
    [[ -n "$fifo" ]] && rm -f "$fifo"
    rm -f "$PROGRESS_BANNER_PIDFILE"
}

progress_stop() {
    _hud_stop "$PROGRESS_BANNER_PIDFILE"
}

# ─── Install/uninstall modal overlay (replaces lib/overlay.swift) ─────────────
# start_overlay <title>   — launch the modal (full-screen backdrop) HUD
# update_overlay <text>   — add a STEP row (auto-completes previous)
# stop_overlay            — dismiss

start_overlay() {
    local title="${1:-hub}"
    _hud_start "$HUB_OVERLAY_PIDFILE" --modal "$title"
    OVERLAY_PID=""   # kept for compat; not used by the new helpers
    OVERLAY_FIFO=""
}

update_overlay() {
    _hud_send "$HUB_OVERLAY_PIDFILE" "STEP	$1"
}

stop_overlay() {
    _hud_stop "$HUB_OVERLAY_PIDFILE"
    OVERLAY_PID=""
    OVERLAY_FIFO=""
}

# ─── Testing banner (small orange top-right "stand by" HUD for automated sessions) ───
cmd_testing_banner() {
    local sub="${1:-}"
    shift || true

    case "$sub" in
        start)
            local msg="${1:-Claude Code is testing hub — stand by}"
            if [[ ! -x "$PROGRESS_BANNER_BIN" ]]; then
                fail "progress_banner not compiled. Run: hub install"
                return 1
            fi
            cmd_testing_banner stop >/dev/null 2>&1 || true
            _hud_start "$TESTING_BANNER_PIDFILE" --accent orange --prefix "[🤖] " "$msg"
            ;;
        stop)
            _hud_stop "$TESTING_BANNER_PIDFILE"
            ;;
        run)
            cmd_testing_banner start "Claude Code is testing hub — stand by"
            local rc=0
            "$@" || rc=$?
            cmd_testing_banner stop
            return $rc
            ;;
        ""|help|--help|-h)
            echo "Usage:"
            echo "  hub testing-banner start [\"message\"]   Show the banner"
            echo "  hub testing-banner stop                   Hide the banner"
            echo "  hub testing-banner run <cmd> [args…]     Show banner, run cmd, then hide"
            ;;
        *)
            fail "Unknown testing-banner subcommand: $sub"
            return 1
            ;;
    esac
}

# (progress_banner_* retained as thin aliases for backward-compatibility with any
#  external callers; real implementation is in progress_start/step/error/stop above.)
progress_banner_start()  { progress_start  "${1:-Setting up workspace…}"; }
progress_banner_update() { progress_step   "$1"; }
progress_banner_error()  { progress_error  "${1:-Failed}"; }
progress_banner_stop()   { progress_stop; }

# --- App switcher: Cmd-Tab-style cycle over the mini launch bar apps ---
# First Alt-N press launches the Swift modal and blocks until the user releases
# Option (commit) or presses Esc (cancel). Subsequent Alt-N presses while the
# modal is up just signal it (SIGUSR1) to advance the highlight, then return.
# The atomic mkdir lock both prevents a second modal and stores the modal's pid.
cmd_app_switcher() {
    [[ -x "$APP_SWITCHER_BIN" ]] || return 0
    [[ -f "$APPS_FILE" ]] || return 0
    # No apps configured → nothing to switch between.
    local app_count
    app_count="$(jq 'length' "$APPS_FILE" 2>/dev/null || echo 0)"
    [[ "$app_count" -gt 0 ]] || return 0

    # Try to become the owner. If mkdir fails, a modal is already running.
    if ! mkdir "$APP_SWITCHER_LOCK_DIR" 2>/dev/null; then
        # Advance the existing modal. The pid file may not exist yet during a
        # cold-start race, so retry briefly before giving up.
        local pid="" tries=0
        while [[ -z "$pid" && $tries -lt 20 ]]; do
            pid="$(cat "$APP_SWITCHER_LOCK_DIR/pid" 2>/dev/null || true)"
            [[ -n "$pid" ]] && break
            sleep 0.02
            tries=$((tries + 1))
        done
        [[ -n "$pid" ]] && kill -USR1 "$pid" 2>/dev/null || true
        return 0
    fi

    # Capture the target workspace before the Cocoa switcher activates its
    # overlay window. Waiting until commit can pick up AeroSpace's previous or
    # fallback workspace when the gesture started from an empty workspace.
    local launch_ws_id
    launch_ws_id="$(aerospace list-workspaces --focused 2>/dev/null || echo "")"
    [[ -n "$launch_ws_id" ]] || { rmdir "$APP_SWITCHER_LOCK_DIR" 2>/dev/null || true; return 0; }

    # We own the lock — run the modal to completion.
    rm -f "$APP_SWITCHER_RESULT"
    "$APP_SWITCHER_BIN" &
    local sw_pid=$!
    echo "$sw_pid" > "$APP_SWITCHER_LOCK_DIR/pid"
    wait "$sw_pid" 2>/dev/null || true

    # Launch whatever was selected (force a new window, like Cmd-F1..F5).
    local slot=""
    [[ -f "$APP_SWITCHER_RESULT" ]] && slot="$(cat "$APP_SWITCHER_RESULT" 2>/dev/null || true)"

    rm -rf "$APP_SWITCHER_LOCK_DIR"
    rm -f "$APP_SWITCHER_RESULT"

    if [[ -n "$slot" ]]; then
        cmd_open "$slot" --force --workspace "$launch_ws_id"
    fi
}

# --- Menu bar toggle (AppleScript, non-blocking) ---

MENU_BAR_PID=""

toggle_menu_bar() {
    local hidden="$1"
    open "x-apple.systempreferences:com.apple.ControlCenter-Settings.extension?MenuBar" &>/dev/null \
        || open "/System/Applications/System Settings.app" &>/dev/null \
        || true
    if [[ "$hidden" == "true" ]]; then
        osascript "$APPLESCRIPT" "Always" &>/dev/null &
    else
        osascript "$APPLESCRIPT" "Never" &>/dev/null &
    fi
    MENU_BAR_PID=$!
}

wait_for_menu_bar() {
    if [[ -n "${MENU_BAR_PID:-}" ]]; then
        local limit="${HUB_MENU_BAR_TIMEOUT:-60}"
        [[ "$limit" =~ ^[0-9]+$ ]] || limit=60

        local ticks=0
        local max_ticks=$((limit * 10))
        while kill -0 "$MENU_BAR_PID" 2>/dev/null; do
            if [[ "$ticks" -ge "$max_ticks" ]]; then
                warn "Menu bar update timed out"
                kill "$MENU_BAR_PID" 2>/dev/null || true
                sleep 0.2
                kill -9 "$MENU_BAR_PID" 2>/dev/null || true
                break
            fi
            sleep 0.1
            ticks=$((ticks + 1))
        done
        wait "$MENU_BAR_PID" 2>/dev/null || true
        killall "System Settings" 2>/dev/null || true
        MENU_BAR_PID=""
    fi
}

# Hide the Dock and menu bar. Blocks until the menu-bar AppleScript finishes.
_fullscreen_apply() {
    progress_start "Entering fullscreen"
    progress_step "Hiding menu bar…"
    toggle_menu_bar true
    progress_step "Configuring Dock…"
    defaults write com.apple.dock autohide -bool true
    defaults delete com.apple.dock autohide-delay 2>/dev/null || true
    defaults delete com.apple.dock autohide-time-modifier 2>/dev/null || true
    progress_step "Restarting Dock…"
    killall Dock
    wait_for_menu_bar
    progress_step "✓  Done"
    progress_stop
}

# Restore the Dock and menu bar.
_fullscreen_restore() {
    progress_start "Exiting fullscreen"
    progress_step "Restoring menu bar…"
    toggle_menu_bar false
    progress_step "Restoring Dock…"
    defaults write com.apple.dock autohide -bool false
    defaults delete com.apple.dock autohide-delay 2>/dev/null || true
    defaults delete com.apple.dock autohide-time-modifier 2>/dev/null || true
    progress_step "Restarting Dock…"
    killall Dock
    wait_for_menu_bar
    progress_step "✓  Done"
    progress_stop
}

# --- Brew helpers ---

check_brew_package() {
    local pkg="$1"
    local cask="$2"
    # First try brew list; fall back to `which` in case the tap is untrusted
    # but the binary is already on PATH (aerospace with nikitabobko/tap).
    if [[ "$cask" == "true" ]]; then
        brew list --cask "$pkg" &>/dev/null || command -v "$pkg" &>/dev/null
    else
        brew list "$pkg" &>/dev/null || command -v "$pkg" &>/dev/null
    fi
}

install_brew_package() {
    local pkg="$1"
    local cask="$2"
    if [[ "$cask" == "true" ]]; then
        brew trust --cask "$pkg" 2>/dev/null || true
        brew install --cask "$pkg"
    else
        brew install "$pkg"
    fi
}

record_missing_brew_package() {
    local display="$1"
    local install_pkg="$2"
    local cask="$3"
    missing+=("$display")
    missing_install+=("$install_pkg")
    missing_cask+=("$cask")
}

# --- Compile overlay ---

compile_swift() {
    local name="$1"
    local src="$2"
    local bin="$3"
    # Optional 4th arg: extra source file (e.g. theme.swift) compiled alongside src.
    local extra="${4:-}"

    if [[ ! -f "$src" ]]; then
        warn "$name source not found — skipping"
        return
    fi

    # Recompile when binary is older than src, extra source, or this script.
    local needs_build=false
    [[ ! -f "$bin" ]] && needs_build=true
    [[ -f "$bin" && "$src" -nt "$bin" ]] && needs_build=true
    [[ -n "$extra" && -f "$extra" && "$extra" -nt "$bin" ]] && needs_build=true

    if [[ "$needs_build" != true ]]; then
        info "$name up to date"
        return
    fi

    mkdir -p "$(dirname "$bin")"
    if [[ -n "$extra" ]]; then
        # Multi-file Swift: only a file named main.swift may have top-level code.
        # Copy the main source to a temp main.swift so the compiler accepts it.
        local tmp_dir
        tmp_dir="$(mktemp -d "$HUB_RUNTIME_DIR/swift.XXXXXX")"
        cp "$src" "$tmp_dir/main.swift"
        if swiftc -O -o "$bin" -framework Cocoa "$extra" "$tmp_dir/main.swift" 2>/dev/null; then
            success "$name compiled: $bin"
        else
            warn "$name compilation failed"
        fi
        rm -rf "$tmp_dir"
    else
        if swiftc -O -o "$bin" -framework Cocoa "$src" 2>/dev/null; then
            success "$name compiled: $bin"
        else
            warn "$name compilation failed"
        fi
    fi
}

compile_all() {
    echo -e "${bold}Compiling Swift binaries...${reset}"
    # UI binaries are compiled with theme.swift; CLI-only helpers are compiled standalone.
    compile_swift "new_workspace_dialog" "$DIALOG_SRC"        "$DIALOG_BIN"        "$THEME_SRC"
    compile_swift "confirm_dialog"       "$CONFIRM_SRC"       "$CONFIRM_BIN"       "$THEME_SRC"
    compile_swift "rename_dialog"        "$RENAME_SRC"        "$RENAME_BIN"        "$THEME_SRC"
    compile_swift "dashboard_dialog"     "$DASHBOARD_SRC"     "$DASHBOARD_BIN"     "$THEME_SRC"
    compile_swift "output_window"        "$OUTPUT_WINDOW_SRC" "$OUTPUT_WINDOW_BIN" "$THEME_SRC"
    compile_swift "progress_banner"      "$PROGRESS_BANNER_SRC" "$PROGRESS_BANNER_BIN" "$THEME_SRC"
    compile_swift "app_switcher"         "$APP_SWITCHER_SRC"  "$APP_SWITCHER_BIN"  "$THEME_SRC"
    compile_swift "log_viewer"           "$LOG_VIEWER_SRC"    "$LOG_VIEWER_BIN"    "$THEME_SRC"
    compile_swift "hub_bar"           "$HUB_BAR_SRC"    "$HUB_BAR_BIN"    "$THEME_SRC"
    # CLI-only helpers — no UI, no theme
    compile_swift "browser_ctl"          "$BROWSER_CTL_SRC"   "$BROWSER_CTL_BIN"
    compile_swift "spatial_order"        "$SPATIAL_ORDER_SRC" "$SPATIAL_ORDER_BIN"
    compile_swift "float_nudge"          "$FLOAT_NUDGE_SRC"   "$FLOAT_NUDGE_BIN"
    if [[ -f "$REPO_DIR/assets/hub-logo.png" ]]; then
        cp "$REPO_DIR/assets/hub-logo.png" "$HUB_CONFIG_DIR/hub-logo.png"
        success "hub-logo.png deployed"
    fi
    build_http_handler
    build_hub_app
    pin_hub_dock_icon
}

plist_xml_escape() {
    local value="$1"
    value="${value//&/&amp;}"
    value="${value//</&lt;}"
    value="${value//>/&gt;}"
    value="${value//\"/&quot;}"
    value="${value//\'/&apos;}"
    printf '%s' "$value"
}

http_handler_display_name() {
    local browser_name=""
    if [[ -f "$APPS_FILE" ]] && command -v jq >/dev/null 2>&1; then
        browser_name="$(jq -r 'if length > 1 then .[1].name // "" else "" end' "$APPS_FILE" 2>/dev/null || true)"
    fi
    if [[ -n "$browser_name" ]]; then
        printf '%s (via Hub)' "$browser_name"
    else
        printf 'Hub HTTP Handler'
    fi
}

http_handler_app_basename() {
    local display_name="$1"
    local basename="$display_name"
    basename="${basename//\//-}"
    basename="${basename//:/-}"
    printf '%s.app' "$basename"
}

http_handler_app_path() {
    local display_name
    display_name="$(http_handler_display_name)"
    printf '%s/%s' "$HUB_APPLICATIONS_DIR" "$(http_handler_app_basename "$display_name")"
}

http_handler_process_pattern() {
    printf '/Contents/MacOS/%s' "$HTTP_HANDLER_EXECUTABLE"
}

is_http_handler_running() {
    pgrep -qf "$(http_handler_process_pattern)"
}

stop_http_handler() {
    pkill -f "$(http_handler_process_pattern)" 2>/dev/null || true
}

cleanup_stale_http_handlers() {
    local active_app="$1"
    local lsregister="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"
    local candidate plist bundle_id

    for candidate in "$HTTP_HANDLER_LEGACY_APP" "$HUB_APPLICATIONS_DIR/Hub HTTP Handler.app" "$HUB_APPLICATIONS_DIR/"*' (via Hub).app'; do
        [[ -d "$candidate" ]] || continue
        [[ "$candidate" == "$active_app" ]] && continue
        plist="$candidate/Contents/Info.plist"
        [[ -f "$plist" ]] || continue
        bundle_id="$(/usr/libexec/PlistBuddy -c "Print :CFBundleIdentifier" "$plist" 2>/dev/null || true)"
        [[ "$bundle_id" == "$HUB_BROWSER_ID" ]] || continue
        if [[ "${HUB_SKIP_LAUNCH_SERVICES:-0}" != "1" ]]; then
            "$lsregister" -u "$candidate" 2>/dev/null || true
        fi
        rm -rf "$candidate"
    done
}

build_http_handler() {
    local src="$HTTP_HANDLER_SRC"
    local app
    app="$(http_handler_app_path)"
    local display_name
    display_name="$(http_handler_display_name)"
    local escaped_display_name
    escaped_display_name="$(plist_xml_escape "$display_name")"
    local bin="$app/Contents/MacOS/$HTTP_HANDLER_EXECUTABLE"
    local plist="$app/Contents/Info.plist"

    if [[ ! -f "$src" ]]; then
        warn "http_handler source not found — skipping"
        return
    fi

    cleanup_stale_http_handlers "$app"

    if [[ -f "$bin" ]] && [[ "$bin" -nt "$src" ]] && [[ "$bin" -nt "${BASH_SOURCE[0]}" ]]; then
        info "$display_name.app up to date"
        return
    fi

    mkdir -p "$app/Contents/MacOS"
    mkdir -p "$app/Contents/Resources"

    cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>sh.hub.http-handler</string>
    <key>CFBundleName</key>
    <string>$escaped_display_name</string>
    <key>CFBundleDisplayName</key>
    <string>$escaped_display_name</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleExecutable</key>
    <string>$HTTP_HANDLER_EXECUTABLE</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>HTTP URL</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>http</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleURLName</key>
            <string>HTTPS URL</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>https</string>
            </array>
        </dict>
    </array>
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.html</string>
                <string>public.xhtml</string>
            </array>
        </dict>
    </array>
    <key>LSHandlerRank</key>
    <string>Alternate</string>
    <key>LSUIElement</key>
    <true/>
</dict>
</plist>
PLIST

    local tmp_http_dir
    tmp_http_dir="$(mktemp -d "$HUB_RUNTIME_DIR/swift-http.XXXXXX")"
    cp "$src" "$tmp_http_dir/main.swift"
    if swiftc -O -o "$bin" -framework Cocoa "$THEME_SRC" "$tmp_http_dir/main.swift" 2>/dev/null; then
        rm -rf "$tmp_http_dir"
        if [[ "${HUB_SKIP_LAUNCH_SERVICES:-0}" != "1" ]]; then
            # Register with Launch Services so it appears in Default Web Browser list
            /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister \
                -f "$app" 2>/dev/null || true
            # Restart if already running so the new binary takes effect
            if is_http_handler_running; then
                stop_http_handler
                sleep 0.3
                open "$app" &
            fi
        else
            info "Skipped Launch Services registration for $display_name.app"
        fi
        if [[ "${HUB_SKIP_LAUNCH_SERVICES:-0}" == "1" ]]; then
            success "$display_name.app built: $app"
        else
            success "$display_name.app built and registered: $app"
        fi
    else
        rm -rf "$tmp_http_dir"
        warn "$display_name.app compilation failed"
    fi
}

# build_hub_icns <out_icns_path>
# Builds a .icns from assets/hub-logo.png via sips + iconutil. Returns
# non-zero (leaving out_icns_path absent) if the source image or tools
# are unavailable, so callers can fall back to no custom icon.
build_hub_icns() {
    local out_icns="$1"
    [[ -f "$HUB_APP_ICON_SRC" ]] || return 1
    command -v sips >/dev/null 2>&1 || return 1
    command -v iconutil >/dev/null 2>&1 || return 1

    local tmp_dir
    tmp_dir="$(mktemp -d "$HUB_RUNTIME_DIR/icns.XXXXXX")"
    local iconset="$tmp_dir/Hub.iconset"
    mkdir -p "$iconset"

    # Pad the source image to a square so sips can generate uniform icon sizes.
    sips -p 512 512 "$HUB_APP_ICON_SRC" --out "$tmp_dir/padded.png" >/dev/null 2>&1 || {
        rm -rf "$tmp_dir"; return 1
    }

    local size
    for size in 16 32 128 256 512; do
        sips -z "$size" "$size" "$tmp_dir/padded.png" \
            --out "$iconset/icon_${size}x${size}.png" >/dev/null 2>&1 || true
        sips -z $((size * 2)) $((size * 2)) "$tmp_dir/padded.png" \
            --out "$iconset/icon_${size}x${size}@2x.png" >/dev/null 2>&1 || true
    done

    if iconutil -c icns "$iconset" -o "$out_icns" 2>/dev/null; then
        rm -rf "$tmp_dir"
        return 0
    else
        rm -rf "$tmp_dir"
        return 1
    fi
}

# build_hub_app — builds ~/Applications/Hub.app, a Dock-clickable launcher
# that runs `hub toggle` (up if down, down if up).
build_hub_app() {
    local src="$HUB_APP_SRC"
    local app="$HUB_APP_PATH"
    local bin="$app/Contents/MacOS/$HUB_APP_EXECUTABLE"
    local plist="$app/Contents/Info.plist"
    local icns="$app/Contents/Resources/Hub.icns"

    if [[ ! -f "$src" ]]; then
        warn "hub_toggle_app source not found — skipping"
        return
    fi

    if [[ -f "$bin" ]] && [[ "$bin" -nt "$src" ]] && [[ "$bin" -nt "${BASH_SOURCE[0]}" ]] \
        && [[ ! "$HUB_APP_ICON_SRC" -nt "$icns" ]]; then
        info "Hub.app up to date"
        return
    fi

    mkdir -p "$app/Contents/MacOS"
    mkdir -p "$app/Contents/Resources"

    local icon_key=""
    if build_hub_icns "$icns"; then
        icon_key="    <key>CFBundleIconFile</key>
    <string>Hub</string>
"
    else
        rm -f "$icns"
    fi

    cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>$HUB_APP_BUNDLE_ID</string>
    <key>CFBundleName</key>
    <string>Hub</string>
    <key>CFBundleDisplayName</key>
    <string>Hub</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleExecutable</key>
    <string>$HUB_APP_EXECUTABLE</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
${icon_key}</dict>
</plist>
PLIST

    local tmp_dir
    tmp_dir="$(mktemp -d "$HUB_RUNTIME_DIR/swift-hub-app.XXXXXX")"
    cp "$src" "$tmp_dir/main.swift"
    if swiftc -O -o "$bin" -framework Cocoa "$tmp_dir/main.swift" 2>/dev/null; then
        rm -rf "$tmp_dir"
        if [[ "${HUB_SKIP_LAUNCH_SERVICES:-0}" != "1" ]]; then
            /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister \
                -f "$app" 2>/dev/null || true
        fi
        success "Hub.app built: $app"
    else
        rm -rf "$tmp_dir"
        warn "Hub.app compilation failed"
    fi
}

# pin_hub_dock_icon — idempotently adds Hub.app to the Dock's persistent-apps
# list. Safe to call every install: no-ops if already pinned. Restarts the
# live Dock, so it's skipped under --no-launch-services (used by isolated/CI
# installs that must not touch real system state).
pin_hub_dock_icon() {
    [[ "${HUB_SKIP_LAUNCH_SERVICES:-0}" != "1" ]] || return 0
    [[ -x "$HUB_APP_PATH/Contents/MacOS/$HUB_APP_EXECUTABLE" ]] || return 0
    command -v defaults >/dev/null 2>&1 || return 0

    if defaults read com.apple.dock persistent-apps 2>/dev/null | grep -qF "$HUB_APP_BUNDLE_ID"; then
        info "Hub.app already pinned to Dock"
        return 0
    fi

    local file_url="file://$HUB_APP_PATH/"
    defaults write com.apple.dock persistent-apps -array-add \
        "<dict><key>tile-data</key><dict><key>bundle-identifier</key><string>$HUB_APP_BUNDLE_ID</string><key>file-data</key><dict><key>_CFURLString</key><string>$file_url</string><key>_CFURLStringType</key><integer>15</integer></dict><key>file-label</key><string>Hub</string><key>file-type</key><integer>41</integer></dict><key>tile-type</key><string>file-tile</string></dict>" \
        2>/dev/null || { warn "Could not pin Hub.app to Dock"; return; }
    killall Dock 2>/dev/null || true
    success "Hub.app pinned to Dock"
}

